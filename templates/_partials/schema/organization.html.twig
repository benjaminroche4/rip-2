{# Schema.org ProfessionalService + WebSite. Always included; the per-page
   WebPage / Article / Product node is appended via {% block schema_page %}.
   Site-wide constants come from twig.yaml globals (site_url, site_email, …). #}
{
    "@type": "ProfessionalService",
    "@id": "{{ site_url }}/#organization",
    "name": "Relocation in Paris",
    "legalName": "SARL Relocation in Paris",
    "url": "{{ site_url }}",
    "description": "{{ 'schema.description'|trans|e('js') }}",
    "telephone": "{{ site_phone }}",
    "email": "{{ site_email }}",
    "inLanguage": ["fr-FR", "en-GB"],
    "areaServed": {
        "@type": "City",
        "name": "Paris"
    },
    "logo": {
        "@type": "ImageObject",
        "url": "{{ site_url }}/medias/logos/logo_red.svg"
    },
    "image": [
        "{{ site_url }}/medias/banner/relocation-in-paris-banner.webp"
    ],
    "address": {
        "@type": "PostalAddress",
        "streetAddress": "155 Rue du Faubourg Saint-Denis",
        "addressLocality": "Paris",
        "postalCode": "75010",
        "addressRegion": "Île-de-France",
        "addressCountry": "FR"
    },
    "geo": {
        "@type": "GeoCoordinates",
        "latitude": 48.878,
        "longitude": 2.355
    },
    "openingHoursSpecification": [
        {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday","Sunday"],
            "opens": "08:00",
            "closes": "20:00"
        }
    ],
    "priceRange": "À partir de 1190€",
    "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "bestRating": "5",
        "worstRating": "1",
        "ratingCount": "370",
        "reviewCount": "370"
    },
    "sameAs": [
        "https://www.linkedin.com/company/relocation-in-paris/",
        "https://www.instagram.com/relocation_in_paris/"
    ],
    "contactPoint": [
        {
            "@type": "ContactPoint",
            "contactType": "customer service",
            "telephone": "{{ site_phone }}",
            "email": "{{ site_email }}",
            "availableLanguage": ["French", "English", "Spanish"]
        },
        {
            "@type": "ContactPoint",
            "contactType": "customer service",
            "telephone": "{{ site_phone_whatsapp }}",
            "url": "{{ site_whatsapp_url }}",
            "availableLanguage": ["French", "English", "Spanish"]
        }
    ]
},
{
    "@type": "WebSite",
    "@id": "{{ site_url }}/#website",
    "url": "{{ site_url }}",
    "name": "Relocation in Paris",
    "publisher": {
        "@id": "{{ site_url }}/#organization"
    },
    "inLanguage": ["fr-FR", "en-GB"]
}
