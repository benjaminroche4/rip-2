{# Meta block extracted from base.html.twig — included from <head>.
   Caller passes via {% include … with %}: pageTitle, pageDescription, pageUrl, pageOgImage. #}

{# Hreflang #}
{% set currentPath = app.request.pathinfo|replace({('/' ~ app.request.locale): ''}) %}
<link rel="alternate" hreflang="fr" href="https://relocation-in-paris.fr/fr{{ currentPath }}" />
<link rel="alternate" hreflang="en" href="https://relocation-in-paris.fr/en{{ currentPath }}" />
<link rel="alternate" hreflang="x-default" href="https://relocation-in-paris.fr/fr{{ currentPath }}" />

{# Preconnect to external origins used for above-the-fold resources #}
<link rel="preconnect" href="https://cdn.sanity.io" crossorigin>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="dns-prefetch" href="https://maps.googleapis.com">
<link rel="dns-prefetch" href="https://maps.gstatic.com">

{# Google Fonts — non-blocking via print media swap #}
<link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,200..800&display=swap">
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,200..800&display=swap" media="print" onload="this.media='all'">
<noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,200..800&display=swap"></noscript>

<link rel="icon" type="image/jpg" href="{{ asset('medias/favicon/favicon.ico') }}" sizes="32x32">
<link rel="apple-touch-icon" sizes="180x180" href="{{ asset('medias/favicon/apple-touch-icon.png') }}">

{# Open Graph #}
<meta property="og:type" content="website">
<meta property="og:site_name" content="Relocation In Paris">
<meta property="og:locale" content="{{ app.request.locale == 'fr' ? 'fr_FR' : 'en_GB' }}">
<meta property="og:locale:alternate" content="{{ app.request.locale == 'fr' ? 'en_GB' : 'fr_FR' }}">
<meta property="og:title" content="Relocation In Paris - {{ pageTitle }}">
<meta property="og:url" content="https://relocation-in-paris.fr{{ pageUrl }}">
<meta property="og:image" content="{{ pageOgImage }}">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<meta property="og:description" content="{{ pageDescription }}">

{# Twitter Card #}
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="Relocation In Paris - {{ pageTitle }}">
<meta name="twitter:description" content="{{ pageDescription }}">
<meta name="twitter:image" content="{{ pageOgImage }}">
