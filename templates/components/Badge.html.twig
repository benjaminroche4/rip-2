{# @prop variant 'default'|'secondary'|'destructive'|'outline' The variant, default to `default` #}
{# @block content The default block #}
{%- props variant = 'default' -%}
{%- set style = html_cva(
    base: 'inline-flex items-center rounded-md border gap-x-1.5 px-2.5 py-0.5 text-xs font-medium transition-colors focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2',
    variants: {
        variant: {
            default: 'text-primary bg-[#FFF4F6] border border-[#F3C7D2]',
            primary: 'border-transparent bg-primary text-white',
            secondary: 'border-transparent bg-slate-100 text-gray-900',
            destructive: 'border-slate-100 bg-slate-50 text-slate-600 rounded-full',
            outline: 'text-foreground',
            success: 'text-green-700 bg-green-50 border border-green-100',
            warning: 'text-amber-700 bg-amber-50 border border-amber-100',
            info: 'text-blue-700 bg-blue-50 border border-blue-100',
        },
    },
) -%}
<div
    class="{{ style.apply({variant: variant}, attributes.render('class'))|tailwind_merge }}"
    {{ attributes }}
>
    {%- block content %}{% endblock -%}
</div>
