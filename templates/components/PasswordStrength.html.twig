{# Anonymous component — renders a password-strength indicator that watches another
   input field. Pass `inputId` (the password input's DOM id) and optionally extra
   `class` styling.

   The whole component fades in only after the user starts typing — the controller
   toggles `opacity-0` based on the computed score (0 ⇔ empty input).

   Strength scoring runs client-side in the password-strength Stimulus controller;
   the authoritative check still runs server-side via Assert\PasswordStrength +
   Assert\NotCompromisedPassword on the DTO. #}
{% set inputId = inputId|default('') %}
{% set class = class|default('') %}
{# Tailwind safelist — these tone classes are added dynamically by the Stimulus
   controller (assets/controllers/password_strength_controller.js), so they must be
   referenced in a template to make it into the compiled CSS:
   bg-red-400 bg-amber-400 bg-lime-500 bg-emerald-500 #}
<div
    data-controller="password-strength"
    data-password-strength-input-id-value="{{ inputId }}"
    data-password-strength-weak-label-value="{{ 'register.passwordStrength.weak'|trans }}"
    data-password-strength-medium-label-value="{{ 'register.passwordStrength.medium'|trans }}"
    data-password-strength-good-label-value="{{ 'register.passwordStrength.good'|trans }}"
    data-password-strength-strong-label-value="{{ 'register.passwordStrength.strong'|trans }}"
    class="mt-2 hidden {{ class }}"
>
    <div
        role="progressbar"
        aria-valuemin="0"
        aria-valuemax="4"
        aria-valuenow="0"
        aria-label="{{ 'register.passwordStrength.label'|trans }}"
        data-password-strength-target="track"
        class="flex gap-1"
    >
        <span data-password-strength-target="segment" class="h-1 flex-1 rounded-sm bg-neutral-200 transition-colors duration-300 ease-out"></span>
        <span data-password-strength-target="segment" class="h-1 flex-1 rounded-sm bg-neutral-200 transition-colors duration-300 ease-out"></span>
        <span data-password-strength-target="segment" class="h-1 flex-1 rounded-sm bg-neutral-200 transition-colors duration-300 ease-out"></span>
        <span data-password-strength-target="segment" class="h-1 flex-1 rounded-sm bg-neutral-200 transition-colors duration-300 ease-out"></span>
    </div>
    <p
        data-password-strength-target="label"
        aria-live="polite"
        class="mt-1 min-h-4 text-xs font-light text-neutral-500"
    >&nbsp;</p>
</div>
