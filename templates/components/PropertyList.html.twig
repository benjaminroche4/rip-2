<div {{ attributes }}
    data-controller="property-list"
    data-property-list-map-markers-outlet="[data-controller*='map-markers']"
>
    {# Filters #}
    <div class="mb-6 flex flex-wrap items-center gap-3">
        <select data-model="on(change)|propertyType" class="rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm text-neutral-700 focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary">
            <option value="">Tous les types</option>
            {% for type in this.availablePropertyTypes %}
                <option value="{{ type }}" {{ propertyType == type ? 'selected' : '' }}>{{ type }}</option>
            {% endfor %}
        </select>

        <select data-model="on(change)|leaseType" class="rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm text-neutral-700 focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary">
            <option value="" {{ leaseType == '' ? 'selected' : '' }}>Toutes durées</option>
            <option value="longTerm" {{ leaseType == 'longTerm' ? 'selected' : '' }}>Long terme</option>
            <option value="midTerm" {{ leaseType == 'midTerm' ? 'selected' : '' }}>Moyen terme</option>
        </select>

        {% if propertyType or leaseType %}
            <button
                type="button"
                data-action="live#action"
                data-live-action-param="resetFilters"
                class="rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm text-neutral-500 hover:text-neutral-700 hover:border-slate-300 transition-colors"
            >
                Réinitialiser
            </button>
        {% endif %}
    </div>

    {# Two-column layout #}
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-x-8">
        <div>
            {% set properties = this.filteredProperties %}
            {% if properties is empty %}
                <div class="text-center py-20 text-neutral-500">
                    <p class="text-lg">Aucun bien ne correspond à vos critères.</p>
                </div>
            {% else %}
                <p class="text-sm text-neutral-500 mb-8">
                    {{ properties|length }} {{ properties|length > 1 ? 'biens' : 'bien' }}
                </p>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    {% for property in properties %}
                        <article
                            id="property-{{ property.uniqueId }}"
                            class="flex flex-col border border-slate-200 rounded-2xl bg-white p-1.5 cursor-pointer"
                            data-property-list-target="card"
                            data-marker-key="{{ property.address.street|default(property.title|default(property.uniqueId)) }}"
                            {% if property.location.lat is defined and property.location.lng is defined and property.location.lat and property.location.lng %}
                                data-action="click->live#action"
                                data-live-action-param="centerOn"
                                data-live-lat-param="{{ property.location.lat }}"
                                data-live-lng-param="{{ property.location.lng }}"
                            {% endif %}
                        >
                            {# Carousel #}
                            <div class="relative aspect-3/2 border border-slate-100 rounded-xl bg-slate-50 overflow-hidden group" data-controller="carousel">
                                <div class="flex h-full transition-transform duration-300 ease-out cursor-grab active:cursor-grabbing" data-carousel-target="track">
                                    {% for photo in property.photos[:5] %}
                                        <div class="w-full h-full shrink-0">
                                            <img
                                                src="{{ photo.url }}?w=600&h=400&fit=crop&auto=format&q=80"
                                                alt="{{ photo.alt|default(property.title|default('Bien immobilier')) }}"
                                                loading="lazy"
                                                width="600"
                                                height="400"
                                                class="w-full h-full object-cover pointer-events-none select-none"
                                                draggable="false"
                                            />
                                        </div>
                                    {% endfor %}
                                </div>
                                {% if property.photos|length > 1 %}
                                    <div class="absolute bottom-2 left-1/2 -translate-x-1/2 flex gap-1.5 bg-gray-900/40 group-hover:bg-gray-900/70 transition duration-100 rounded-full px-1.5 py-1" data-carousel-target="dots">
                                        {% for photo in property.photos[:5] %}
                                            <button
                                                type="button"
                                                class="size-1.5 rounded-full transition-colors duration-200 {{ loop.first ? 'bg-white' : 'bg-white/50' }}"
                                                data-carousel-target="dot"
                                                data-action="carousel#goTo"
                                                data-index="{{ loop.index0 }}"
                                            ></button>
                                        {% endfor %}
                                    </div>
                                {% endif %}
                            </div>

                            {# Card body #}
                            <div class="px-2 py-3 flex flex-col flex-1 space-y-4">
                                {% if property.availableDate is defined and property.availableDate %}
                                    <div>
                                        <twig:Badge variant="primary" class="rounded-lg bg-[#EFFDF4] border border-green-100 font-light text-green-600 gap-x-2 px-1">
                                            {% if property.agentPhoto is defined and property.agentPhoto %}
                                                <img
                                                    src="{{ property.agentPhoto }}?w=48&h=48&fit=crop&auto=format&q=80"
                                                    alt=""
                                                    loading="lazy"
                                                    width="24"
                                                    height="24"
                                                    class="size-5 rounded-full outline outline-1 -outline-offset-1 outline-black/5"
                                                />
                                            {% endif %}
                                            {% if property.availableDate|date('Y-m-d') <= 'now'|date('Y-m-d') %}
                                                <p class="font-semibold">Disponible immédiatement</p>
                                            {% else %}
                                                <p>À partir du <span class="font-semibold">{{ property.availableDate|date('d/m/Y') }}</span></p>
                                            {% endif %}
                                        </twig:Badge>
                                    </div>
                                {% endif %}
                                <div class="space-y-1">
                                    <div>
                                        {% if property.monthlyRent %}
                                            <p class="text-primary text-xl font-semibold">{{ property.monthlyRent|number_format(0, ',', ' ') }}€<span class="text-gray-600 text-sm font-light ml-1">/mois CC</span></p>
                                        {% else %}
                                            <p class="text-primary text-xl font-semibold">Prix sur demande</p>
                                        {% endif %}
                                    </div>
                                    {% if property.title %}
                                        <h3 class="font-semibold">{{ property.title }}</h3>
                                    {% endif %}
                                    {% if property.address is defined and property.address %}
                                        <div>
                                            <address class="not-italic text-gray-500 text-sm flex items-center gap-x-1">
                                                {{ ux_icon('gg:pin', {'class': 'size-4 shrink-0'}) }}
                                                {% if property.address.street %}{{ property.address.street }}, {% endif %}{{ property.address.city }}{% if property.address.postalCode %} {{ property.address.postalCode }}{% endif %}
                                            </address>
                                        </div>
                                    {% endif %}
                                </div>
                                <div class="bg-neutral-50 rounded-lg p-2 grid grid-cols-3 divide-x divide-gray-200">
                                    <div class="flex items-center justify-center gap-x-1">
                                        {{ ux_icon('ic:outline-bed', {'class': 'size-5 text-gray-800 shrink-0'}) }}
                                        <p class="text-sm font-light">{{ property.bedrooms ?? '-' }} ch.</p>
                                    </div>
                                    <div class="flex items-center justify-center gap-x-1">
                                        {{ ux_icon('material-symbols:door-open-outline', {'class': 'size-5 text-gray-800 shrink-0'}) }}
                                        <p class="text-sm font-light">{{ property.rooms ?? '-' }} p.</p>
                                    </div>
                                    <div class="flex items-center justify-center gap-x-1">
                                        {{ ux_icon('solar:maximize-square-linear', {'class': 'size-5 text-gray-800 shrink-0'}) }}
                                        <p class="text-sm font-light">{{ property.surface ? property.surface ~ ' m²' : '-' }}</p>
                                    </div>
                                </div>
                            </div>
                        </article>
                    {% endfor %}
                </div>
            {% endif %}
        </div>

        {# Map #}
        <aside class="rounded-3xl p-2 border border-neutral-200" data-controller="map-markers map-restriction">
            {{ ux_map(map, {style: 'height: 100%;', 'class': 'rounded-2xl'}) }}
        </aside>
    </div>
</div>
