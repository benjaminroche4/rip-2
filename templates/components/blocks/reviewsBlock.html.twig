<section class="px-6 py-12 sm:py-16 lg:px-8 max-w-7xl mx-auto">
    <div class="border border-neutral-200 py-12 px-6 rounded-3xl bg-neutral-50">
        <div class="flex flex-col space-y-3 justify-center text-center">
            <p class="font-semibold text-primary font-secondary">{{ 'reviews.title'|trans|raw }}</p>
            <h2 class="text-3xl sm:text-4xl font-medium text-pretty">{{ 'reviews.subTitle'|trans|raw }}</h2>
            <div class="flex items-center justify-center mt-3 gap-x-3">
                {{ ux_icon('devicon:google', {'class':'size-5 shrink-0'}) }}
                <p class="text-neutral-600 font-light text-pretty"><span class="font-semibold">{{ 'reviews.info.number'|trans({'%count%': google_reviews_count})|raw }}</span> {{ 'reviews.info.text'|trans|raw }} <a href="https://share.google/c8msBrKphxqVY03er" target="_blank" rel="noopener noreferrer nofollow" class="underline underline-offset-4 hover:text-primary transition duration-100">{{ 'reviews.info.google'|trans|raw }}</a></p>
            </div>
        </div>
        <div
            class="mt-10 -mx-6 overflow-hidden"
            data-controller="reviews-swiper"
            data-reviews-swiper-autoplay-value="true"
            data-reviews-swiper-autoplay-delay-value="4000"
        >
            <div class="flex gap-6 px-6" data-reviews-swiper-target="track">
                {% for i in 1..6 %}
                    <div class="shrink-0 flex flex-col gap-5 bg-white rounded-2xl p-6 border border-neutral-200" data-reviews-swiper-target="card">
                        <div class="flex flex-col min-[410px]:flex-row gap-2 min-[410px]:items-center justify-between">
                            <div class="flex items-center gap-x-4">
                                <img
                                    src="{{ asset('medias/reviews/user-'~ i ~'.webp')|trans }}"
                                    alt="{{ ('reviews.' ~ i ~ '.alt')|trans|raw }}"
                                    loading="lazy"
                                    width="40"
                                    height="40"
                                    class="size-10 rounded-full outline outline-1 -outline-offset-1 outline-black/5"
                                />
                                <div class="flex flex-col">
                                    <p class="font-medium">{{ ('reviews.' ~ i ~ '.name')|trans|raw }}</p>
                                    <p class="text-slate-600 text-xs">{{ ('reviews.' ~ i ~ '.date')|trans|raw }}</p>
                                </div>
                            </div>
                            <div class="inline-block">
                                {% if ('reviews.' ~ i ~ '.from')|trans == 'Trustpilot' %}
                                    <twig:Badge variant="secondary" class="rounded-full font-medium gap-x-1.5">
                                        {{ ux_icon('simple-icons:trustpilot', {'class': 'size-4 fill-[#4FAC7A] text-[#4FAC7A] srhink-0'}) }}
                                        {{ ('reviews.' ~ i ~ '.from')|trans|raw }}
                                    </twig:Badge>
                                {% endif %}
                                {% if ('reviews.' ~ i ~ '.from')|trans == 'Google' %}
                                    <twig:Badge variant="secondary" class="rounded-full font-medium gap-x-1.5">
                                        {{ ux_icon('devicon:google', {'class': 'size-4 srhink-0'}) }}
                                        {{ ('reviews.' ~ i ~ '.from')|trans|raw }}
                                    </twig:Badge>
                                {% endif %}
                            </div>
                        </div>
                        <div class="h-[1px] bg-gradient-to-r from-slate-400/20 via-slate-500 to-slate-400/20 opacity-20"></div>
                        <div class="flex gap-2 items-center">
                            <div class="flex gap-1 items-center" role="img" aria-label="Note : 5 sur 5">
                                {% for s in 1..5 %}
                                    {{ ux_icon('iconamoon:star-fill', {'class': 'size-4 fill-yellow-400 text-yellow-400 srhink-0'}) }}
                                {% endfor %}
                            </div>
                            <p class="font-semibold" aria-hidden="true">5.0</p>
                        </div>
                        <p class="text-neutral-900 text-pretty leading-relaxed flex-1">{{ ('reviews.' ~ i ~ '.text')|trans|raw }}</p>
                    </div>
                {% endfor %}
            </div>
            <div class="flex justify-center gap-2 mt-6">
                {% for d in 0..5 %}
                    <button
                        class="h-2 rounded-full transition-all duration-200 {{ d == 0 ? 'w-4 bg-primary' : 'w-2 bg-neutral-300' }}"
                        data-reviews-swiper-target="indicator"
                        data-action="click->reviews-swiper#goTo"
                        data-index="{{ d }}"
                        aria-label="Aller à l'avis {{ d + 1 }}"
                    ></button>
                {% endfor %}
            </div>
        </div>
        <div class="mt-10 flex items-center justify-center">
            <twig:Button variant="default" as="a" size="lg" href="{{ path('app_contact') }}">
                <img
                    src="{{ asset('medias/team/team_1.webp') }}"
                    alt="{{ 'header.menu.findTenant.imgAlt'|trans|raw }}"
                    loading="lazy"
                    width="24"
                    height="24"
                    class="size-6 rounded-full outline outline-1 -outline-offset-1 outline-black/5"
                />
                {{ 'ctaFooter.button'|trans|raw }}
            </twig:Button>
        </div>
    </div>
</section>
