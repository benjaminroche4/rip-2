{%- props line, size = 'default' -%}
{% set lines = {
    '1': {color: '#FFCD00', textColor: '#000'},
    '2': {color: '#003CA6', textColor: '#fff'},
    '3': {color: '#837902', textColor: '#fff'},
    '3bis': {color: '#6EC4E8', textColor: '#000'},
    '4': {color: '#CF009E', textColor: '#fff'},
    '5': {color: '#FF7E2E', textColor: '#000'},
    '6': {color: '#6ECA97', textColor: '#000'},
    '7': {color: '#FA9ABA', textColor: '#000'},
    '7bis': {color: '#6ECA97', textColor: '#000'},
    '8': {color: '#E19BDF', textColor: '#000'},
    '9': {color: '#B6BD00', textColor: '#000'},
    '10': {color: '#C9910D', textColor: '#fff'},
    '11': {color: '#704B1C', textColor: '#fff'},
    '12': {color: '#007852', textColor: '#fff'},
    '13': {color: '#6EC4E8', textColor: '#000'},
    '14': {color: '#62259D', textColor: '#fff'},
    'A': {color: '#F7403A', textColor: '#fff'},
    'B': {color: '#4B92DB', textColor: '#fff'},
    'C': {color: '#F3D311', textColor: '#000'},
    'D': {color: '#45A04A', textColor: '#fff'},
    'E': {color: '#E04DA7', textColor: '#fff'},
} %}
{% set data = lines[line]|default({color: '#6B7280', textColor: '#fff'}) %}
{% set isRer = line in ['A', 'B', 'C', 'D', 'E'] %}
{% set sizeClasses = size == 'sm' ? 'size-5 text-[10px]' : 'size-6 text-xs' %}
<span
    class="inline-flex items-center justify-center {{ isRer ? 'rounded' : 'rounded-full' }} font-bold shrink-0 {{ sizeClasses }}"
    style="background-color: {{ data.color }}; color: {{ data.textColor }}"
    {{ attributes }}
>
    {{ line }}
</span>
