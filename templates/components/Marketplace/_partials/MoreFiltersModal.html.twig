{# More filters modal. Rendered inside a `group/mf` + `more-filters-modal` controller. #}
{% set t = 'marketplace.list.search.' %}
{% set sectionHead = 'flex items-center gap-2 px-1 text-base font-medium text-gray-900' %}
{% set sectionIcon = 'size-[18px] shrink-0 text-primary' %}
{% set checkboxClass = 'size-3.5 shrink-0 rounded-[4px] border-slate-300 text-primary focus:ring-primary/40' %}
{% set optionRow = 'flex items-center gap-2 px-2 py-1.5 rounded-md cursor-pointer hover:bg-slate-50 text-base text-gray-600' %}

{# Backdrop #}
<div data-action="more-filters-modal#close"
    class="fixed inset-0 z-50 bg-black/60 invisible opacity-0 group-data-open/mf:visible group-data-open/mf:opacity-100 transition-opacity duration-200"></div>

{# Panel #}
<div role="dialog" aria-modal="true" tabindex="-1" aria-label="{{ (t ~ 'moreFiltersModal.title')|trans }}"
    data-more-filters-modal-target="dialog"
    class="fixed z-50 bg-white flex flex-col text-left invisible opacity-0 group-data-open/mf:visible group-data-open/mf:opacity-100 transition duration-200
           max-lg:inset-x-0 max-lg:bottom-0 max-lg:max-h-[90vh] max-lg:rounded-t-2xl max-lg:translate-y-full max-lg:group-data-open/mf:translate-y-0 max-lg:shadow-2xl
           lg:top-1/2 lg:left-1/2 lg:-translate-x-1/2 lg:-translate-y-1/2 lg:w-[560px] lg:max-w-[calc(100vw-2rem)] lg:max-h-[calc(100vh-4rem)] lg:rounded-2xl lg:shadow-xl">

    {# Header #}
    <div class="flex items-start justify-between gap-4 p-5 shrink-0">
        <div class="flex flex-col">
            <p class="font-secondary font-medium text-xl text-gray-900">{{ (t ~ 'moreFiltersModal.title')|trans }}</p>
            <p class="text-base text-gray-500">{{ (t ~ 'moreFiltersModal.subtitle')|trans }}</p>
        </div>
        <button type="button" data-action="more-filters-modal#close" aria-label="{{ (t ~ 'moreFiltersModal.close')|trans }}"
            class="shrink-0 text-gray-400 hover:text-gray-700 transition-colors cursor-pointer">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="size-5" aria-hidden="true">
                <path d="M6 18 18 6M6 6l12 12" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
        </button>
    </div>

    {# Body #}
    <div class="flex flex-col gap-5 px-5 overflow-y-auto">
        {# Budget #}
        <div class="flex flex-col gap-3">
            <div class="{{ sectionHead }} text-base">
                {{ ux_icon('iconoir:euro', {'class': sectionIcon}) }}
                {{ (t ~ 'budget.title')|trans }}
            </div>
            <div class="bg-[#f7f7f7] rounded-xl p-3 flex flex-col gap-4"
                data-controller="range-slider"
                data-range-slider-locale-value="{{ locale }}"
                data-range-slider-floor-value="800">
                <div class="text-center">
                    <p class="font-secondary font-semibold text-xl text-gray-900" data-range-slider-target="output">€{{ (draftRentMin ?? 800)|number_format(0, '.', ',') }}</p>
                    <p class="text-xs text-gray-500">{{ (t ~ 'budget.label')|trans }}</p>
                </div>
                <input type="range" min="800" max="10000" step="100" value="{{ draftRentMin ?? 800 }}"
                    data-model="norender|draftRentMin"
                    data-range-slider-target="input"
                    data-action="input->range-slider#update change->more-filters-modal#recount"
                    aria-label="{{ (t ~ 'budget.title')|trans }}"
                    class="budget-slider w-full" />
                <div class="flex items-center justify-between text-xs font-semibold text-gray-900">
                    <span>€800</span>
                    <span>€10000+</span>
                </div>
            </div>
        </div>

        {# Two-column: features | availability #}
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-5 gap-y-5">
            <div class="flex flex-col gap-2">
                <div class="{{ sectionHead }}">
                    {{ ux_icon('iconoir:home-simple', {'class': sectionIcon}) }}
                    {{ (t ~ 'features.title')|trans }}
                </div>
                {% for f in this.featureOptions %}
                    <label class="{{ optionRow }}">
                        <input type="checkbox" data-model="norender|draftFeatures" value="{{ f }}" {{ f in draftFeatures ? 'checked' }}
                            data-action="more-filters-modal#recount" class="{{ checkboxClass }}" />
                        <span class="truncate">{{ (t ~ 'features.' ~ f)|trans }}</span>
                    </label>
                {% endfor %}
            </div>

            <div class="flex flex-col gap-2">
                <div class="{{ sectionHead }}">
                    {{ ux_icon('iconoir:calendar', {'class': sectionIcon}) }}
                    {{ (t ~ 'availability.title')|trans }}
                </div>
                <label class="{{ optionRow }}">
                    <input type="radio" name="draftAvailability" data-model="norender|draftAvailability" value="now" {{ draftAvailability == 'now' ? 'checked' }}
                        data-action="more-filters-modal#recount" class="{{ checkboxClass }}" />
                    <span class="truncate">{{ (t ~ 'availability.now')|trans }}</span>
                </label>
                <label class="{{ optionRow }}">
                    <input type="radio" name="draftAvailability" data-model="norender|draftAvailability" value="30days" {{ draftAvailability == '30days' ? 'checked' }}
                        data-action="more-filters-modal#recount" class="{{ checkboxClass }}" />
                    <span class="truncate">{{ (t ~ 'availability.days30')|trans }}</span>
                </label>
            </div>
        </div>

        {# Transport #}
        <div class="flex flex-col gap-2">
            <div class="{{ sectionHead }}">
                {# tram #}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" class="{{ sectionIcon }}" aria-hidden="true">
                    <rect x="6" y="3" width="12" height="13" rx="2"/><path d="M6 9h12M10 3V2m4 1V2M9 20l-2 2m8-2 2 2" stroke-linecap="round"/>
                    <circle cx="9" cy="12.5" r="0.6" fill="currentColor"/><circle cx="15" cy="12.5" r="0.6" fill="currentColor"/>
                </svg>
                {{ (t ~ 'transport.title')|trans }}
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-5">
                <label class="{{ optionRow }}">
                    <input type="checkbox" data-model="norender|draftNearMetro" {{ draftNearMetro ? 'checked' }}
                        data-action="more-filters-modal#recount" class="{{ checkboxClass }}" />
                    <span class="truncate">{{ (t ~ 'transport.metro')|trans }}</span>
                </label>
                <label class="{{ optionRow }}">
                    <input type="checkbox" data-model="norender|draftNearRer" {{ draftNearRer ? 'checked' }}
                        data-action="more-filters-modal#recount" class="{{ checkboxClass }}" />
                    <span class="truncate">{{ (t ~ 'transport.rer')|trans }}</span>
                </label>
            </div>
        </div>
    </div>

    {# Footer #}
    <div class="flex flex-col gap-3 p-5 shrink-0">
        <div class="h-px w-full bg-linear-to-r from-transparent via-slate-200 to-transparent"></div>
        <div class="flex items-center justify-between gap-3">
            <button type="button" data-action="more-filters-modal#reset"
                class="px-3 h-[38px] rounded-lg bg-[#f7f7f7] hover:bg-[#efefef] text-sm font-medium text-gray-900 transition-colors cursor-pointer">
                {{ (t ~ 'moreFiltersModal.reset')|trans }}
            </button>
            <div class="flex items-center gap-3">
                <span class="text-base text-gray-500">
                    <span data-more-filters-modal-target="count">{{ this.draftMoreFiltersCount }}</span> {{ (t ~ 'moreFiltersModal.selected')|trans }}
                </span>
                <button type="button" data-action="live#action more-filters-modal#close" data-live-action-param="search"
                    class="px-4 h-[38px] rounded-lg bg-primary hover:bg-primary/90 text-sm font-medium text-white transition-colors cursor-pointer">
                    {{ (t ~ 'moreFiltersModal.apply')|trans }}
                </button>
            </div>
        </div>
    </div>
</div>
