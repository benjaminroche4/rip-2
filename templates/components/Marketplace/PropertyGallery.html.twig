{# @prop property  Property DTO with mainPhoto, photos, title #}
{# @prop locale    string current locale, used as alt fallback #}
{%- props property, locale = 'fr' -%}

{%- set gridPhotos = [] -%}
{%- set galleryPhotos = [] -%}
{%- if property.mainPhoto.url is defined and property.mainPhoto.url -%}
    {%- set gridPhotos = gridPhotos|merge([property.mainPhoto]) -%}
    {%- set galleryPhotos = galleryPhotos|merge([property.mainPhoto]) -%}
{%- endif -%}
{%- for photo in property.photos|default([]) -%}
    {%- if photo.url and photo.url != property.mainPhoto.url|default('') -%}
        {%- if gridPhotos|length < 4 -%}
            {%- set gridPhotos = gridPhotos|merge([photo]) -%}
        {%- endif -%}
        {%- set galleryPhotos = galleryPhotos|merge([photo]) -%}
    {%- endif -%}
{%- endfor -%}

<section
    {{ attributes.defaults({class: "bg-neutral-50 rounded-2xl p-2"}) }}
    data-controller="gallery"
    data-gallery-photos-value="{{ galleryPhotos|map(p => {url: p.url, alt: p.alt|default(property.title)})|json_encode|e('html_attr') }}"
>
    {# Mobile/tablet: 1 main square + 3 squares below #}
    <div class="lg:hidden max-w-3xl mx-auto space-y-3">
        {% if gridPhotos[0] is defined %}
            <button type="button" data-action="gallery#open" aria-label="{{ 'marketplace.show.gallery.viewPhotos'|trans }}" class="relative block w-full aspect-square cursor-pointer focus-visible:ring-2 focus-visible:ring-primary/50 focus-visible:outline-none focus-visible:rounded-2xl after:absolute after:inset-0 after:rounded-2xl after:bg-black/0 hover:after:bg-black/20 after:transition after:duration-100">
                <img
                    src="{{ gridPhotos[0].url }}?w=900&h=900&fit=crop&auto=format&fm=webp&q=80"
                    srcset="{{ gridPhotos[0].url }}?w=600&h=600&fit=crop&auto=format&fm=webp&q=80 600w,
                            {{ gridPhotos[0].url }}?w=900&h=900&fit=crop&auto=format&fm=webp&q=80 900w,
                            {{ gridPhotos[0].url }}?w=1200&h=1200&fit=crop&auto=format&fm=webp&q=80 1200w"
                    sizes="(max-width: 1024px) 100vw, 48rem"
                    alt="{{ gridPhotos[0].alt|default(property.title) }}"
                    width="900"
                    height="900"
                    draggable="false"
                    class="w-full h-full object-cover rounded-2xl"
                />
            </button>
        {% endif %}

        {% set remainingCount = galleryPhotos|length - 4 %}
        <div class="grid grid-cols-3 gap-3">
            {% for i in 1..3 %}
                {% if gridPhotos[i] is defined %}
                    {% set isLast = (i == 3) and (remainingCount > 0) %}
                    <button type="button" data-action="gallery#open" aria-label="{{ 'marketplace.show.gallery.viewPhoto'|trans({'%n%': i + 1}) }}" class="relative block aspect-square cursor-pointer focus-visible:ring-2 focus-visible:ring-primary/50 focus-visible:outline-none focus-visible:rounded-xl {{ isLast ? '' : 'after:absolute after:inset-0 after:rounded-xl after:bg-black/0 hover:after:bg-black/20 after:transition after:duration-100' }}">
                        <img
                            src="{{ gridPhotos[i].url }}?w=400&h=400&fit=crop&auto=format&fm=webp&q=75"
                            srcset="{{ gridPhotos[i].url }}?w=300&h=300&fit=crop&auto=format&fm=webp&q=75 300w,
                                    {{ gridPhotos[i].url }}?w=400&h=400&fit=crop&auto=format&fm=webp&q=75 400w,
                                    {{ gridPhotos[i].url }}?w=600&h=600&fit=crop&auto=format&fm=webp&q=75 600w"
                            sizes="(max-width: 1024px) 33vw, 16rem"
                            alt="{{ gridPhotos[i].alt|default(property.title) }}"
                            width="400"
                            height="400"
                            loading="lazy"
                            decoding="async"
                            draggable="false"
                            class="w-full h-full rounded-xl object-cover"
                        />
                        {% if isLast %}
                            <span class="absolute inset-0 rounded-xl bg-black/50 hover:bg-black/60 transition-colors duration-100 flex items-center justify-center text-white font-semibold text-2xl">
                                +{{ remainingCount }}
                            </span>
                        {% endif %}
                    </button>
                {% endif %}
            {% endfor %}
        </div>
    </div>

    {# Desktop: 8-col grid layout #}
    <div class="hidden lg:grid grid-cols-8 gap-3">
        <div class="col-span-3">
            {% if gridPhotos[0] is defined %}
                <button type="button" data-action="gallery#open" data-gallery-index-param="0" aria-label="{{ 'marketplace.show.gallery.viewPhoto'|trans({'%n%': 1}) }}" class="relative w-full h-full cursor-pointer focus-visible:ring-2 focus-visible:ring-primary/50 focus-visible:outline-none focus-visible:rounded-xl after:absolute after:inset-0 after:rounded-xl after:bg-black/0 hover:after:bg-black/20 after:transition after:duration-100">
                    <img
                        src="{{ gridPhotos[0].url }}?w=900&h=600&fit=crop&auto=format&fm=webp&q=80"
                        srcset="{{ gridPhotos[0].url }}?w=600&h=400&fit=crop&auto=format&fm=webp&q=80 600w,
                                {{ gridPhotos[0].url }}?w=900&h=600&fit=crop&auto=format&fm=webp&q=80 900w,
                                {{ gridPhotos[0].url }}?w=1200&h=800&fit=crop&auto=format&fm=webp&q=80 1200w"
                        sizes="37.5vw"
                        alt="{{ gridPhotos[0].alt|default(property.title) }}"
                        width="900"
                        height="600"
                        draggable="false"
                        class="w-full h-full object-cover rounded-xl"
                    />
                </button>
            {% endif %}
        </div>
        <div class="col-span-2 flex flex-col gap-3">
            {% for i in 1..2 %}
                {% if gridPhotos[i] is defined %}
                    <button type="button" data-action="gallery#open" data-gallery-index-param="{{ i }}" aria-label="{{ 'marketplace.show.gallery.viewPhoto'|trans({'%n%': i + 1}) }}" class="relative flex-1 min-h-0 w-full cursor-pointer focus-visible:ring-2 focus-visible:ring-primary/50 focus-visible:outline-none focus-visible:rounded-xl after:absolute after:inset-0 after:rounded-xl after:bg-black/0 hover:after:bg-black/20 after:transition after:duration-100">
                        <img
                            src="{{ gridPhotos[i].url }}?w=600&h=400&fit=crop&auto=format&fm=webp&q=75"
                            srcset="{{ gridPhotos[i].url }}?w=400&h=267&fit=crop&auto=format&fm=webp&q=75 400w,
                                    {{ gridPhotos[i].url }}?w=600&h=400&fit=crop&auto=format&fm=webp&q=75 600w"
                            sizes="25vw"
                            alt="{{ gridPhotos[i].alt|default(property.title) }}"
                            width="600"
                            height="400"
                            loading="lazy"
                            decoding="async"
                            draggable="false"
                            class="w-full h-full rounded-xl object-cover"
                        />
                    </button>
                {% endif %}
            {% endfor %}
        </div>
        <div class="col-span-3 relative">
            {% if gridPhotos[3] is defined %}
                <button type="button" data-action="gallery#open" data-gallery-index-param="3" aria-label="{{ 'marketplace.show.gallery.viewPhoto'|trans({'%n%': 4}) }}" class="relative w-full h-full cursor-pointer focus-visible:ring-2 focus-visible:ring-primary/50 focus-visible:outline-none focus-visible:rounded-xl after:absolute after:inset-0 after:rounded-xl after:bg-black/0 hover:after:bg-black/20 after:transition after:duration-100">
                    <img
                        src="{{ gridPhotos[3].url }}?w=900&h=600&fit=crop&auto=format&fm=webp&q=80"
                        srcset="{{ gridPhotos[3].url }}?w=600&h=400&fit=crop&auto=format&fm=webp&q=80 600w,
                                {{ gridPhotos[3].url }}?w=900&h=600&fit=crop&auto=format&fm=webp&q=80 900w,
                                {{ gridPhotos[3].url }}?w=1200&h=800&fit=crop&auto=format&fm=webp&q=80 1200w"
                        sizes="37.5vw"
                        alt="{{ gridPhotos[3].alt|default(property.title) }}"
                        width="900"
                        height="600"
                        loading="lazy"
                        decoding="async"
                        draggable="false"
                        class="w-full h-full object-cover rounded-xl"
                    />
                </button>
            {% endif %}
            <twig:Button variant="secondary" size="sm" class="absolute bottom-3 right-3 z-10" data-action="gallery#open" data-gallery-index-param="0">
                {{ ux_icon('iconoir:view-grid') }}
                {{ 'marketplace.show.gallery.showAll'|trans({'%count%': galleryPhotos|length}) }}
            </twig:Button>
        </div>
    </div>

    {# Lightbox dialog — mobile vertical scroll, desktop carousel #}
    <dialog
        data-gallery-target="dialog"
        data-action="click->gallery#closeOnClickOutside"
        tabindex="-1"
        class="fixed inset-0 z-50 m-0 h-full w-full max-h-full max-w-full bg-black/95 backdrop:bg-transparent open:block focus:outline-none"
    >
        <button
            type="button"
            data-action="gallery#close"
            aria-label="{{ 'marketplace.show.gallery.close'|trans }}"
            class="fixed top-4 right-4 z-20 size-10 flex items-center justify-center rounded-full bg-white/10 hover:bg-white/20 text-white transition duration-100 cursor-pointer focus-visible:ring-2 focus-visible:ring-primary/50 focus-visible:outline-none"
        >
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" class="size-6"><path d="M6 18 18 6M6 6l12 12" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>

        {# Mobile: vertical scroll #}
        <div class="lg:hidden h-full overflow-y-auto overscroll-contain">
            <div class="max-w-4xl mx-auto px-3 sm:px-4 pt-16 sm:pt-20 pb-8 sm:pb-12 flex flex-col gap-2 sm:gap-3">
                {% for photo in galleryPhotos %}
                    <img
                        src="{{ photo.url }}?w=1400&fit=max&auto=format&fm=webp&q=85"
                        srcset="{{ photo.url }}?w=800&fit=max&auto=format&fm=webp&q=85 800w,
                                {{ photo.url }}?w=1200&fit=max&auto=format&fm=webp&q=85 1200w,
                                {{ photo.url }}?w=1600&fit=max&auto=format&fm=webp&q=85 1600w"
                        sizes="100vw"
                        alt="{{ photo.alt|default(property.title) }}"
                        loading="{{ loop.first ? 'eager' : 'lazy' }}"
                        decoding="async"
                        draggable="false"
                        class="w-full rounded-xl select-none"
                    />
                {% endfor %}
            </div>
        </div>

        {# Desktop: carousel #}
        <div class="hidden lg:flex relative items-center justify-center w-full h-full px-4 py-12">
            <button
                type="button"
                data-action="gallery#prev"
                aria-label="{{ 'marketplace.show.gallery.previous'|trans }}"
                class="absolute left-4 z-10 size-10 flex items-center justify-center rounded-full bg-white/10 hover:bg-white/20 text-white transition duration-100 cursor-pointer focus-visible:ring-2 focus-visible:ring-primary/50 focus-visible:outline-none"
            >
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" class="size-5"><path d="m15 18-6-6 6-6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>

            <div class="flex flex-col items-center gap-6 max-h-full w-full">
                <img
                    data-gallery-target="image"
                    src=""
                    alt=""
                    draggable="false"
                    style="touch-action: none"
                    class="max-h-[calc(100vh-14rem)] max-w-full object-contain select-none rounded-lg transition-all duration-300 ease-out cursor-grab"
                />
                <div class="w-full max-w-4xl px-4">
                    <div class="flex flex-col items-center gap-2">
                        <span data-gallery-target="counter" class="text-white/50 text-xs font-medium"></span>
                        <div data-gallery-target="thumbnails" class="flex flex-nowrap gap-2 p-1 scroll-p-1 w-full overflow-x-auto scrollbar-hide scroll-smooth"></div>
                    </div>
                </div>
            </div>

            <button
                type="button"
                data-action="gallery#next"
                aria-label="{{ 'marketplace.show.gallery.next'|trans }}"
                class="absolute right-4 z-10 size-10 flex items-center justify-center rounded-full bg-white/10 hover:bg-white/20 text-white transition duration-100 cursor-pointer focus-visible:ring-2 focus-visible:ring-primary/50 focus-visible:outline-none"
            >
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" class="size-5"><path d="m9 18 6-6-6-6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
        </div>
    </dialog>
</section>
