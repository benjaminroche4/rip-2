{% macro arrondissementLabel(i, locale) %}
    {%- if locale == 'fr' -%}
        {{ i == 1 ? '1er arrondissement' : i ~ 'e arrondissement' }}
    {%- else -%}
        {%- set suffix = {1: 'st', 2: 'nd', 3: 'rd'}[i]|default('th') -%}
        {{ i ~ suffix ~ ' arrondissement' }}
    {%- endif -%}
{% endmacro %}

{% macro arrondissementShort(i, locale) %}
    {%- if locale == 'fr' -%}
        {{ i == 1 ? '1er' : i ~ 'e' }}
    {%- else -%}
        {%- set suffix = {1: 'st', 2: 'nd', 3: 'rd'}[i]|default('th') -%}
        {{ i ~ suffix }}
    {%- endif -%}
{% endmacro %}

{% import _self as ui %}

{% set selectClass = 'font-light w-full bg-transparent appearance-none cursor-pointer border-none shadow-none focus:ring-0 focus:outline-none text-gray-900 invalid:text-gray-400 invalid:font-light' %}
{% set inputClass = 'font-light text-gray-900 w-full bg-transparent placeholder:text-gray-400 [appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none border-none shadow-none focus:ring-0 focus:outline-none' %}
{% set fieldWrapper = 'px-3 py-3 lg:py-2 flex items-center gap-x-2 max-lg:border border-slate-200 max-lg:rounded-xl' %}
{% set iconClass = 'size-5 text-gray-400 shrink-0' %}

<div {{ attributes }}>
    <section class="max-w-4xl mx-auto lg:px-8 px-6 lg:py-16 py-10">
        <div
            class="relative group/dd border border-slate-200 rounded-2xl px-3 py-3 lg:py-2 shadow-lg shadow-gray-500/10 bg-white space-y-3 lg:space-y-0 lg:flex items-center w-full"
            data-controller="arrondissement-dropdown"
        >
            <div class="grid lg:grid-cols-3 divide-slate-200 lg:divide-x flex-1 w-full space-y-3 lg:space-y-0">
                <div class="{{ fieldWrapper }}">
                    {{ ux_icon('lucide:map-pin', {'class': iconClass}) }}
                    <button
                        type="button"
                        data-action="arrondissement-dropdown#toggle"
                        aria-label="{{ 'marketplace.list.search.arrondissement'|trans }}"
                        class="flex items-center gap-x-2 flex-1 min-w-0 bg-transparent cursor-pointer text-left {{ draftArrondissements is empty ? 'text-gray-400 font-light' : 'text-gray-900' }}"
                    >
                        <span class="flex-1 truncate">
                            {%- if draftArrondissements is empty -%}
                                {{ 'marketplace.list.search.arrondissement'|trans }}
                            {%- elseif draftArrondissements|length == 1 -%}
                                {{ ui.arrondissementLabel(draftArrondissements|first, locale) }}
                            {%- else -%}
                                {{ 'marketplace.list.search.arrondissementSelected'|trans({'%count%': draftArrondissements|length}) }}
                            {%- endif -%}
                        </span>
                        {{ ux_icon('lucide:chevron-down', {'class': 'size-4 text-gray-400 shrink-0 transition-transform duration-200 group-data-open/dd:rotate-180'}) }}
                    </button>
                </div>

                {# Mobile backdrop #}
                <div
                    data-action="click->arrondissement-dropdown#close"
                    class="fixed inset-0 z-40 bg-gray-900/40 invisible opacity-0 transition-opacity duration-200 group-data-open/dd:visible group-data-open/dd:opacity-100 lg:hidden"
                ></div>

                {# Arrondissement panel: centered dropdown on desktop, bottom sheet on mobile #}
                <div
                    class="flex flex-col gap-5 z-50 bg-white border border-slate-200 text-left transition duration-200 ease-out invisible opacity-0 group-data-open/dd:visible group-data-open/dd:opacity-100
                           max-lg:fixed max-lg:inset-x-0 max-lg:bottom-0 max-lg:max-h-[85vh] max-lg:overflow-y-auto max-lg:rounded-t-2xl max-lg:p-5 max-lg:shadow-2xl max-lg:translate-y-full max-lg:group-data-open/dd:translate-y-0
                           lg:absolute lg:top-[calc(100%_+_0.75rem)] lg:left-1/2 lg:-translate-x-1/2 lg:w-[840px] lg:max-w-[calc(100vw_-_2rem)] lg:rounded-2xl lg:p-6 lg:shadow-xl lg:shadow-gray-500/10"
                >
                    <div class="flex flex-col lg:flex-row gap-5">
                            {# Curated areas (decorative) #}
                            <div class="flex flex-col gap-5 lg:w-[230px] shrink-0">
                                <div class="flex flex-col gap-2">
                                    <div class="flex items-center gap-x-2 px-2">
                                        {{ ux_icon('lucide:trending-up', {'class': 'size-4.5 shrink-0 text-primary'}) }}
                                        <p class="text-sm font-medium text-gray-900">{{ 'marketplace.list.search.arrondissementPanel.popular'|trans }}</p>
                                    </div>
                                    <ul role="list" class="flex flex-col gap-0.5 text-sm text-gray-500">
                                        {% for label in [ui.arrondissementLabel(16, locale), ui.arrondissementLabel(7, locale), 'marketplace.list.search.arrondissementPanel.areas.marais'|trans] %}
                                            <li class="flex items-center gap-x-2 px-2 py-1">
                                                {{ ux_icon('lucide:map-pin', {'class': 'size-4 shrink-0 text-gray-400'}) }}
                                                <span class="truncate">{{ label }}</span>
                                            </li>
                                        {% endfor %}
                                    </ul>
                                </div>
                                <div class="flex flex-col gap-2">
                                    <div class="flex items-center gap-x-2 px-2">
                                        {{ ux_icon('lucide:users', {'class': 'size-4.5 shrink-0 text-primary'}) }}
                                        <p class="text-sm font-medium text-gray-900">{{ 'marketplace.list.search.arrondissementPanel.family'|trans }}</p>
                                    </div>
                                    <ul role="list" class="flex flex-col gap-0.5 text-sm text-gray-500">
                                        {% for label in [ui.arrondissementLabel(15, locale), 'marketplace.list.search.arrondissementPanel.areas.neuilly'|trans] %}
                                            <li class="flex items-center gap-x-2 px-2 py-1">
                                                {{ ux_icon('lucide:map-pin', {'class': 'size-4 shrink-0 text-gray-400'}) }}
                                                <span class="truncate">{{ label }}</span>
                                            </li>
                                        {% endfor %}
                                    </ul>
                                </div>
                            </div>

                            <div class="hidden lg:block w-px self-stretch bg-linear-to-b from-transparent via-slate-200 to-transparent"></div>

                            {# All arrondissements (multi-select) #}
                            <div class="flex flex-col gap-3 flex-1 min-w-0">
                                <div class="flex items-center gap-x-2 px-2">
                                    {{ ux_icon('lucide:map', {'class': 'size-4.5 shrink-0 text-primary'}) }}
                                    <p class="text-sm font-medium text-gray-900">{{ 'marketplace.list.search.arrondissementPanel.all'|trans }}</p>
                                </div>
                                <div class="grid grid-cols-2 lg:grid-cols-3 gap-x-4 gap-y-0.5">
                                    {% for i in 1..20 %}
                                        <label class="flex items-center gap-x-2 px-2 py-1 rounded-md cursor-pointer hover:bg-slate-50 text-sm text-gray-500">
                                            <input
                                                type="checkbox"
                                                data-model="norender|draftArrondissements"
                                                value="{{ i }}"
                                                {{ i in draftArrondissements ? 'checked' }}
                                                class="size-3.5 shrink-0 rounded border-slate-300 text-primary focus:ring-primary/40"
                                            />
                                            <span class="truncate">{{ ui.arrondissementShort(i, locale) }} · {{ this.arrondissementNames[i] }}</span>
                                        </label>
                                    {% endfor %}
                                </div>
                            </div>
                        </div>

                        {# Mobile actions #}
                        <div class="flex items-center justify-between gap-3 pt-4 border-t border-slate-100 lg:hidden">
                            <button
                                type="button"
                                data-action="live#action:prevent arrondissement-dropdown#close"
                                data-live-action-param="clearArrondissements"
                                class="px-4 py-2.5 rounded-xl text-sm font-medium text-gray-700 hover:bg-slate-50"
                            >
                                {{ 'marketplace.list.search.arrondissementPanel.clear'|trans }}
                            </button>
                            <button
                                type="button"
                                data-action="live#action:prevent arrondissement-dropdown#close"
                                data-live-action-param="search"
                                class="flex-1 px-4 py-2.5 rounded-xl text-sm font-medium text-white bg-primary hover:bg-primary/90"
                            >
                                {{ 'marketplace.list.search.arrondissementPanel.apply'|trans }}
                            </button>
                        </div>
                    </div>

                <div class="{{ fieldWrapper }}">
                    {{ ux_icon('iconoir:home-simple', {'class': iconClass}) }}
                    <select data-model="norender|draftPropertyType" data-action="keydown.enter->live#action" data-live-action-param="search" required aria-label="{{ 'marketplace.list.search.type'|trans }}" class="{{ selectClass }}">
                        <option value="">{{ 'marketplace.list.search.type'|trans|raw }}</option>
                        {% for slug, name in this.propertyTypes %}
                            <option value="{{ slug }}" {{ (draftPropertyType ?: propertyType) == slug ? 'selected' }}>{{ name }}</option>
                        {% endfor %}
                    </select>
                </div>

                <div class="{{ fieldWrapper }}">
                    {{ ux_icon('iconoir:euro', {'class': iconClass}) }}
                    <div class="flex items-center gap-x-1 flex-1 min-w-0">
                        <input
                            type="number"
                            inputmode="numeric"
                            pattern="[0-9]*"
                            data-model="norender|draftRentMin"
                            data-action="keydown.enter->live#action"
                            data-live-action-param="search"
                            placeholder="{{ 'marketplace.list.search.price.min'|trans|raw }}"
                            min="0"
                            step="100"
                            value="{{ draftRentMin ?? rentMin }}"
                            class="{{ inputClass }}"
                        />
                        <span class="text-gray-300 shrink-0">–</span>
                        <input
                            type="number"
                            inputmode="numeric"
                            pattern="[0-9]*"
                            data-model="norender|draftRentMax"
                            data-action="keydown.enter->live#action"
                            data-live-action-param="search"
                            placeholder="{{ 'marketplace.list.search.price.max'|trans|raw }}"
                            min="0"
                            step="100"
                            value="{{ draftRentMax ?? rentMax }}"
                            class="{{ inputClass }}"
                        />
                    </div>
                </div>
            </div>

            <twig:Button
                variant="default"
                size="lg"
                data-action="live#action"
                data-live-action-param="search"
                data-loading="action(search)|addAttribute(disabled)"
                class="w-full lg:w-auto"
            >
                <span class="relative inline-flex items-center justify-center">
                    <span data-loading="action(search)|addClass(invisible)">
                        {{ 'marketplace.list.search.button'|trans|raw }}
                    </span>
                    <span class="hidden absolute inset-0 flex items-center justify-center" data-loading="action(search)|removeClass(hidden)">
                        <twig:Spinner />
                    </span>
                </span>
            </twig:Button>
        </div>
    </section>

    <section class="max-w-full mx-auto lg:px-8 px-6 lg:pb-16 pb-12">
        <div
            class="grid grid-cols-1 lg:grid-cols-2 gap-x-8"
            data-controller="map-markers map-teleport map-expand"
            data-map-markers-card-url-value="{{ path('app_property_card_fragment', {locale: locale, id: '__ID__'}) }}"
            data-map-markers-locale-value="{{ locale }}"
            data-map-teleport-open-class="!translate-y-0 !opacity-100 !pointer-events-auto"
            data-map-expand-grid-default-class="lg:grid-cols-2"
            data-map-expand-grid-expanded-class="lg:grid-cols-1"
            data-map-expand-list-hidden-class="lg:hidden"
            data-map-expand-expand-label-value="{{ 'marketplace.list.properties.expandMap'|trans }}"
            data-map-expand-collapse-label-value="{{ 'marketplace.list.properties.collapseMap'|trans }}"
        >
            <div data-map-expand-target="list">
                <div class="max-[360px]:flex-col min-[361px]:flex-row flex justify-between min-[361px]:items-center gap-2 mb-8">
                    <h1 class="text-base font-medium font-secondary flex gap-x-1">
                        {{ this.totalCount }} {{ 'marketplace.list.properties.title'|trans|raw }}
                    </h1>
                    <button
                        type="button"
                        data-action="map-teleport#open"
                        class="lg:hidden cursor-pointer rounded-lg justify-center bg-primary/5 hover:bg-primary/10 py-2 px-2 flex items-center gap-x-2 text-sm text-primary transition duration-100 focus-visible:ring-2 focus-visible:ring-primary/50 focus-visible:outline-none"
                    >
                        {{ ux_icon('material-symbols:map-outline-rounded', {'class': 'size-4.5 shrink-0 text-primary'}) }}
                        {{ 'marketplace.list.properties.map'|trans|raw }}
                    </button>
                </div>

                <div class="hidden" data-loading="action(search)|show">
                    <div class="grid sm:grid-cols-2 3xl:grid-cols-3! gap-6">
                        {% for i in 1..4 %}
                            <div class="flex flex-col border border-slate-200 rounded-2xl bg-white p-1.5">
                                <twig:Skeleton class="aspect-4/3 rounded-xl bg-neutral-800/10" />
                                <div class="px-2 py-3 flex flex-col flex-1 space-y-4">
                                    <div class="space-y-2">
                                        <twig:Skeleton class="h-7 w-1/3 rounded-md bg-neutral-800/10" />
                                        <twig:Skeleton class="h-5 w-2/3 rounded-md bg-neutral-800/10" />
                                        <twig:Skeleton class="h-4 w-1/2 rounded-md bg-neutral-800/10" />
                                    </div>
                                    <twig:Skeleton class="h-12 w-full rounded-lg bg-neutral-800/10" />
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>

                <div data-loading="action(search)|hide">
                    {% if this.items is empty %}
                        <div class="flex flex-col items-center justify-center py-16 text-center">
                            <img src="{{ asset('medias/svg/no-results.svg') }}" alt="{{ 'marketplace.list.properties.noResults'|trans }}" width="184" height="136" draggable="false" class="mb-6 select-none pointer-events-none" />
                            <p class="text-gray-600 text-lg font-medium mb-4">
                                {{ 'marketplace.list.properties.noResults'|trans }}
                            </p>
                            <button
                                type="button"
                                data-action="live#action"
                                data-live-action-param="clearFilters"
                                class="px-5 py-2.5 rounded-xl border border-slate-200 text-sm font-medium text-gray-700 hover:bg-slate-50 transition-colors cursor-pointer"
                            >
                                {{ 'marketplace.list.properties.clearFilters'|trans }}
                            </button>
                        </div>
                    {% else %}
                        <div class="grid sm:grid-cols-2 3xl:grid-cols-3! gap-6">
                            {% for property in this.items %}
                                {% include 'components/Marketplace/PropertyCard.html.twig' with { property, locale } only %}
                            {% endfor %}
                        </div>
                    {% endif %}
                </div>

                {% if this.hasMore %}
                    <div class="flex justify-center mt-8">
                        <button
                            data-action="live#action"
                            data-live-action-param="more"
                            class="px-6 py-3 border border-slate-200 rounded-xl text-sm font-medium hover:bg-slate-50 transition-colors"
                        >
                            <span data-loading="action(more)|hide">{{ 'marketplace.list.properties.button'|trans|raw }}</span>
                            <span data-loading="action(more)|show" class="hidden items-center gap-x-2">
                                <twig:Spinner class="inline" />
                                {{ 'marketplace.list.properties.loading'|trans|raw }}
                            </span>
                        </button>
                    </div>
                {% endif %}
            </div>

            <div
                data-map-teleport-target="container"
                data-loading="action(updateBounds)|addClass(opacity-50)"
                class="
                    max-lg:fixed max-lg:inset-0 max-lg:z-50 max-lg:bg-white max-lg:translate-y-full max-lg:opacity-0 max-lg:pointer-events-none max-lg:transition-all max-lg:duration-300
                    lg:block lg:rounded-3xl lg:p-2 lg:border lg:border-neutral-200 lg:transition-opacity lg:duration-200 lg:sticky lg:top-4 lg:h-[calc(100vh-2rem)]
                "
            >
                <button
                    type="button"
                    data-action="map-teleport#close"
                    aria-label="{{ 'marketplace.list.properties.closeMap'|trans|raw }}"
                    class="lg:hidden cursor-pointer absolute top-4 right-4 z-20 size-10 flex items-center justify-center rounded-full bg-white shadow-lg text-gray-700 hover:bg-neutral-100 transition duration-100 focus-visible:ring-2 focus-visible:ring-primary/50 focus-visible:outline-none"
                >
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" class="size-6">
                        <path d="M6 18 18 6M6 6l12 12" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </button>

                <button
                    type="button"
                    data-map-expand-target="button"
                    data-action="map-expand#toggle"
                    aria-pressed="false"
                    aria-label="{{ 'marketplace.list.properties.expandMap'|trans }}"
                    class="hidden lg:flex cursor-pointer absolute top-4 right-4 z-20 size-10 items-center justify-center rounded-full bg-white shadow-md ring-1 ring-black/5 text-gray-700 hover:bg-neutral-100 transition duration-100 focus-visible:ring-2 focus-visible:ring-primary/50 focus-visible:outline-none"
                >
                    <span data-map-expand-target="expandIcon" class="flex">
                        {{ ux_icon('lucide:maximize-2', {'class': 'size-5 shrink-0'}) }}
                    </span>
                    <span data-map-expand-target="collapseIcon" class="hidden">
                        {{ ux_icon('lucide:minimize-2', {'class': 'size-5 shrink-0'}) }}
                    </span>
                </button>
                {{ ux_map(map, {style: 'height: 100%; width: 100%;', 'class': 'lg:rounded-2xl', 'data-controller': 'map-cluster map-restriction map-paris-boundary'}) }}
            </div>
        </div>
    </section>
</div>
