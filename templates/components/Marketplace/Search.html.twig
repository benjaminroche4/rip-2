{% macro arrondissementLabel(i, locale) %}
    {%- if locale == 'fr' -%}
        {{ i == 1 ? '1er arrondissement' : i ~ 'e arrondissement' }}
    {%- else -%}
        {%- set suffix = {1: 'st', 2: 'nd', 3: 'rd'}[i]|default('th') -%}
        {{ i ~ suffix ~ ' arrondissement' }}
    {%- endif -%}
{% endmacro %}

{% macro arrondissementShort(i, locale) %}
    {%- if locale == 'fr' -%}
        {{ i == 1 ? '1er' : i ~ 'e' }}
    {%- else -%}
        {%- set suffix = {1: 'st', 2: 'nd', 3: 'rd'}[i]|default('th') -%}
        {{ i ~ suffix }}
    {%- endif -%}
{% endmacro %}

{% import _self as ui %}

{% set t = 'marketplace.list.search.' %}
{% set pillClass = 'flex items-center gap-2 h-[44px] px-3.5 rounded-xl bg-[#f7f7f7] hover:bg-[#efefef] text-sm text-gray-900 cursor-pointer transition-colors w-full lg:w-auto' %}
{% set pillIcon = 'size-[18px] shrink-0 text-gray-500' %}
{% set sectionHead = 'flex items-center gap-2 px-1 text-sm font-medium text-gray-900' %}
{% set sectionIcon = 'size-[18px] shrink-0 text-primary' %}
{% set checkboxClass = 'size-3.5 shrink-0 rounded-[4px] border-slate-300 text-primary focus:ring-primary/40' %}
{% set optionRow = 'flex items-center gap-2 px-2 py-1.5 rounded-md cursor-pointer hover:bg-slate-50 text-sm text-gray-600' %}

{# Property type pill summary (built from draft selections) #}
{% set typeLabels = [] %}
{% for b in draftBedrooms %}
    {% set typeLabels = typeLabels|merge([(t ~ 'layout.' ~ (b == 'studio' ? 'studio' : 'bed' ~ b))|trans]) %}
{% endfor %}
{% if 'yes' in draftFurnished %}{% set typeLabels = typeLabels|merge([(t ~ 'style.furnished')|trans]) %}{% endif %}
{% if 'no' in draftFurnished %}{% set typeLabels = typeLabels|merge([(t ~ 'style.unfurnished')|trans]) %}{% endif %}
{% if draftLongTerm %}{% set typeLabels = typeLabels|merge([(t ~ 'rental.longTerm')|trans]) %}{% endif %}
{% if draftMidTerm %}{% set typeLabels = typeLabels|merge([(t ~ 'rental.midTerm')|trans]) %}{% endif %}

<div {{ attributes }}>
    <section class="max-w-4xl mx-auto lg:px-8 px-6 lg:py-16 py-10">
        <div class="relative border border-slate-200 rounded-2xl p-3 lg:p-3.5 shadow-lg shadow-gray-500/10 bg-white">
            {# ---- Free-text search + custom Google Places autocomplete ---- #}
            <div class="relative flex items-center gap-2.5 px-2 pb-3 lg:pb-3.5 border-b border-slate-100" data-controller="places-autocomplete">
                {{ ux_icon('lucide:search', {'class': 'size-5 shrink-0 text-gray-400'}) }}
                <input
                    type="search"
                    data-model="norender|draftQ"
                    data-places-autocomplete-target="input"
                    data-action="input->places-autocomplete#search keydown->places-autocomplete#navigate keydown.enter->live#action"
                    data-live-action-param="search"
                    value="{{ draftQ }}"
                    placeholder="{{ (t ~ 'q')|trans }}"
                    aria-label="{{ (t ~ 'q')|trans }}"
                    autocomplete="off"
                    role="combobox"
                    aria-autocomplete="list"
                    aria-expanded="false"
                    class="font-light w-full bg-transparent placeholder:text-gray-400 border-none shadow-none focus:ring-0 focus:outline-none text-gray-900 [&::-webkit-search-cancel-button]:appearance-none"
                />
                {# Hidden bridge: a picked Google address fires the searchAddress LiveAction #}
                <button type="button" class="hidden" aria-hidden="true" tabindex="-1"
                    data-places-autocomplete-target="trigger"
                    data-action="places-autocomplete:select->live#action"
                    data-live-action-param="searchAddress"></button>
                {# Custom suggestions dropdown (populated by the controller) #}
                <ul data-places-autocomplete-target="results" role="listbox"
                    class="hidden absolute left-0 right-0 top-full mt-2 z-50 max-h-72 overflow-y-auto bg-white border border-slate-200 rounded-xl shadow-xl shadow-gray-500/10 p-1"></ul>
            </div>

            {# ---- Pills + actions ---- #}
            <div class="flex flex-col lg:flex-row lg:items-center gap-3 pt-3 lg:pt-3.5">
                <div class="flex flex-col lg:flex-row gap-3 lg:flex-1">

                    {# ===== Localisation ===== #}
                    <div class="relative group/loc w-full lg:w-auto" data-controller="arrondissement-dropdown">
                        <button type="button" data-action="arrondissement-dropdown#toggle"
                            aria-label="{{ (t ~ 'localisation')|trans }}" aria-haspopup="true" aria-expanded="false"
                            class="{{ pillClass }} justify-between {{ draftArrondissements is not empty ? 'ring-1 ring-primary/30' }}">
                            <span class="flex items-center gap-2 min-w-0">
                                {{ ux_icon('lucide:map-pin', {'class': pillIcon}) }}
                                <span class="truncate {{ draftArrondissements is empty ? 'text-gray-500' }}">
                                    {%- if draftArrondissements is empty -%}
                                        {{ (t ~ 'localisation')|trans }}
                                    {%- elseif draftArrondissements|length == 1 -%}
                                        {{ ui.arrondissementLabel(draftArrondissements|first, locale) }}
                                    {%- else -%}
                                        {{ (t ~ 'arrondissementSelected')|trans({'%count%': draftArrondissements|length}) }}
                                    {%- endif -%}
                                </span>
                            </span>
                            {{ ux_icon('lucide:chevron-down', {'class': 'size-4 shrink-0 text-gray-400 transition-transform duration-200 group-data-open/loc:rotate-180'}) }}
                        </button>

                        {# Mobile backdrop #}
                        <div data-action="click->arrondissement-dropdown#close"
                            class="fixed inset-0 z-40 bg-gray-900/40 invisible opacity-0 group-data-open/loc:visible group-data-open/loc:opacity-100 group-data-open/loc:transition-opacity group-data-open/loc:duration-200 lg:hidden"></div>

                        <div class="flex flex-col z-50 bg-white border border-slate-200 text-left invisible opacity-0 group-data-open/loc:visible group-data-open/loc:opacity-100 group-data-open/loc:transition group-data-open/loc:duration-200 group-data-open/loc:ease-out
                                    max-lg:fixed max-lg:inset-x-0 max-lg:bottom-0 max-lg:max-h-[85vh] max-lg:rounded-t-2xl max-lg:shadow-2xl max-lg:translate-y-full max-lg:group-data-open/loc:translate-y-0
                                    lg:absolute lg:top-[calc(100%_+_0.75rem)] lg:left-0 lg:w-[820px] lg:max-w-[calc(100vw_-_2rem)] lg:rounded-2xl lg:p-6 lg:shadow-xl lg:shadow-gray-500/10">
                            {# Grab handle + title (mobile bottom sheet only) #}
                            <div class="lg:hidden shrink-0">
                                <div class="flex justify-center pt-3 pb-1"><span class="h-1.5 w-10 rounded-full bg-gray-300"></span></div>
                                <p class="px-5 pt-1 pb-3 text-base font-medium text-gray-900">{{ (t ~ 'localisation')|trans }}</p>
                            </div>
                            <div class="flex flex-col lg:flex-row gap-5 max-lg:flex-1 max-lg:min-h-0 max-lg:overflow-y-auto max-lg:px-5 max-lg:pb-4">
                                {# Curated areas #}
                                <div class="flex flex-col gap-5 lg:w-[230px] shrink-0">
                                    <div class="flex flex-col gap-2">
                                        <div class="{{ sectionHead }}">
                                            {{ ux_icon('lucide:trending-up', {'class': sectionIcon}) }}
                                            {{ (t ~ 'arrondissementPanel.popular')|trans }}
                                        </div>
                                        <ul role="list" class="flex flex-col gap-0.5">
                                            {% for area in this.popularAreas %}
                                                <li>
                                                    <button type="button"
                                                        data-action="live#action:prevent arrondissement-dropdown#close"
                                                        data-live-action-param="selectArea"
                                                        data-live-arrondissements-param="{{ area.csv }}"
                                                        class="flex items-center gap-2 w-full px-2 py-1.5 rounded-md text-sm text-gray-600 text-left cursor-pointer transition-colors hover:bg-slate-50 hover:text-gray-900">
                                                        {{ ux_icon('lucide:map-pin', {'class': 'size-4 shrink-0 text-gray-400'}) }}
                                                        <span class="truncate">{{ (t ~ 'arrondissementPanel.areas.' ~ area.key)|trans }}</span>
                                                    </button>
                                                </li>
                                            {% endfor %}
                                        </ul>
                                    </div>
                                    <div class="flex flex-col gap-2">
                                        <div class="{{ sectionHead }}">
                                            {{ ux_icon('lucide:users', {'class': sectionIcon}) }}
                                            {{ (t ~ 'arrondissementPanel.family')|trans }}
                                        </div>
                                        <ul role="list" class="flex flex-col gap-0.5">
                                            {% for area in this.familyAreas %}
                                                <li>
                                                    <button type="button"
                                                        data-action="live#action:prevent arrondissement-dropdown#close"
                                                        data-live-action-param="selectArea"
                                                        data-live-arrondissements-param="{{ area.csv }}"
                                                        class="flex items-center gap-2 w-full px-2 py-1.5 rounded-md text-sm text-gray-600 text-left cursor-pointer transition-colors hover:bg-slate-50 hover:text-gray-900">
                                                        {{ ux_icon('lucide:map-pin', {'class': 'size-4 shrink-0 text-gray-400'}) }}
                                                        <span class="truncate">{{ (t ~ 'arrondissementPanel.areas.' ~ area.key)|trans }}</span>
                                                    </button>
                                                </li>
                                            {% endfor %}
                                        </ul>
                                    </div>
                                </div>

                                <div class="hidden lg:block w-px self-stretch bg-linear-to-b from-transparent via-slate-200 to-transparent"></div>

                                {# All arrondissements #}
                                <div class="flex flex-col gap-3 flex-1 min-w-0">
                                    <div class="{{ sectionHead }}">
                                        {{ ux_icon('lucide:map', {'class': sectionIcon}) }}
                                        {{ (t ~ 'arrondissementPanel.all')|trans }}
                                    </div>
                                    {% set arrondissementNames = this.arrondissementNames %}
                                    <div class="grid grid-cols-2 lg:grid-cols-3 gap-x-4 gap-y-0.5">
                                        {% for i in 1..20 %}
                                            <label class="flex items-center gap-2 px-2 py-1.5 rounded-md cursor-pointer hover:bg-slate-50 text-sm text-gray-600">
                                                <input type="checkbox" data-model="norender|draftArrondissements" value="{{ i }}" {{ i in draftArrondissements ? 'checked' }} class="{{ checkboxClass }}" />
                                                <span class="truncate">{{ ui.arrondissementShort(i, locale) }} · {{ arrondissementNames[i] }}</span>
                                            </label>
                                        {% endfor %}
                                    </div>
                                </div>
                            </div>

                            {# Mobile sticky action bar #}
                            <div class="shrink-0 flex items-center gap-3 px-5 py-4 border-t border-slate-100 bg-white lg:hidden">
                                <button type="button" data-action="live#action:prevent arrondissement-dropdown#close" data-live-action-param="clearArrondissements"
                                    class="px-4 py-2.5 rounded-xl text-sm font-medium text-gray-900 bg-[#f7f7f7] hover:bg-[#efefef] transition-colors">{{ (t ~ 'arrondissementPanel.clear')|trans }}</button>
                                <button type="button" data-action="live#action:prevent arrondissement-dropdown#close" data-live-action-param="search"
                                    class="flex-1 px-4 py-2.5 rounded-xl text-sm font-medium text-white bg-primary hover:bg-primary/90 transition-colors">{{ (t ~ 'arrondissementPanel.apply')|trans }}</button>
                            </div>
                        </div>
                    </div>

                    {# ===== Property type ===== #}
                    <div class="relative group/type w-full lg:w-auto" data-controller="arrondissement-dropdown">
                        <button type="button" data-action="arrondissement-dropdown#toggle"
                            aria-label="{{ (t ~ 'propertyType')|trans }}" aria-haspopup="true" aria-expanded="false"
                            class="{{ pillClass }} justify-between {{ typeLabels is not empty ? 'ring-1 ring-primary/30' }}">
                            <span class="flex items-center gap-2 min-w-0">
                                {{ ux_icon('iconoir:home-simple', {'class': pillIcon}) }}
                                <span class="truncate {{ typeLabels is empty ? 'text-gray-500' }}">
                                    {%- if typeLabels is empty -%}
                                        {{ (t ~ 'propertyType')|trans }}
                                    {%- elseif typeLabels|length == 1 -%}
                                        {{ typeLabels|first }}
                                    {%- else -%}
                                        {{ (t ~ 'typeCount')|trans({'%count%': typeLabels|length}) }}
                                    {%- endif -%}
                                </span>
                            </span>
                            {{ ux_icon('lucide:chevron-down', {'class': 'size-4 shrink-0 text-gray-400 transition-transform duration-200 group-data-open/type:rotate-180'}) }}
                        </button>

                        <div data-action="click->arrondissement-dropdown#close"
                            class="fixed inset-0 z-40 bg-gray-900/40 invisible opacity-0 group-data-open/type:visible group-data-open/type:opacity-100 group-data-open/type:transition-opacity group-data-open/type:duration-200 lg:hidden"></div>

                        <div class="flex flex-col z-50 bg-white border border-slate-200 text-left invisible opacity-0 group-data-open/type:visible group-data-open/type:opacity-100 group-data-open/type:transition group-data-open/type:duration-200 group-data-open/type:ease-out
                                    max-lg:fixed max-lg:inset-x-0 max-lg:bottom-0 max-lg:max-h-[85vh] max-lg:rounded-t-2xl max-lg:shadow-2xl max-lg:translate-y-full max-lg:group-data-open/type:translate-y-0
                                    lg:absolute lg:top-[calc(100%_+_0.75rem)] lg:left-0 lg:w-[620px] lg:max-w-[calc(100vw_-_2rem)] lg:rounded-2xl lg:p-6 lg:shadow-xl lg:shadow-gray-500/10">
                            {# Grab handle + title (mobile bottom sheet only) #}
                            <div class="lg:hidden shrink-0">
                                <div class="flex justify-center pt-3 pb-1"><span class="h-1.5 w-10 rounded-full bg-gray-300"></span></div>
                                <p class="px-5 pt-1 pb-3 text-base font-medium text-gray-900">{{ (t ~ 'propertyType')|trans }}</p>
                            </div>
                            <div class="grid grid-cols-1 lg:grid-cols-3 gap-x-6 gap-y-5 max-lg:flex-1 max-lg:min-h-0 max-lg:overflow-y-auto max-lg:px-5 max-lg:pb-4">
                                {# Layout (bedrooms) #}
                                <div class="flex flex-col gap-2">
                                    <div class="{{ sectionHead }}">
                                        {{ ux_icon('lucide:trending-up', {'class': sectionIcon}) }}
                                        {{ (t ~ 'layout.title')|trans }}
                                    </div>
                                    {% for b in this.bedroomOptions %}
                                        <label class="{{ optionRow }}">
                                            <input type="checkbox" data-model="norender|draftBedrooms" value="{{ b }}" {{ b in draftBedrooms ? 'checked' }} class="{{ checkboxClass }}" />
                                            <span class="truncate">{{ (t ~ 'layout.' ~ (b == 'studio' ? 'studio' : 'bed' ~ b))|trans }}</span>
                                        </label>
                                    {% endfor %}
                                </div>
                                {# Style (furnished) #}
                                <div class="flex flex-col gap-2">
                                    <div class="{{ sectionHead }}">
                                        {{ ux_icon('iconoir:building', {'class': sectionIcon}) }}
                                        {{ (t ~ 'style.title')|trans }}
                                    </div>
                                    <label class="{{ optionRow }}">
                                        <input type="checkbox" data-model="norender|draftFurnished" value="yes" {{ 'yes' in draftFurnished ? 'checked' }} class="{{ checkboxClass }}" />
                                        <span class="truncate">{{ (t ~ 'style.furnished')|trans }}</span>
                                    </label>
                                    <label class="{{ optionRow }}">
                                        <input type="checkbox" data-model="norender|draftFurnished" value="no" {{ 'no' in draftFurnished ? 'checked' }} class="{{ checkboxClass }}" />
                                        <span class="truncate">{{ (t ~ 'style.unfurnished')|trans }}</span>
                                    </label>
                                </div>
                                {# Rental category #}
                                <div class="flex flex-col gap-2">
                                    <div class="{{ sectionHead }}">
                                        {{ ux_icon('lucide:file-text', {'class': sectionIcon}) }}
                                        {{ (t ~ 'rental.title')|trans }}
                                    </div>
                                    <label class="{{ optionRow }}">
                                        <input type="checkbox" data-model="norender|draftLongTerm" {{ draftLongTerm ? 'checked' }} class="{{ checkboxClass }}" />
                                        <span class="truncate">{{ (t ~ 'rental.longTerm')|trans }}</span>
                                    </label>
                                    <label class="{{ optionRow }}">
                                        <input type="checkbox" data-model="norender|draftMidTerm" {{ draftMidTerm ? 'checked' }} class="{{ checkboxClass }}" />
                                        <span class="truncate">{{ (t ~ 'rental.midTerm')|trans }}</span>
                                    </label>
                                </div>
                            </div>

                            {# Mobile sticky action bar #}
                            <div class="shrink-0 flex items-center gap-3 px-5 py-4 border-t border-slate-100 bg-white lg:hidden">
                                <button type="button" data-action="live#action:prevent arrondissement-dropdown#close" data-live-action-param="clearPropertyType"
                                    class="px-4 py-2.5 rounded-xl text-sm font-medium text-gray-900 bg-[#f7f7f7] hover:bg-[#efefef] transition-colors">{{ (t ~ 'arrondissementPanel.clear')|trans }}</button>
                                <button type="button" data-action="live#action:prevent arrondissement-dropdown#close" data-live-action-param="search"
                                    class="flex-1 px-4 py-2.5 rounded-xl text-sm font-medium text-white bg-primary hover:bg-primary/90 transition-colors">{{ (t ~ 'arrondissementPanel.apply')|trans }}</button>
                            </div>
                        </div>
                    </div>

                    {# ===== More filters ===== #}
                    {% set moreCount = this.moreFiltersCount %}
                    <div class="w-full lg:w-auto group/mf" data-controller="more-filters-modal">
                        <button type="button" data-action="more-filters-modal#open"
                            aria-haspopup="dialog" aria-expanded="false"
                            class="{{ pillClass }} justify-between">
                            <span class="flex items-center gap-2 min-w-0">
                                {# funnel #}
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="{{ pillIcon }}" aria-hidden="true">
                                    <path d="M3 5h18l-7 8v6l-4 2v-8L3 5Z" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                                <span class="truncate text-gray-900">{{ (t ~ 'moreFilters')|trans }}</span>
                            </span>
                            <span class="shrink-0 inline-flex items-center justify-center min-w-[20px] h-5 px-1.5 rounded-full text-xs font-semibold {{ moreCount > 0 ? 'bg-primary text-white' : 'bg-slate-200 text-gray-500' }}"
                                data-more-filters-modal-target="badge">{{ moreCount }}</span>
                        </button>

                        {% include 'components/Marketplace/_partials/MoreFiltersModal.html.twig' %}
                    </div>
                </div>

                {# Reset + Search #}
                <div class="flex items-center gap-2 lg:gap-3 shrink-0">
                    <button type="button" data-action="live#action" data-live-action-param="clearFilters"
                        class="hidden lg:inline-flex px-3 py-2 rounded-lg text-sm font-medium text-gray-500 hover:text-gray-900 hover:bg-slate-50 transition-colors cursor-pointer">
                        {{ (t ~ 'reset')|trans }}
                    </button>
                    <twig:Button
                        variant="default"
                        size="lg"
                        data-action="live#action arrondissement-dropdown#close"
                        data-live-action-param="search"
                        data-loading="action(search)|addAttribute(disabled)"
                        class="w-full lg:w-auto">
                        <span class="relative inline-flex items-center justify-center">
                            <span data-loading="action(search)|addClass(invisible)">{{ (t ~ 'button')|trans|raw }}</span>
                            <span class="hidden absolute inset-0 flex items-center justify-center" data-loading="action(search)|removeClass(hidden)">
                                <twig:Spinner />
                            </span>
                        </span>
                    </twig:Button>
                </div>
            </div>
        </div>
    </section>

    <section class="max-w-full mx-auto lg:px-8 px-6 lg:pb-16 pb-12">
        <div
            class="grid grid-cols-1 lg:grid-cols-2 gap-x-8"
            data-controller="map-markers map-teleport map-expand"
            data-map-markers-card-url-value="{{ path('app_property_card_fragment', {locale: locale, id: '__ID__'}) }}"
            data-map-markers-locale-value="{{ locale }}"
            data-map-teleport-open-class="!translate-y-0 !opacity-100 !pointer-events-auto"
            data-map-expand-grid-default-class="lg:grid-cols-2"
            data-map-expand-grid-expanded-class="lg:grid-cols-1"
            data-map-expand-list-hidden-class="lg:hidden"
            data-map-expand-expand-label-value="{{ 'marketplace.list.properties.expandMap'|trans }}"
            data-map-expand-collapse-label-value="{{ 'marketplace.list.properties.collapseMap'|trans }}"
        >
            <div data-map-expand-target="list">
                <div class="max-[360px]:flex-col min-[361px]:flex-row flex justify-between min-[361px]:items-center gap-2 mb-8">
                    <h1 class="text-base font-medium font-secondary flex gap-x-1">
                        {{ this.totalCount }} {{ 'marketplace.list.properties.title'|trans|raw }}
                    </h1>
                    <button
                        type="button"
                        data-action="map-teleport#open"
                        class="lg:hidden cursor-pointer rounded-lg justify-center bg-primary/5 hover:bg-primary/10 py-2 px-2 flex items-center gap-x-2 text-sm text-primary transition duration-100 focus-visible:ring-2 focus-visible:ring-primary/50 focus-visible:outline-none"
                    >
                        {{ ux_icon('material-symbols:map-outline-rounded', {'class': 'size-4.5 shrink-0 text-primary'}) }}
                        {{ 'marketplace.list.properties.map'|trans|raw }}
                    </button>
                </div>

                <div class="hidden" data-loading="action(search)|show">
                    <div class="grid sm:grid-cols-2 3xl:grid-cols-3! gap-6">
                        {% for i in 1..4 %}
                            <div class="flex flex-col border border-slate-200 rounded-2xl bg-white p-1.5">
                                <twig:Skeleton class="aspect-4/3 rounded-xl bg-neutral-800/10" />
                                <div class="px-2 py-3 flex flex-col flex-1 space-y-4">
                                    <div class="space-y-2">
                                        <twig:Skeleton class="h-7 w-1/3 rounded-md bg-neutral-800/10" />
                                        <twig:Skeleton class="h-5 w-2/3 rounded-md bg-neutral-800/10" />
                                        <twig:Skeleton class="h-4 w-1/2 rounded-md bg-neutral-800/10" />
                                    </div>
                                    <twig:Skeleton class="h-12 w-full rounded-lg bg-neutral-800/10" />
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>

                <div data-loading="action(search)|hide">
                    {% if this.items is empty %}
                        <div class="flex flex-col items-center justify-center py-16 text-center">
                            <img src="{{ asset('medias/svg/no-results.svg') }}" alt="{{ 'marketplace.list.properties.noResults'|trans }}" width="184" height="136" draggable="false" class="mb-6 select-none pointer-events-none" />
                            <p class="text-gray-600 text-lg font-medium mb-4">
                                {{ 'marketplace.list.properties.noResults'|trans }}
                            </p>
                            <button
                                type="button"
                                data-action="live#action"
                                data-live-action-param="clearFilters"
                                class="px-5 py-2.5 rounded-xl border border-slate-200 text-sm font-medium text-gray-700 hover:bg-slate-50 transition-colors cursor-pointer"
                            >
                                {{ 'marketplace.list.properties.clearFilters'|trans }}
                            </button>
                        </div>
                    {% else %}
                        <div class="grid sm:grid-cols-2 3xl:grid-cols-3! gap-6">
                            {% for property in this.items %}
                                {% include 'components/Marketplace/PropertyCard.html.twig' with { property, locale } only %}
                            {% endfor %}
                        </div>
                    {% endif %}
                </div>

                {% if this.hasMore %}
                    <div class="flex justify-center mt-8">
                        <button
                            data-action="live#action"
                            data-live-action-param="more"
                            class="px-6 py-3 border border-slate-200 rounded-xl text-sm font-medium hover:bg-slate-50 transition-colors"
                        >
                            <span data-loading="action(more)|hide">{{ 'marketplace.list.properties.button'|trans|raw }}</span>
                            <span data-loading="action(more)|show" class="hidden items-center gap-x-2">
                                <twig:Spinner class="inline" />
                                {{ 'marketplace.list.properties.loading'|trans|raw }}
                            </span>
                        </button>
                    </div>
                {% endif %}
            </div>

            <div
                data-map-teleport-target="container"
                data-loading="action(updateBounds)|addClass(opacity-50)"
                class="
                    max-lg:fixed max-lg:inset-0 max-lg:z-50 max-lg:bg-white max-lg:translate-y-full max-lg:opacity-0 max-lg:pointer-events-none max-lg:transition-all max-lg:duration-300
                    lg:block lg:rounded-3xl lg:p-2 lg:border lg:border-neutral-200 lg:transition-opacity lg:duration-200 lg:sticky lg:top-4 lg:h-[calc(100vh-2rem)]
                "
            >
                <button
                    type="button"
                    data-action="map-teleport#close"
                    aria-label="{{ 'marketplace.list.properties.closeMap'|trans|raw }}"
                    class="lg:hidden cursor-pointer absolute top-4 right-4 z-20 size-10 flex items-center justify-center rounded-full bg-white shadow-lg text-gray-700 hover:bg-neutral-100 transition duration-100 focus-visible:ring-2 focus-visible:ring-primary/50 focus-visible:outline-none"
                >
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" class="size-6">
                        <path d="M6 18 18 6M6 6l12 12" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </button>

                <button
                    type="button"
                    data-map-expand-target="button"
                    data-action="map-expand#toggle"
                    aria-pressed="false"
                    aria-label="{{ 'marketplace.list.properties.expandMap'|trans }}"
                    class="hidden lg:flex cursor-pointer absolute top-4 right-4 z-20 size-10 items-center justify-center rounded-full bg-white shadow-md ring-1 ring-black/5 text-gray-700 hover:bg-neutral-100 transition duration-100 focus-visible:ring-2 focus-visible:ring-primary/50 focus-visible:outline-none"
                >
                    <span data-map-expand-target="expandIcon" class="flex">
                        {{ ux_icon('lucide:maximize-2', {'class': 'size-5 shrink-0'}) }}
                    </span>
                    <span data-map-expand-target="collapseIcon" class="hidden">
                        {{ ux_icon('lucide:minimize-2', {'class': 'size-5 shrink-0'}) }}
                    </span>
                </button>
                {{ ux_map(map, {style: 'height: 100%; width: 100%;', 'class': 'lg:rounded-2xl', 'data-controller': 'map-cluster map-restriction map-paris-boundary'}) }}
            </div>
        </div>
    </section>
</div>
