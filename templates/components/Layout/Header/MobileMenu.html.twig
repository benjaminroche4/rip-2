{# @prop currentRoute        string  the current Symfony route name #}
{# @prop currentParameters   array   route params (used to swap _locale on lang switch) #}
{# @prop blogSwitchParams    array|null  per-locale params for blog post detail (alternateSlug aware) #}
{# @prop propertySwitchParams array|null per-locale params for property detail (alternateProperty aware) #}
{%- props currentRoute, currentParameters = {}, blogSwitchParams = null, propertySwitchParams = null -%}

<el-dialog>
    <dialog id="mobile-menu" class="m-0 p-0 backdrop:bg-transparent lg:hidden" aria-label="{{ 'header.menu.mobile'|trans|default('Menu mobile') }}">
        <div tabindex="0" class="fixed inset-0 focus:outline focus:outline-0">
            <el-dialog-panel class="fixed inset-y-0 right-0 z-10 flex w-full flex-col justify-between overflow-y-auto bg-white sm:max-w-sm sm:ring-1 sm:ring-gray-900/10">
                <div class="px-6 py-4">
                    <div class="flex items-center justify-between">
                        <a href="{{ path('app_home') }}" class="-m-1.5 p-1.5" aria-label="{{ 'header.logo.ariaLabel'|trans|default('Retour à l accueil') }}">
                            <span class="sr-only">Relocation In Paris</span>
                            <img
                                src="{{ asset('medias/logos/logo_red.svg') }}"
                                width="153"
                                height="150"
                                loading="eager"
                                alt="{{ 'header.logo.alt'|trans|raw }}"
                                class="h-8 w-auto"
                            />
                        </a>
                        <div class="flex items-center gap-x-2 lg:hidden">
                            <button
                                type="button"
                                command="close"
                                commandfor="mobile-menu"
                                aria-label="{{ 'header.actionClose'|trans|raw }}"
                                class="size-10 flex items-center justify-center rounded-lg text-gray-700 hover:bg-neutral-100 transition duration-100"
                            >
                                <span class="sr-only">{{ 'header.actionClose'|trans|raw }}</span>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" class="size-6">
                                    <path d="M6 18 18 6M6 6l12 12" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                            </button>
                        </div>
                    </div>
                    <div class="mt-4 flow-root">
                        <div class="h-[1px] bg-gradient-to-r from-slate-400/20 via-slate-500 to-slate-400/20 opacity-20 mb-8"></div>
                        <div class="-my-6">
                            <div class="py-3 space-y-3">
                                <a
                                    href="{{ path('app_service_find_accommodation') }}"
                                    class="{% if currentRoute == 'app_service_find_accommodation' %}bg-neutral-100 text-primary{% endif %} -mx-3 block rounded-lg px-3 py-2 text-base font-medium text-gray-900 hover:bg-gray-50 flex items-center justify-between"
                                >
                                    {{ 'header.menu.findAccommodation'|trans|raw }}
                                    <div class="max-[328px]:hidden px-2 py-0.5 rounded-lg font-medium border border-gray-200 text-xs flex items-center gap-x-2 text-gray-600 bg-white">
                                        <span class="relative flex size-2" aria-hidden="true">
                                            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-green-400 opacity-75"></span>
                                            <span class="relative inline-flex size-2 rounded-full bg-green-500"></span>
                                        </span>
                                        {{ 'header.badge.tailorMade'|trans|raw }}
                                    </div>
                                </a>
                                <a
                                    href="{{ path('app_pricing') }}"
                                    class="{% if currentRoute == 'app_pricing' %}bg-neutral-100 text-primary{% endif %} -mx-3 block rounded-lg px-3 py-2 text-base font-medium text-gray-900 hover:bg-gray-50"
                                >
                                    {{ 'header.menu.pricing'|trans|raw }}
                                </a>
                                <div class="-mx-3">
                                    <button
                                        type="button"
                                        command="--toggle"
                                        commandfor="services"
                                        aria-expanded="false"
                                        class="aria-expanded:bg-neutral-100 {% if currentRoute in ['app_service_landlords', 'app_service_find_tenant'] %}bg-neutral-100 text-primary{% endif %} flex w-full items-center text-start justify-between rounded-lg py-2 pl-3 pr-3.5 font-medium text-gray-900 hover:bg-gray-50 text-base"
                                    >
                                        {{ 'header.menu.propertyManagement'|trans|raw }}
                                        <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="size-5 flex-none shrink-0 transition-transform duration-200 [[aria-expanded='true']_&]:rotate-180">
                                            <path d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" fill-rule="evenodd"/>
                                        </svg>
                                    </button>
                                    <el-disclosure id="services" hidden class="mt-2 space-y-2 [&:not([hidden])]:block">
                                        <a
                                            href="{{ path('app_service_landlords') }}"
                                            class="{% if currentRoute == 'app_service_landlords' %}bg-neutral-100{% endif %} group relative rounded-lg p-3 text-sm/6 hover:bg-neutral-100 transition duration-100 block"
                                        >
                                            <div class="flex items-start justify-start gap-x-4">
                                                <div class="bg-neutral-100 p-2 rounded-lg group-hover:bg-white transition duration-100 {% if currentRoute == 'app_service_landlords' %}bg-white{% endif %}">
                                                    {{ ux_icon('meteor-icons:key', {'class': 'size-6 text-primary', 'aria-hidden': 'true'}) }}
                                                </div>
                                                <div class="flex flex-col w-full">
                                                    <div class="flex items-center justify-between">
                                                        <p class="block font-semibold text-gray-900">
                                                            {{ 'header.menu.management.title'|trans|raw }}
                                                        </p>
                                                        <div class="flex -space-x-1 max-[328px]:hidden" aria-label="Plateformes partenaires">
                                                            <div class="inline-flex size-6 rounded-full outline outline-1 -outline-offset-1 outline-black/5 ring-2 ring-white bg-[#2446FF] items-center justify-center">
                                                                {{ ux_icon('simple-icons:tripdotcom', {'class': 'size-4 brightness-0 invert', 'aria-hidden': 'true'}) }}
                                                            </div>
                                                            <div class="z-10 inline-flex size-6 rounded-full outline outline-1 -outline-offset-1 outline-black/5 ring-2 ring-white bg-[#133B95] items-center justify-center">
                                                                {{ ux_icon('tabler:brand-booking', {'class': 'size-4 brightness-0 invert', 'aria-hidden': 'true'}) }}
                                                            </div>
                                                            <div class="z-20 inline-flex size-6 rounded-full outline outline-1 -outline-offset-1 outline-black/5 ring-2 ring-white bg-[#F5385D] items-center justify-center">
                                                                {{ ux_icon('logos:airbnb-icon', {'class': 'size-4 brightness-0 invert', 'aria-hidden': 'true'}) }}
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <p class="mt-2 text-neutral-600">
                                                        {{ 'header.menu.management.text'|trans|raw }}
                                                    </p>
                                                </div>
                                            </div>
                                        </a>
                                        <a
                                            href="{{ path('app_service_find_tenant') }}"
                                            class="{% if currentRoute == 'app_service_find_tenant' %}bg-neutral-100{% endif %} group relative rounded-lg p-3 text-sm/6 hover:bg-neutral-100 transition duration-100 block"
                                        >
                                            <div class="flex items-start justify-start gap-x-4">
                                                <div class="bg-neutral-100 p-2 rounded-lg group-hover:bg-white transition duration-100 {% if currentRoute == 'app_service_find_tenant' %}bg-white{% endif %}">
                                                    {{ ux_icon('lucide:search', {'class': 'size-6 text-primary', 'aria-hidden': 'true'}) }}
                                                </div>
                                                <div class="flex flex-col w-full">
                                                    <div class="flex items-center justify-between">
                                                        <p class="block font-semibold text-gray-900">
                                                            {{ 'header.menu.findTenant.title'|trans|raw }}
                                                        </p>
                                                        <div class="relative max-[328px]:hidden">
                                                            <span class="absolute inset-0 flex items-center justify-center" aria-hidden="true">
                                                                <span class="absolute inline-flex size-5 animate-ping rounded-full bg-slate-400 opacity-40"></span>
                                                            </span>
                                                            <img
                                                                src="{{ asset('medias/team/team_1.webp') }}"
                                                                alt="{{ 'header.menu.findTenant.imgAlt'|trans|raw }}"
                                                                loading="lazy"
                                                                width="24"
                                                                height="24"
                                                                class="relative z-10 inline-block size-6 bg-white rounded-full outline outline-1 -outline-offset-1 outline-black/5 ring-2 ring-white"
                                                            />
                                                        </div>
                                                    </div>
                                                    <p class="mt-2 text-neutral-600">
                                                        {{ 'header.menu.findTenant.text'|trans|raw }}
                                                    </p>
                                                </div>
                                            </div>
                                        </a>
                                        <a
                                            href="{{ path('app_service_companies') }}"
                                            class="{% if currentRoute == 'app_service_companies' %}bg-neutral-100{% endif %} group relative rounded-lg p-3 text-sm/6 hover:bg-neutral-100 transition duration-100 block"
                                        >
                                            <div class="flex items-start justify-start gap-x-4">
                                                <div class="bg-neutral-100 p-2 rounded-lg group-hover:bg-white transition duration-100 {% if currentRoute == 'app_service_companies' %}bg-white{% endif %}">
                                                    {{ ux_icon('cuida:building-outline', {'class': 'size-6 text-primary', 'aria-hidden': 'true'}) }}
                                                </div>
                                                <div class="flex flex-col w-full">
                                                    <div class="flex items-center justify-between">
                                                        <p class="block font-semibold text-gray-900">
                                                            {{ 'header.menu.companies.title'|trans|raw }}
                                                        </p>
                                                    </div>
                                                    <p class="mt-2 text-neutral-600">
                                                        {{ 'header.menu.companies.text'|trans|raw }}
                                                    </p>
                                                </div>
                                            </div>
                                        </a>
                                    </el-disclosure>
                                </div>
                                <a
                                    href="{{ path('app_about_us') }}"
                                    class="{% if currentRoute == 'app_about_us' %}bg-neutral-100 text-primary{% endif %} -mx-3 block rounded-lg px-3 py-2 text-base font-medium text-gray-900 hover:bg-gray-50"
                                >
                                    {{ 'header.menu.aboutUs'|trans|raw }}
                                </a>
                            </div>
                            <div class="py-3 space-y-3">
                                <div class="h-[1px] bg-gradient-to-r from-slate-400/20 via-slate-500 to-slate-400/20 opacity-20 mb-4"></div>
                                <div class="-mx-3">
                                    <button
                                        type="button"
                                        command="--toggle"
                                        commandfor="lang"
                                        aria-expanded="false"
                                        class="flex aria-expanded:bg-neutral-100 cursor-pointer w-full items-center justify-between rounded-lg py-2 px-3.5 text-sm/7 font-semibold text-gray-900 hover:bg-neutral-100 transition duration-100"
                                    >
                                        <span class="flex items-center gap-x-4">
                                            {% if app.request.locale == 'fr' %}
                                                {{ ux_icon('circle-flags:fr', {'class': 'size-5 rounded-full', 'aria-hidden': 'true'}) }}
                                                FR
                                            {% elseif app.request.locale == 'en' %}
                                                {{ ux_icon('circle-flags:en', {'class': 'size-5 rounded-full', 'aria-hidden': 'true'}) }}
                                                EN
                                            {% endif %}
                                        </span>
                                        <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="size-5 flex-none shrink-0 transition-transform duration-200 [[aria-expanded='true']_&]:rotate-180">
                                            <path d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" fill-rule="evenodd"/>
                                        </svg>
                                    </button>
                                    <el-disclosure id="lang" hidden class="mt-2 [&:not([hidden])]:block">
                                        <a
                                            href="{{ path(currentRoute, blogSwitchParams ? blogSwitchParams.fr : (propertySwitchParams ? propertySwitchParams.fr : (currentParameters ?? {})|merge({'_locale': 'fr'}))) }}"
                                            hreflang="fr"
                                            lang="fr"
                                            class="block rounded-lg py-2 px-3.5 text-sm/7 font-semibold text-gray-900 hover:bg-neutral-100 cursor-pointer flex justify-between items-center"
                                        >
                                            <span class="flex items-center gap-x-4">
                                                {{ ux_icon('circle-flags:fr', {'class': 'size-5 rounded-full', 'aria-hidden': 'true'}) }}
                                                FR
                                            </span>
                                            {% if app.request.locale == 'fr' %}
                                                <div class="rounded-full bg-primary p-1" aria-label="Langue active">
                                                    {{ ux_icon('lucide:check', {'class': 'text-white size-2.5 shrink-0', 'aria-hidden': 'true'}) }}
                                                </div>
                                            {% endif %}
                                        </a>
                                        <a
                                            href="{{ path(currentRoute, blogSwitchParams ? blogSwitchParams.en : (propertySwitchParams ? propertySwitchParams.en : (currentParameters ?? {})|merge({'_locale': 'en'}))) }}"
                                            hreflang="en"
                                            lang="en"
                                            class="block rounded-lg py-2 px-3.5 text-sm/7 font-semibold text-gray-900 hover:bg-neutral-100 cursor-pointer flex justify-between items-center"
                                        >
                                            <span class="flex items-center gap-x-4">
                                                {{ ux_icon('circle-flags:en', {'class': 'size-5 rounded-full', 'aria-hidden': 'true'}) }}
                                                EN
                                            </span>
                                            {% if app.request.locale == 'en' %}
                                                <div class="rounded-full bg-primary p-1" aria-label="Langue active">
                                                    {{ ux_icon('lucide:check', {'class': 'text-white size-2.5 shrink-0', 'aria-hidden': 'true'}) }}
                                                </div>
                                            {% endif %}
                                        </a>
                                    </el-disclosure>
                                </div>
                                <div class="h-[1px] bg-gradient-to-r from-slate-400/20 via-slate-500 to-slate-400/20 opacity-20 mb-4"></div>
                            </div>
                            <div class="space-y-3 -mx-3">
                                <twig:Button variant="default" as="a" size="lg" class="w-full" href="{{ path('app_contact') }}">
                                    {{ 'header.cta.title'|trans|raw }}
                                </twig:Button>
                            </div>
                        </div>
                    </div>
                </div>
            </el-dialog-panel>
        </div>
    </dialog>
</el-dialog>
