{# Footer login/admin/logout link — ESI fragment.
   Caller passes `currentRoute` so the active-style highlight still works
   even though we're outside the parent page's request scope. Admin users
   see a shortcut to the dashboard instead of the logout link. #}
{%- set route = currentRoute|default('') -%}
{% if app.user %}
    {% if is_granted('ROLE_ADMIN') %}
        <a href="{{ path('admin_dashboard', {_locale: app.request.locale, adminPrefix: adminPrefix}) }}" class="{% if route == 'admin_dashboard' %}text-slate-400{% else %}text-slate-200{% endif %} hover:text-slate-400 transition duration-100">{{ 'footer.menu.adminSpace'|trans|raw }}</a>
    {% else %}
        <a href="{{ path('app_logout') }}" class="{% if route == 'app_logout' %}text-slate-400{% else %}text-slate-200{% endif %} hover:text-slate-400 transition duration-100">{{ 'footer.menu.logout'|trans|raw }}</a>
    {% endif %}
{% else %}
    <a href="{{ path('app_login') }}" class="{% if route == 'app_login' %}text-slate-400{% else %}text-slate-200{% endif %} hover:text-slate-400 transition duration-100">{{ 'footer.menu.login'|trans|raw }}</a>
{% endif %}
