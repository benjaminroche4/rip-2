{# @prop form  Symfony form view (ContactType) #}
{%- props form -%}

<div class="text-center mb-6 lg:mb-12 mt-3 lg:mt-0">
    <div class="flex items-center justify-center gap-x-3 mb-4">
        <div class="flex -space-x-1.5" aria-hidden="true">
            <img src="{{ asset('medias/team/team_1.webp') }}" alt="{{ 'ctaFooter.image.1.alt'|trans|raw }}" loading="eager" width="28" height="28" class="inline-block size-7 rounded-full outline outline-1 -outline-offset-1 outline-gray-700/10 ring-2 ring-white" />
            <img src="{{ asset('medias/team/team_5.webp') }}" alt="{{ 'ctaFooter.image.2.alt'|trans|raw }}" loading="eager" width="28" height="28" class="inline-block size-7 rounded-full outline outline-1 -outline-offset-1 outline-gray-700/10 ring-2 ring-white" />
            <img src="{{ asset('medias/team/team_3.webp') }}" alt="{{ 'ctaFooter.image.3.alt'|trans|raw }}" loading="eager" width="28" height="28" class="inline-block size-7 rounded-full outline outline-1 -outline-offset-1 outline-gray-700/10 ring-2 ring-white" />
        </div>
        <div class="py-2 px-2.5 rounded-full bg-white flex items-center justify-center gap-x-1.5 text-green-600">
            <span class="relative flex size-1.5" aria-hidden="true">
                <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-green-400 opacity-75"></span>
                <span class="relative inline-flex size-1.5 rounded-full bg-green-500"></span>
            </span>
            <p class="text-xs">{{ 'contact.contactForm.badge'|trans|raw }}</p>
        </div>
    </div>
    <div class="space-y-1">
        <h2 id="form-heading" class="text-2xl font-semibold">{{ 'contact.contactForm.title'|trans|raw }}</h2>
        <p class="text-slate-600 font-light text-pretty">{{ 'contact.contactForm.text'|trans|raw }}</p>
    </div>
</div>

{{ form_start(form, {'attr': {'class': 'space-y-6', 'novalidate': 'novalidate'}}) }}

{% for message in app.flashes('contactSuccess') %}
    <div role="alert" aria-live="polite" class="rounded-xl bg-green-50 p-4">
        <div class="flex items-start gap-x-3">
            <div class="flex-shrink-0" aria-hidden="true">
                {{ ux_icon('lucide:circle-check', {'class': 'text-green-600 size-5'}) }}
            </div>
            <div class="space-y-0.5">
                <p class="text-base font-medium text-green-800">{{ message }}</p>
                <p class="text-sm text-slate-600">{{ 'contact.contactForm.success.text'|trans }}</p>
            </div>
        </div>
    </div>
{% endfor %}

<div class="space-y-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <div>
            <div class="flex items-center gap-x-0.5">
                {{ form_label(form.firstName, null, {'label_attr': {'class': 'block text-sm/6 font-semibold text-gray-900'}}) }}
                <span class="text-red-600" aria-hidden="true">*</span>
            </div>
            <div class="mt-2">
                {{ form_widget(form.firstName, {'attr': {
                    'class': 'block w-full rounded-lg bg-white px-3 py-2.5 text-base text-gray-900 border border-gray-300 placeholder:text-gray-400 focus:outline focus:outline-2 focus:-outline-offset-2 focus:ring-primary/60 focus:outline-primary/80 sm:text-sm/6',
                    'placeholder': 'contact.contactForm.firstName.placeholder'|trans,
                    'autocomplete': 'given-name',
                    'aria-required': 'true'
                }}) }}
                {% for error in form.firstName.vars.errors %}
                    <p class="mt-1.5 text-sm text-red-600" role="alert">{{ error.message }}</p>
                {% endfor %}
            </div>
        </div>
        <div>
            <div class="flex items-center gap-x-0.5">
                {{ form_label(form.lastName, null, {'label_attr': {'class': 'block text-sm/6 font-semibold text-gray-900'}}) }}
                <span class="text-red-600" aria-hidden="true">*</span>
            </div>
            <div class="mt-2">
                {{ form_widget(form.lastName, {'attr': {
                    'class': 'block w-full rounded-lg bg-white px-3 py-2.5 text-base text-gray-900 border border-gray-300 placeholder:text-gray-400 focus:outline focus:outline-2 focus:-outline-offset-2 focus:ring-primary/60 focus:outline-primary/80 sm:text-sm/6',
                    'placeholder': 'contact.contactForm.lastName.placeholder'|trans,
                    'autocomplete': 'family-name',
                    'aria-required': 'true'
                }}) }}
                {% for error in form.lastName.vars.errors %}
                    <p class="mt-1.5 text-sm text-red-600" role="alert">{{ error.message }}</p>
                {% endfor %}
            </div>
        </div>
    </div>

    <div>
        <div class="flex items-center gap-x-0.5">
            {{ form_label(form.email, null, {'label_attr': {'class': 'block text-sm/6 font-semibold text-gray-900'}}) }}
            <span class="text-red-600" aria-hidden="true">*</span>
        </div>
        <div class="mt-2">
            {{ form_widget(form.email, {'attr': {
                'class': 'block w-full rounded-lg bg-white px-3 py-2.5 text-base text-gray-900 border border-gray-300 placeholder:text-gray-400 focus:outline focus:outline-2 focus:-outline-offset-2 focus:ring-primary/60 focus:outline-primary/80 sm:text-sm/6',
                'placeholder': 'contact.contactForm.email.placeholder'|trans,
                'autocomplete': 'email',
                'aria-required': 'true'
            }}) }}
            {% for error in form.email.vars.errors %}
                <p class="mt-1.5 text-sm text-red-600" role="alert">{{ error.message }}</p>
            {% endfor %}
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <div data-controller="phone-input" data-phone-input-initial-country-value="{{ app.request.locale == 'en' ? 'gb' : 'fr' }}" data-phone-input-search-placeholder-value="{{ 'phoneInput.searchPlaceholder'|trans }}" class="text-base sm:text-sm/6">
            <div class="flex items-center gap-x-0.5">
                {{ form_label(form.phoneNumber, null, {'label_attr': {'class': 'block text-sm/6 font-semibold text-gray-900'}}) }}
                <span class="text-red-600" aria-hidden="true">*</span>
            </div>
            <div class="mt-2">
                {{ form_widget(form.phoneNumber, {'attr': {
                    'class': 'block w-full rounded-lg bg-white px-3 py-2.5 text-base text-gray-900 border border-gray-300 placeholder:text-gray-400 focus:outline focus:outline-2 focus:-outline-offset-2 focus:ring-primary/60 focus:outline-primary/80 sm:text-sm/6',
                    'placeholder': ' ',
                    'autocomplete': 'tel',
                    'aria-required': 'true',
                    'data-phone-input-target': 'input'
                }}) }}
                {% for error in form.phoneNumber.vars.errors %}
                    <p class="mt-1.5 text-sm text-red-600" role="alert">{{ error.message }}</p>
                {% endfor %}
            </div>
        </div>
        <div>
            <div class="flex items-center gap-x-0.5">
                {{ form_label(form.company, null, {'label_attr': {'class': 'block text-sm/6 font-semibold text-gray-900'}}) }}
            </div>
            <div class="mt-2">
                {{ form_widget(form.company, {'attr': {
                    'class': 'block w-full rounded-lg bg-white px-3 py-2.5 text-base text-gray-900 border border-gray-300 placeholder:text-gray-400 focus:outline focus:outline-2 focus:-outline-offset-2 focus:ring-primary/60 focus:outline-primary/80 sm:text-sm/6',
                    'placeholder': 'contact.contactForm.company.placeholder'|trans,
                    'autocomplete': 'organization'
                }}) }}
            </div>
        </div>
    </div>

    <div data-controller="select" class="relative">
        <div class="flex items-center gap-x-0.5">
            {{ form_label(form.helpType, null, {'label_attr': {'class': 'block text-sm/6 font-semibold text-gray-900'}}) }}
            <span class="text-red-600" aria-hidden="true">*</span>
        </div>
        <div class="mt-2">
            {{ form_widget(form.helpType, {'attr': {
                'class': 'sr-only',
                'data-select-target': 'select',
                'tabindex': -1,
                'aria-hidden': 'true',
            }}) }}
            <button
                type="button"
                data-select-target="button"
                data-action="click->select#toggle"
                aria-haspopup="listbox"
                aria-expanded="false"
                aria-controls="{{ form.helpType.vars.id }}-panel"
                class="flex w-full items-center justify-between rounded-lg bg-white px-3 py-2.5 text-base text-gray-900 border border-gray-300 focus:outline focus:outline-2 focus:-outline-offset-2 focus:ring-primary/60 focus:outline-primary/80 sm:text-sm/6 cursor-pointer"
            >
                <span data-select-target="display" class="text-gray-400">{{ 'contact.contactForm.helpType.placeholder'|trans }}</span>
                <svg aria-hidden="true" class="size-4 text-gray-400 ml-2 shrink-0" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 0 1 1.06.02L10 11.06l3.71-3.83a.75.75 0 1 1 1.08 1.04l-4.25 4.39a.75.75 0 0 1-1.08 0L5.21 8.27a.75.75 0 0 1 .02-1.06Z" clip-rule="evenodd"/></svg>
            </button>
            <div
                id="{{ form.helpType.vars.id }}-panel"
                data-select-target="panel"
                hidden
                class="absolute z-10 mt-1 w-full overflow-hidden rounded-lg bg-white border border-gray-300 shadow-lg"
            >
                <ul
                    role="listbox"
                    tabindex="-1"
                    data-select-target="list"
                    data-action="click->select#choose keydown->select#keydown"
                    class="max-h-60 overflow-auto py-1 outline-none"
                ></ul>
            </div>
            {% for error in form.helpType.vars.errors %}
                <p class="mt-1.5 text-sm text-red-600" role="alert">{{ error.message }}</p>
            {% endfor %}
        </div>
    </div>

    <div>
        <div class="flex items-center gap-x-0.5">
            {{ form_label(form.message, null, {'label_attr': {'class': 'block text-sm/6 font-semibold text-gray-900'}}) }}
        </div>
        <div class="mt-2">
            {{ form_widget(form.message, {'attr': {
                'rows': '5',
                'class': 'block w-full rounded-lg bg-white px-3 py-2.5 text-base text-gray-900 border border-gray-300 placeholder:text-gray-400 focus:outline focus:outline-2 focus:-outline-offset-2 focus:ring-primary/60 focus:outline-primary/80 sm:text-sm/6',
                'placeholder': 'contact.contactForm.message.placeholder'|trans,
                'autocomplete': 'off'
            }}) }}
        </div>
    </div>
</div>

<div>
    <div class="flex items-center">
        {{ form_widget(form.accept, {'attr': {
            'class': 'peer size-4 inline-block align-middle accent-primary rounded-sm border border-gray-300 focus:outline focus:outline-2 focus:-outline-offset-2 focus:ring-primary/60 focus:outline-primary/80 checked:bg-primary checked:border-primary disabled:cursor-not-allowed disabled:opacity-50',
            'aria-required': 'true'
        }}) }}
        <label for="{{ form.accept.vars.id }}" class="ml-3 block text-sm leading-5 text-neutral-900">{{ 'contact.contactForm.accept.label'|trans }}</label>
    </div>
    {% for error in form.accept.vars.errors %}
        <p class="mt-1.5 text-sm text-red-600" role="alert">{{ error.message }}</p>
    {% endfor %}
</div>

<div class="pt-4">
    <twig:Button variant="default" size="lg" class="w-full cursor-pointer">
        {{ ux_icon('famicons:paper-plane-outline', {'class': 'size-4 shrink-0', 'aria-hidden': 'true'}) }}
        {{ 'contact.contactForm.button'|trans|raw }}
    </twig:Button>
</div>

{{ form_end(form) }}

<p class="-mt-2 flex items-start mt-1 lg:mt-0 lg:items-center font-light justify-center gap-x-1.5 text-neutral-500 text-left lg:text-center text-sm">
    {{ ux_icon('mingcute:bell-ringing-line', {'class': 'size-4 shrink-0 text-neutral-500', 'aria-hidden': 'true'}) }}
    {{ 'contact.contactForm.subButtonText'|trans|raw }}
</p>
