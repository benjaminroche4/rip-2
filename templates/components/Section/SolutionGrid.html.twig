{# Reusable solution-features section: heading + sub-heading + grid of N
   cards, each with an icon and a title/text translation pair.

   Translation keys are derived from `keyPrefix` so the call site stays
   short. For keyPrefix="findAccommodation.solution" + icons of length 6,
   the section reads:
     - findAccommodation.solution.title       (small caption)
     - findAccommodation.solution.subTitle    (h2)
     - findAccommodation.solution.{1..6}.title
     - findAccommodation.solution.{1..6}.text

   Used by services/findAccommodation, services/findTenant. #}

{# @prop keyPrefix string Translation namespace, e.g. 'findAccommodation.solution' #}
{# @prop icons     array  Iconify icon names; the array length determines the card count #}
{%- props keyPrefix, icons -%}

<section class="max-w-6xl mx-auto lg:px-8 px-6 lg:py-16 py-12">
    <div class="rounded-2xl bg-neutral-100/80 p-8">
        <div class="mt-5 pb-12 lg:pb-16 mx-auto text-center space-y-3">
            <h2 class="text-sm font-semibold text-primary font-secondary">{{ (keyPrefix ~ '.title')|trans|raw }}</h2>
            <h2 class="text-3xl font-medium text-pretty text-center">{{ (keyPrefix ~ '.subTitle')|trans|raw }}</h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 lg:grid-cols-3">
            {% for icon in icons %}
                {% set i = loop.index %}
                <div class="bg-white rounded-xl p-6 border border-neutral-100 hover:border-primary/20 transition-colors duration-100 space-y-2 shadow-lg shadow-gray-300/30 group">
                    <div class="flex items-center flex-col gap-3">
                        <div class="p-2 border bg-white border-slate-200 block rounded-lg w-fit group-hover:bg-primary transition-colors duration-100">
                            {{ ux_icon(icon, {'class':'size-6 text-primary shrink-0 group-hover:text-white'}) }}
                        </div>
                        <h3 class="font-semibold text-lg text-center text-pretty">{{ (keyPrefix ~ '.' ~ i ~ '.title')|trans|raw }}</h3>
                    </div>
                    <p class="flex-auto text-neutral-800/70 text-base/6 text-center">{{ (keyPrefix ~ '.' ~ i ~ '.text')|trans|raw }}</p>
                </div>
            {% endfor %}
        </div>
    </div>
</section>
