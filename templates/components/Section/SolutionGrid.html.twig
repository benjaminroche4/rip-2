{# Reusable feature/solution grid: heading + sub-heading + grid of N cards,
   each with an icon and a title/text translation pair.

   Translation keys are derived from `keyPrefix` so the call site stays
   short. For keyPrefix="findAccommodation.solution" + icons of length 6,
   the section reads:
     - findAccommodation.solution.title       (small caption / eyebrow)
     - findAccommodation.solution.subTitle    (h2)
     - findAccommodation.solution.{1..6}.title
     - findAccommodation.solution.{1..6}.text

   Used by services/find_accommodation, services/find_tenant, services/companies
   and property_estimation (gestion locative). #}

{# @prop keyPrefix string Translation namespace, e.g. 'findAccommodation.solution' #}
{# @prop icons     array  Iconify icon names; the array length determines the card count #}
{%- props keyPrefix, icons -%}

<section class="max-w-6xl mx-auto lg:px-8 px-6 lg:py-16 py-12">
    <div class="mx-auto max-w-2xl text-center pb-12 lg:pb-16">
        <p class="font-semibold text-primary font-secondary">{{ (keyPrefix ~ '.title')|trans|raw }}</p>
        <h2 class="mt-3 text-3xl sm:text-4xl font-medium text-black text-balance leading-[1.3]">{{ (keyPrefix ~ '.subTitle')|trans|raw }}</h2>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {% for icon in icons %}
            {% set i = loop.index %}
            <div class="group rounded-2xl p-2 border border-neutral-200">
                <div class="flex h-full flex-col items-start gap-4 rounded-xl p-5 bg-linear-to-b from-neutral-100 to-neutral-100/0 transition-colors duration-100 ease-out group-hover:from-primary group-hover:to-primary">
                    <div class="flex size-11 shrink-0 items-center justify-center rounded-lg bg-white p-2.5">
                        {{ ux_icon(icon, {'class':'size-6 text-primary shrink-0'}) }}
                    </div>
                    <div class="flex flex-col gap-1.5">
                        <h3 class="text-lg font-medium text-pretty text-black transition-colors duration-100 ease-out group-hover:text-white">{{ (keyPrefix ~ '.' ~ i ~ '.title')|trans|raw }}</h3>
                        <p class="text-sm font-light text-[#525252] transition-colors duration-100 ease-out group-hover:text-white/90">{{ (keyPrefix ~ '.' ~ i ~ '.text')|trans|raw }}</p>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
</section>
