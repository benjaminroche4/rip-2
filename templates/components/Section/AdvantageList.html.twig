{# Reusable "advantage" section: heading + intro paragraph + a 2-column
   grid with a Stimulus features-list on the left and a single image
   on the right.

   Translation keys derived from `keyPrefix`:
     - {keyPrefix}.title    (small caption)
     - {keyPrefix}.subTitle (h3)
     - {keyPrefix}.text     (intro paragraph)
     - {keyPrefix}.{1..N}.title / .text (per-feature)

   Used by services/findAccommodation, services/findTenant, services/companies. #}

{# @prop keyPrefix string Translation namespace, e.g. 'findAccommodation.advantage' #}
{# @prop imageSrc  string Asset path for the right-hand image #}
{# @prop imageAlt  string Alt text for the image #}
{# @prop count     int    Number of feature items (default 4) #}
{%- props keyPrefix, imageSrc, imageAlt, count = 4 -%}

<section class="overflow-hidden bg-white py-12 lg:py-16 lg:px-8 px-6">
    <div class="mx-auto max-w-7xl md:px-6 lg:px-8">
        <div class="max-w-xl mb-8 mx-auto lg:mx-0">
            <h2 class="text-sm font-semibold text-primary font-secondary">{{ (keyPrefix ~ '.title')|trans|raw }}</h2>
            <h3 class="mt-3 text-pretty text-3xl font-medium">{{ (keyPrefix ~ '.subTitle')|trans|raw }}</h3>
            <p class="mt-6 text-neutral-600">
                {{ (keyPrefix ~ '.text')|trans|raw }}
            </p>
        </div>
        <div class="grid grid-cols-1 gap-x-8 gap-y-16 sm:gap-y-20 lg:grid-cols-2 lg:items-start">
            <div class="lg:px-0 lg:pr-4">
                <div class="mx-auto max-w-2xl lg:mx-0 max-w-lg">
                    <div data-controller="features-list" class="relative bg-white">
                        <div class="relative">
                            {% for i in 1..count %}
                                <div
                                    data-features-list-target="item"
                                    data-action="click->features-list#activate"
                                    class="relative pl-6 pr-4 py-4 rounded-r-xl cursor-pointer transition-colors duration-200"
                                >
                                    <div class="absolute left-0 top-0 w-1 h-full bg-gray-200 rounded-full"></div>
                                    <div
                                        data-features-list-target="indicator"
                                        class="absolute left-0 top-0 w-1 bg-primary rounded-full"
                                        style="height: 0;"
                                    ></div>
                                    <h4 class="font-bold text-lg text-slate-800 mb-2">
                                        {{ (keyPrefix ~ '.' ~ i ~ '.title')|trans|raw }}
                                    </h4>
                                    <p class="text-sm text-slate-600">
                                        {{ (keyPrefix ~ '.' ~ i ~ '.text')|trans|raw }}
                                    </p>
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                </div>
            </div>
            <div class="h-full">
                <img
                    width="546"
                    height="448"
                    loading="eager"
                    src="{{ asset(imageSrc) }}"
                    alt="{{ imageAlt }}"
                    class="w-full h-[250px] lg:h-full object-cover rounded-2xl"
                />
            </div>
        </div>
    </div>
</section>
