{# Anonymous Twig component <twig:Input>.
   All standard <input> attributes (type, name, value, placeholder, required,
   pattern, min/max, autocomplete, …) pass through via {{ attributes }}.
   Add focus, disabled and file-input variants out of the box. #}
<input
    class="{{ 'flex h-10 w-full rounded-lg border border-gray-300 bg-white px-3 py-2.5 text-base text-gray-900 sm:text-sm/6 file:border-0 file:bg-transparent file:text-sm file:font-medium placeholder:text-gray-400 focus:outline focus:outline-2 focus:-outline-offset-2 focus:ring-primary/60 focus:outline-primary/80 disabled:cursor-not-allowed disabled:opacity-50 ' ~ attributes.render('class')|tailwind_merge }}"
    {{ attributes }}
>
