{# @prop kpi array{title: string, period: string, value: int, previous: ?int, deltaPercent: ?int, trend: 'up'|'down'|'neutral', currentLabel?: ?string, previousLabel?: ?string} KPI payload built by AdminKpiBuilder #}
{# @prop currencySymbol string Optional currency suffix; when set the value is rendered with thousands separator + suffix (formatting and bar-label width adapt accordingly). #}
{%- props kpi, currencySymbol = '' -%}
{%- set _gradient = {
    up: 'from-green-100/60 to-green-100/0',
    down: 'from-red-100/60 to-red-100/0',
    neutral: 'from-neutral-100/50 to-neutral-100/0',
}[kpi.trend] -%}
{%- set _deltaColor = {
    up: 'text-green-700',
    down: 'text-red-700',
    neutral: 'text-gray-500',
}[kpi.trend] -%}
{%- set _trendIcon = {
    up: 'streamline:graph-arrow-increase',
    down: 'streamline:graph-arrow-decrease',
    neutral: null,
}[kpi.trend] -%}
{%- set _maxVal = max(kpi.value, kpi.previous ?? 0) -%}
{%- set _curPct = (_maxVal > 0) ? (kpi.value / _maxVal * 100)|round : 0 -%}
{%- set _prevPct = (_maxVal > 0 and kpi.previous is not null) ? (kpi.previous / _maxVal * 100)|round : 0 -%}
{%- set _hasCurrency = '' != currencySymbol -%}
{%- set _barLabelWidth = _hasCurrency ? 'w-24' : 'w-10' -%}
{%- set _formattedValue = _hasCurrency ? kpi.value|number_format(0, ',', ' ') : kpi.value -%}
{%- set _formattedPrevious = _hasCurrency ? kpi.previous|number_format(0, ',', ' ') : kpi.previous -%}
<article {{ attributes.defaults({class: 'rounded-2xl border border-gray-950/5 bg-white p-2'}) }}>
    <div class="space-y-6 rounded-xl bg-linear-to-b p-4 {{ _gradient }}">
        <div>
            <h2 class="text-xl font-semibold tracking-tight text-gray-900">{{ kpi.title }}</h2>
            <p class="mt-0.5 text-sm text-pretty text-gray-500">{{ kpi.period }}</p>
        </div>
        <div class="space-y-4">
            <div class="flex items-end justify-between gap-3">
                <p class="text-3xl font-medium tabular-nums text-gray-900">
                    {{ _formattedValue }}{% if _hasCurrency %}<span class="ml-1 text-2xl text-gray-500">{{ currencySymbol }}</span>{% endif %}
                </p>
                {% if _trendIcon %}
                    <div class="flex items-center gap-x-2 text-sm font-light {{ _deltaColor }}">
                        {% if kpi.deltaPercent is not null %}
                            {{ kpi.deltaPercent > 0 ? '+' : '' }}{{ kpi.deltaPercent }}%
                        {% endif %}
                        {{ ux_icon(_trendIcon, {class: 'size-4', 'aria-hidden': 'true'}) }}
                    </div>
                {% endif %}
            </div>
            <div class="space-y-1.5">
                <div class="flex items-center gap-2 text-xs">
                    <span class="w-16 shrink-0 text-gray-500">{{ kpi.currentLabel ?? 'admin.dashboard.kpi.currentLabel'|trans }}</span>
                    <div class="h-1.5 grow overflow-hidden rounded-full bg-gray-100">
                        <div class="h-full rounded-full bg-gray-700 w-(--bar-pct)" style="--bar-pct: {{ _curPct }}%"></div>
                    </div>
                    <p class="{{ _barLabelWidth }} shrink-0 text-right text-xs tabular-nums text-gray-700">
                        {{ _formattedValue }}{% if _hasCurrency %} {{ currencySymbol }}{% endif %}
                    </p>
                </div>
                <div class="flex items-center gap-2 text-xs">
                    <span class="w-16 shrink-0 text-gray-500">{{ kpi.previousLabel ?? 'admin.dashboard.kpi.previousLabel'|trans }}</span>
                    <div class="h-1.5 grow overflow-hidden rounded-full bg-gray-100">
                        <div class="h-full rounded-full bg-gray-300 w-(--bar-pct)" style="--bar-pct: {{ _prevPct }}%"></div>
                    </div>
                    <p class="{{ _barLabelWidth }} shrink-0 text-right text-xs tabular-nums text-gray-500">
                        {{ _formattedPrevious }}{% if _hasCurrency %} {{ currencySymbol }}{% endif %}
                    </p>
                </div>
            </div>
        </div>
    </div>
</article>
