{#
    Admin:DocumentRequestForm — bilingual multi-person document request flow.
    Sidebar master-detail layout: left rail lists every person with their
    summary, right panel shows the form of the active one. Below the grids
    sit the household-wide fields (typology, drive link, language).

    Spacing / surface conventions mirror DocumentList:
      - section heading: text-base font-semibold + text-sm text-gray-500 sub
      - container cards: rounded-2xl border border-gray-950/5 bg-white p-2
      - inner surface: rounded-xl bg-neutral-50/50 p-4..p-5
      - vertical rhythm: space-y-6 between sections, gap-* inside flex/grid
#}

{# Macro: form fields for a single person. Reused as the body of the
   right-hand panel — keeps the input markup in a single place. #}
{% macro personFields(personForm, docsById, locale) %}
    {% set hasFirstNameErrors = personForm.firstName.vars.errors|length > 0 %}
    {% set hasLastNameErrors = personForm.lastName.vars.errors|length > 0 %}

    <div class="flex flex-col gap-5">
        <div>
            <p id="{{ personForm.role.vars.id }}-label" class="text-sm font-semibold text-gray-900">
                {{ 'admin.tools.documents.request.person.role.label'|trans }}
                <span class="text-red-600" aria-hidden="true">*</span>
            </p>
            <div role="radiogroup" aria-labelledby="{{ personForm.role.vars.id }}-label" class="mt-2 inline-flex rounded-lg border border-gray-950/5 bg-neutral-50/50 p-1">
                {% for choice in personForm.role.children %}
                    <label for="{{ choice.vars.id }}" class="cursor-pointer rounded-md px-4 py-1.5 text-sm font-medium text-gray-700 transition-colors hover:text-gray-900 has-[input:checked]:bg-white has-[input:checked]:text-primary has-[input:checked]:shadow-sm">
                        <input
                            type="radio"
                            id="{{ choice.vars.id }}"
                            name="{{ choice.vars.full_name }}"
                            value="{{ choice.vars.value }}"
                            {% if choice.vars.checked %}checked{% endif %}
                            class="sr-only"
                        />
                        {{ choice.vars.label|trans }}
                    </label>
                {% endfor %}
            </div>
            {% for error in personForm.role.vars.errors %}
                <p class="mt-1.5 text-sm text-red-600" role="alert">{{ error.message }}</p>
            {% endfor %}
        </div>

        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
            <div>
                <twig:Label for="{{ personForm.firstName.vars.id }}" class="text-sm font-semibold text-gray-900">
                    {{ 'admin.tools.documents.request.person.firstName.label'|trans }}
                    <span class="text-red-600" aria-hidden="true">*</span>
                </twig:Label>
                <div class="mt-2">
                    <twig:Input
                        type="text"
                        id="{{ personForm.firstName.vars.id }}"
                        name="{{ personForm.firstName.vars.full_name }}"
                        value="{{ personForm.firstName.vars.value }}"
                        maxlength="50"
                        required="required"
                        aria-invalid="{{ hasFirstNameErrors ? 'true' : 'false' }}"
                    />
                    {% for error in personForm.firstName.vars.errors %}
                        <p class="mt-1.5 text-sm text-red-600" role="alert">{{ error.message }}</p>
                    {% endfor %}
                </div>
            </div>
            <div>
                <twig:Label for="{{ personForm.lastName.vars.id }}" class="text-sm font-semibold text-gray-900">
                    {{ 'admin.tools.documents.request.person.lastName.label'|trans }}
                    <span class="text-red-600" aria-hidden="true">*</span>
                </twig:Label>
                <div class="mt-2">
                    <twig:Input
                        type="text"
                        id="{{ personForm.lastName.vars.id }}"
                        name="{{ personForm.lastName.vars.full_name }}"
                        value="{{ personForm.lastName.vars.value }}"
                        maxlength="50"
                        required="required"
                        aria-invalid="{{ hasLastNameErrors ? 'true' : 'false' }}"
                    />
                    {% for error in personForm.lastName.vars.errors %}
                        <p class="mt-1.5 text-sm text-red-600" role="alert">{{ error.message }}</p>
                    {% endfor %}
                </div>
            </div>
        </div>

        <div>
            <p id="{{ personForm.documents.vars.id }}-label" class="text-sm font-semibold text-gray-900">
                {{ 'admin.tools.documents.request.person.documents.label'|trans }}
                <span class="text-red-600" aria-hidden="true">*</span>
            </p>
            <div role="group" aria-labelledby="{{ personForm.documents.vars.id }}-label" class="mt-2 grid grid-cols-1 gap-2 sm:grid-cols-2">
                {% if personForm.documents.children is empty %}
                    <p class="col-span-full rounded-lg border border-dashed border-gray-950/10 bg-gray-50/50 p-3 text-xs italic text-gray-500">
                        {{ 'admin.tools.documents.request.person.documents.emptyCatalogue'|trans }}
                    </p>
                {% else %}
                    {% for docChoice in personForm.documents.children %}
                        {% set doc = docsById[docChoice.vars.value] ?? null %}
                        <label for="{{ docChoice.vars.id }}" class="group flex h-full cursor-pointer items-start gap-3 rounded-lg border border-gray-950/5 bg-white p-3 transition-colors has-[input:checked]:border-primary/40 has-[input:checked]:bg-primary/5 hover:bg-neutral-50/60">
                            <span class="group inline-grid size-4 shrink-0 grid-cols-1 self-start pt-0.5">
                                <input
                                    type="checkbox"
                                    id="{{ docChoice.vars.id }}"
                                    name="{{ docChoice.vars.full_name }}"
                                    value="{{ docChoice.vars.value }}"
                                    {% if docChoice.vars.checked %}checked{% endif %}
                                    class="col-start-1 row-start-1 appearance-none rounded-sm border border-gray-300 bg-white checked:border-primary checked:bg-primary focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary disabled:border-gray-300 disabled:bg-gray-100 forced-colors:appearance-auto"
                                />
                                <svg viewBox="0 0 14 14" fill="none" class="pointer-events-none col-start-1 row-start-1 size-7/8 self-center justify-self-center stroke-white">
                                    <path d="M3 8L6 11L11 3.5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-not-has-checked:opacity-0" />
                                </svg>
                            </span>
                            <span class="min-w-0 flex-1">
                                <span class="flex items-center gap-1.5">
                                    <span class="block text-sm font-medium text-gray-900">{{ doc ? doc.getName(locale) : docChoice.vars.label|trans }}</span>
                                    {% if doc and doc.pinned %}
                                        <twig:ux:icon
                                            name="lucide:pin"
                                            class="size-3 shrink-0 text-gray-400"
                                            title="{{ 'admin.tools.documents.list.pinnedBadge'|trans }}"
                                            role="img"
                                            aria-label="{{ 'admin.tools.documents.list.pinnedBadge'|trans }}"
                                            data-testid="document-pinned-badge"
                                        />
                                    {% endif %}
                                </span>
                                {% if doc %}
                                    {% set desc = doc.getDescription(locale) %}
                                    {% if desc %}
                                        <span class="mt-0.5 block text-xs text-gray-500">{{ desc }}</span>
                                    {% endif %}
                                {% endif %}
                            </span>
                        </label>
                    {% endfor %}
                {% endif %}
            </div>
            {% for error in personForm.documents.vars.errors %}
                <p class="mt-1.5 text-sm text-red-600" role="alert">{{ error.message }}</p>
            {% endfor %}
        </div>
    </div>
{% endmacro %}

{% macro removeButton(idx, label) %}
    <button
        type="button"
        class="inline-flex items-center gap-1 rounded-lg px-2 py-1 text-xs font-medium text-gray-500 transition-colors hover:bg-red-50 hover:text-red-600 focus:outline-none focus-visible:outline focus-visible:outline-2 focus-visible:-outline-offset-2 focus-visible:outline-gray-300"
        data-action="live#action"
        data-live-action-param="removePerson"
        data-live-index-param="{{ idx }}"
    >
        <twig:ux:icon name="lucide:x" class="size-3.5 shrink-0" aria-hidden="true" />
        {{ label }}
    </button>
{% endmacro %}

{% import _self as ui %}

{% set persons = form.persons %}
{% set personCount = persons.children|length %}
{% set maxPersons = constant('App\\Admin\\Entity\\DocumentRequest::MAX_PERSONS') %}
{% set canAdd = personCount < maxPersons %}
{% set docsById = this.documentsById %}
{% set activeIndex = this.activePersonIndex %}

<form
    {{ attributes.defaults({
        'data-action': 'live#action:prevent document-request:download@window->download-trigger#download',
        'data-live-action-param': 'generate',
        'data-model': 'on(change)|*',
        'data-controller': 'download-trigger',
        novalidate: true,
        autocomplete: 'off',
    }) }}
    class="space-y-6"
    data-testid="document-request-form"
>
    {# ───── Persons (sidebar master-detail) ─────────────────────────── #}
    <section data-testid="document-request-persons">
        <div class="mb-3 flex items-baseline justify-between gap-4">
            <h2 class="text-base font-semibold tracking-tight text-gray-900">
                {{ 'admin.tools.documents.request.persons.title'|trans }}
            </h2>
            <p class="text-xs text-gray-500">
                {{ 'admin.tools.documents.request.persons.count'|trans({'%count%': personCount, '%max%': maxPersons}) }}
            </p>
        </div>

        <div
            class="grid grid-cols-1 gap-3 lg:grid-cols-[220px_1fr]"
            data-controller="person-picker"
            data-person-picker-active-value="{{ activeIndex }}"
        >
            <aside class="rounded-2xl border border-gray-950/5 bg-white p-2">
                <nav class="flex flex-col gap-1" aria-label="{{ 'admin.tools.documents.request.persons.title'|trans }}">
                    {% for personForm in persons %}
                        {% set fn = personForm.firstName.vars.value %}
                        {% set ln = personForm.lastName.vars.value %}
                        {% set role = personForm.role.vars.value %}
                        <button
                            type="button"
                            data-action="click->person-picker#select"
                            data-person-picker-target="tab"
                            data-person-picker-index-param="{{ loop.index0 }}"
                            data-active="{{ loop.index0 == activeIndex ? 'true' : 'false' }}"
                            class="group flex w-full cursor-pointer items-start justify-between gap-2 rounded-lg px-3 py-2 text-left text-sm transition-colors hover:bg-neutral-100/60 data-[active=true]:bg-neutral-100 data-[active=true]:text-gray-900 data-[active=true]:ring-1 data-[active=true]:ring-gray-950/5"
                            data-testid="document-request-person-tab"
                        >
                            <span class="min-w-0">
                                <span class="block font-medium text-gray-900">
                                    {{ 'admin.tools.documents.request.person.heading'|trans({'%number%': loop.index}) }}
                                    {% if role %}
                                        <span class="ml-1 inline-flex items-center rounded-full bg-gray-100 px-1.5 py-0.5 text-[10px] font-medium uppercase tracking-wide text-gray-600 group-data-[active=true]:bg-white">
                                            {{ ('admin.tools.documents.request.person.role.' ~ role)|trans }}
                                        </span>
                                    {% endif %}
                                </span>
                                {% if fn or ln %}
                                    <span class="block truncate text-xs text-gray-500">{{ fn }} {{ ln }}</span>
                                {% else %}
                                    <span class="block text-xs italic text-gray-400">{{ 'admin.tools.documents.request.person.toComplete'|trans }}</span>
                                {% endif %}
                            </span>
                        </button>
                    {% endfor %}
                    {% if canAdd %}
                        <button
                            type="button"
                            class="flex w-full items-center justify-center gap-1.5 rounded-lg border border-dashed border-gray-950/10 px-2 py-2 text-xs font-medium whitespace-nowrap text-gray-600 transition-colors hover:border-primary/40 hover:bg-primary/5 hover:text-primary focus:outline-none focus-visible:outline focus-visible:outline-2 focus-visible:-outline-offset-2 focus-visible:outline-gray-300"
                            data-action="live#action"
                            data-live-action-param="addPerson"
                            data-testid="document-request-add-person"
                        >
                            <twig:ux:icon name="lucide:user-plus" class="size-3.5 shrink-0" aria-hidden="true" />
                            {{ 'admin.tools.documents.request.actions.addPerson'|trans }}
                        </button>
                    {% endif %}
                </nav>
            </aside>

            <div class="rounded-2xl border border-gray-950/5 bg-white p-5">
                {% for personForm in persons %}
                    <div data-person-picker-target="form" {% if not loop.first %}hidden{% endif %} data-testid="document-request-person">
                        <header class="mb-4 flex items-center justify-between gap-3">
                            <p class="text-sm font-semibold tracking-tight text-gray-900">
                                {{ 'admin.tools.documents.request.person.heading'|trans({'%number%': loop.index}) }}
                            </p>
                            {% if personCount > 1 %}
                                {{ ui.removeButton(loop.index0, 'admin.tools.documents.request.actions.removePerson'|trans) }}
                            {% endif %}
                        </header>
                        {{ ui.personFields(personForm, docsById, app.locale) }}
                    </div>
                {% endfor %}
            </div>
        </div>

        {% for error in persons.vars.errors %}
            <p class="mt-3 text-sm text-red-600" role="alert">{{ error.message }}</p>
        {% endfor %}
    </section>

    {# ───── Typology — visual cards with composition icons ──────────── #}
    {# Mapping enum value → icon composition. Tenants drawn as `user`,
       guarantors as `shield-check`, joined by a `+` separator. #}
    {% set typologyIcons = {
        two_tenants_two_guarantors: {tenants: 2, guarantors: 2},
        two_tenants_one_guarantor: {tenants: 2, guarantors: 1},
        one_tenant_two_guarantors: {tenants: 1, guarantors: 2},
        one_tenant_one_guarantor: {tenants: 1, guarantors: 1},
        two_tenants: {tenants: 2, guarantors: 0},
        one_tenant: {tenants: 1, guarantors: 0},
    } %}
    <section data-testid="document-request-typology">
        <div class="mb-3">
            <h2 class="text-base font-semibold tracking-tight text-gray-900">
                {{ 'admin.tools.documents.request.typology.title'|trans }}
            </h2>
            <p class="mt-0.5 text-sm text-gray-500">{{ 'admin.tools.documents.request.typology.subtitle'|trans }}</p>
        </div>

        <div class="grid grid-cols-2 gap-3 sm:grid-cols-3">
            {% for choice in form.typology.children %}
                {% set comp = typologyIcons[choice.vars.value] ?? {tenants: 1, guarantors: 0} %}
                <label for="{{ choice.vars.id }}" class="group flex cursor-pointer flex-col items-center gap-3 rounded-xl border border-gray-950/5 bg-white p-4 text-center transition-colors has-[input:checked]:border-primary/40 has-[input:checked]:bg-primary/5 hover:bg-neutral-50/60">
                    <input
                        type="radio"
                        id="{{ choice.vars.id }}"
                        name="{{ choice.vars.full_name }}"
                        value="{{ choice.vars.value }}"
                        {% if choice.vars.checked %}checked{% endif %}
                        class="sr-only"
                    />
                    <span class="flex items-center gap-1.5 text-gray-700 group-has-[input:checked]:text-primary">
                        {% for _ in 1..comp.tenants %}
                            <twig:ux:icon name="lucide:user" class="size-6 shrink-0" aria-hidden="true" />
                        {% endfor %}
                        {% if comp.guarantors > 0 %}
                            <span class="mx-1 text-gray-300">+</span>
                            {% for _ in 1..comp.guarantors %}
                                <twig:ux:icon name="lucide:shield-check" class="size-6 shrink-0" aria-hidden="true" />
                            {% endfor %}
                        {% endif %}
                    </span>
                    <span class="text-xs font-medium text-gray-900">{{ choice.vars.label|trans }}</span>
                </label>
            {% endfor %}
        </div>

        {% for error in form.typology.vars.errors %}
            <p class="mt-2 text-sm text-red-600" role="alert">{{ error.message }}</p>
        {% endfor %}
    </section>

    {# ───── Note (free text, optional) — sits before drive/language so
           the advisor can craft the message right after picking the
           household composition. ──────────────────────────────────────── #}
    <section data-testid="document-request-note">
        <twig:Label for="{{ form.note.vars.id }}" class="text-sm font-semibold text-gray-900">
            {{ 'admin.tools.documents.request.note.label'|trans }}
        </twig:Label>
        <p id="{{ form.note.vars.id }}-help" class="mt-0.5 text-xs text-gray-500">{{ 'admin.tools.documents.request.note.help'|trans }}</p>
        <div class="mt-2">
            <textarea
                id="{{ form.note.vars.id }}"
                name="{{ form.note.vars.full_name }}"
                rows="3"
                maxlength="2000"
                placeholder="{{ 'admin.tools.documents.request.note.placeholder'|trans }}"
                aria-invalid="{{ form.note.vars.errors|length > 0 ? 'true' : 'false' }}"
                aria-describedby="{{ form.note.vars.id }}-help"
                class="block min-h-20 w-full resize-y rounded-lg border border-gray-300 bg-white px-3 py-2.5 text-base text-gray-900 placeholder:text-gray-400 focus:ring-primary/60 focus:outline focus:-outline-offset-2 focus:outline-2 focus:outline-primary/80 disabled:cursor-not-allowed disabled:opacity-50 sm:text-sm/6"
            >{{ form.note.vars.value }}</textarea>
            {% for error in form.note.vars.errors %}
                <p class="mt-1.5 text-sm text-red-600" role="alert">{{ error.message }}</p>
            {% endfor %}
        </div>
    </section>

    {# ───── Drive link + Language paired in a 2-col grid ────────────── #}
    <section>
        <div class="grid grid-cols-1 gap-5 sm:grid-cols-[1fr_auto]">
            <div data-testid="document-request-drive">
                <twig:Label for="{{ form.driveLink.vars.id }}" class="text-sm font-semibold text-gray-900">
                    {{ 'admin.tools.documents.request.driveLink.label'|trans }}
                    <span class="text-red-600" aria-hidden="true">*</span>
                </twig:Label>
                <p class="mt-0.5 text-xs text-gray-500">{{ 'admin.tools.documents.request.driveLink.help'|trans }}</p>
                <div class="mt-2">
                    <twig:Input
                        type="url"
                        id="{{ form.driveLink.vars.id }}"
                        name="{{ form.driveLink.vars.full_name }}"
                        value="{{ form.driveLink.vars.value }}"
                        maxlength="512"
                        required="required"
                        placeholder="https://drive.google.com/..."
                        inputmode="url"
                        aria-invalid="{{ form.driveLink.vars.errors|length > 0 ? 'true' : 'false' }}"
                    />
                    {% for error in form.driveLink.vars.errors %}
                        <p class="mt-1.5 text-sm text-red-600" role="alert">{{ error.message }}</p>
                    {% endfor %}
                </div>
            </div>

            <div data-testid="document-request-language">
                <p class="text-sm font-semibold text-gray-900">
                    {{ 'admin.tools.documents.request.language.title'|trans }}
                </p>
                <p class="mt-0.5 text-xs text-gray-500">{{ 'admin.tools.documents.request.language.subtitle'|trans }}</p>
                <div class="mt-2 flex flex-wrap gap-2">
                    {% for choice in form.language.children %}
                        <label for="{{ choice.vars.id }}" class="flex cursor-pointer items-center gap-2 rounded-lg border border-gray-950/5 bg-white px-3 py-2 transition-colors has-[input:checked]:border-primary/40 has-[input:checked]:bg-primary/5 hover:bg-neutral-50/60">
                            <span class="group inline-grid size-4 shrink-0 grid-cols-1">
                                <input
                                    type="radio"
                                    id="{{ choice.vars.id }}"
                                    name="{{ choice.vars.full_name }}"
                                    value="{{ choice.vars.value }}"
                                    {% if choice.vars.checked %}checked{% endif %}
                                    class="col-start-1 row-start-1 appearance-none rounded-full border border-gray-300 bg-white checked:border-primary checked:bg-primary focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary forced-colors:appearance-auto"
                                />
                                <span class="pointer-events-none col-start-1 row-start-1 size-[round(down,40%,1px)] self-center justify-self-center rounded-full bg-white group-not-has-checked:opacity-0"></span>
                            </span>
                            <span class="text-sm font-medium text-gray-900">{{ choice.vars.label|trans }}</span>
                        </label>
                    {% endfor %}
                </div>
            </div>
        </div>
    </section>

    {# ───── Submit ──────────────────────────────────────────────────── #}
    <div class="flex flex-col-reverse items-stretch gap-3 border-t border-gray-950/5 pt-5 sm:flex-row sm:items-center sm:justify-end">
        <twig:Button variant="default" type="submit" data-testid="document-request-submit">
            <twig:ux:icon name="lucide:download" class="size-4 shrink-0" aria-hidden="true" />
            {{ 'admin.tools.documents.request.actions.generate'|trans }}
        </twig:Button>
    </div>
</form>
