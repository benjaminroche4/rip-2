<div {{ attributes }} data-testid="users-list">
    {% set users = this.items %}

    {% if users is empty %}
        <twig:Admin:EmptyCard message="{{ 'admin.users.empty'|trans }}" />
    {% else %}
        <div class="rounded-2xl border border-gray-950/5 bg-white p-2">
            <div class="overflow-hidden rounded-xl">
                <table class="w-full text-left text-sm" data-testid="users-table" aria-label="{{ 'admin.users.title'|trans }}">
                    <thead class="border-b border-gray-950/5 bg-neutral-50/50">
                        <tr class="text-xs font-semibold tracking-wide text-gray-500 uppercase">
                            <th scope="col" class="px-4 py-3 font-semibold">{{ 'admin.users.column.name'|trans }}</th>
                            <th scope="col" class="px-4 py-3 font-semibold">{{ 'admin.users.column.email'|trans }}</th>
                            <th scope="col" class="px-4 py-3 font-semibold">{{ 'admin.users.column.role'|trans }}</th>
                            <th scope="col" class="px-4 py-3 font-semibold">{{ 'admin.users.column.lastLogin'|trans }}</th>
                            <th scope="col" class="px-4 py-3 text-right font-semibold">{{ 'admin.users.column.createdAt'|trans }}</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-950/5">
                        {% for user in users %}
                            {% set isAdmin = user.primaryRole == 'admin' %}
                            {% set profileUrl = path('admin_user_show', {
                                adminPrefix: this.adminPrefix,
                                uniqueId: user.uniqueId,
                                slug: user.slug,
                            }) %}
                            <tr class="cursor-pointer transition-colors hover:bg-neutral-50/60 has-[a:focus-visible]:bg-neutral-50/60">
                                <td class="relative px-4 py-3">
                                    <div class="flex items-center gap-3">
                                        <twig:Avatar
                                            filename="{{ user.avatarFilename }}"
                                            name="{{ user.fullName }}"
                                            email="{{ user.email }}"
                                            size="8"
                                        />
                                        <a
                                            href="{{ profileUrl }}"
                                            class="font-medium text-gray-900 after:absolute after:inset-0 after:content-['']"
                                            data-testid="user-row-link"
                                        >
                                            {{ user.fullName ?: user.email }}
                                        </a>
                                    </div>
                                </td>
                                <td class="px-4 py-3 text-gray-600">{{ user.email }}</td>
                                <td class="px-4 py-3">
                                    <twig:Badge variant="{{ isAdmin ? 'primary' : 'secondary' }}" class="rounded-full">
                                        {{ ('admin.users.role.' ~ user.primaryRole)|trans }}
                                    </twig:Badge>
                                </td>
                                <td class="px-4 py-3 text-gray-500">
                                    {% if user.lastLoginAt %}
                                        <span title="{{ user.lastLoginAt|format_datetime('medium', 'short') }}">
                                            {{ user.lastLoginAt|ago|capitalize }}
                                        </span>
                                    {% else %}
                                        <span class="text-gray-400">{{ 'admin.users.lastLoginNever'|trans }}</span>
                                    {% endif %}
                                </td>
                                <td class="px-4 py-3 text-right tabular-nums text-gray-500">
                                    {{ user.createdAt|format_date('long') }}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

        {% if this.hasMore %}
            <div class="mt-6 flex justify-center">
                <twig:Button
                    variant="secondary"
                    data-action="live#action"
                    data-live-action-param="more"
                    data-testid="users-load-more"
                >
                    <span data-loading="action(more)|hide">{{ 'admin.users.button.loadMore'|trans }}</span>
                    <span data-loading="action(more)|show" class="hidden items-center gap-x-2">
                        <twig:Spinner class="inline" />
                        {{ 'admin.users.button.loading'|trans }}
                    </span>
                </twig:Button>
            </div>
        {% endif %}
    {% endif %}
</div>
