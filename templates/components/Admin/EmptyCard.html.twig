{# @prop message string Pre-translated message to display #}
{%- props message -%}
<div {{ attributes.defaults({class: 'rounded-2xl border border-gray-950/5 bg-white p-2'}) }}>
    <div class="rounded-xl bg-linear-to-b from-neutral-100/50 to-neutral-100/0 px-6 py-12 text-center">
        <p class="text-sm text-gray-500">{{ message }}</p>
    </div>
</div>
