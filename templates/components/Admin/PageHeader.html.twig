{# Admin:PageHeader — sticky page-top bar shared by every admin page. The
   title is required; the subtitle is an optional descriptive line shown
   under it; the default slot is the right-side actions area (back link,
   export buttons, etc.).

   Each admin page renders its own `<twig:Admin:PageHeader>` inside the
   `page_header` block (see `templates/admin/base.html.twig`), so the
   slot/prop boundary stays inside a single page's scope — no block
   inheritance crossing the component boundary. #}
{# @prop title string Rendered as the page `<h1>` — required. #}
{# @prop subtitle string|null Short descriptive line under the title; rendered only if non-empty. #}
{%- props title, subtitle = null -%}
<header class="flex flex-wrap items-start justify-between gap-x-6 gap-y-3 border-b border-gray-950/5 bg-white px-8 py-6">
    <div class="min-w-0">
        <h1 class="text-3xl font-semibold tracking-tight text-balance text-gray-900">{{ title }}</h1>
        {%- if subtitle and subtitle|trim is not empty %}
            <p class="mt-2 max-w-[60ch] text-sm text-pretty text-gray-500">{{ subtitle }}</p>
        {% endif -%}
    </div>
    {% block content %}{% endblock %}
</header>
