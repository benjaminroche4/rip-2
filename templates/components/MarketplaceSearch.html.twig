<div {{ attributes }}>
    <section class="max-w-4xl mx-auto lg:px-8 px-6 lg:py-16 py-12">
        <div class="border border-slate-200 rounded-2xl px-3 py-2 shadow-lg shadow-gray-500/10 bg-white flex items-center justify-between w-full">
            <div class="grid grid-cols-3 divide-slate-200 divide-x flex-1">
                <div class="px-3 py-2 flex items-center gap-x-2">
                    {{ ux_icon('iconoir:elevator', {'class': 'size-5 text-gray-400 shrink-0'}) }}
                    <input
                        type="text"
                        data-model="debounce(300)|location"
                        placeholder="Localisation"
                        class="font-light text-gray-400 outline-none w-full bg-transparent"
                        value="{{ location }}"
                    />
                </div>
                <div class="px-3 py-2 flex items-center gap-x-2">
                    {{ ux_icon('iconoir:home-simple', {'class': 'size-5 text-gray-400 shrink-0'}) }}
                    <select
                        data-model="on(change)|propertyType"
                        class="font-light text-gray-400 outline-none w-full bg-transparent appearance-none cursor-pointer"
                    >
                        <option value="">{{ locale == 'fr' ? 'Type de bien' : 'Property type' }}</option>
                        {% for slug, name in this.propertyTypes %}
                            <option value="{{ slug }}" {{ propertyType == slug ? 'selected' : '' }}>{{ name }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="px-3 py-2 flex items-center gap-x-2">
                    {{ ux_icon('iconoir:elevator', {'class': 'size-5 text-gray-400 shrink-0'}) }}
                    <p class="font-light text-gray-400">Localisation</p>
                </div>
            </div>
            <twig:Button variant="default" size="lg">
                Rechercher
            </twig:Button>
        </div>
    </section>
    <section class="max-w-7xl mx-auto lg:px-8 px-6 lg:pb-16 pb-12">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-x-8" data-controller="map-markers">
            <div>
                <h3 class="text-base font-medium mb-8 font-secondary">
                    {{ this.totalCount }} offres en location à Paris
                </h3>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-6" data-loading="addClass(opacity-50)">
                        {% for property in this.items %}
                            <article class="flex flex-col border border-slate-200 rounded-2xl bg-white p-1.5"
                                    data-property-id="{{ property._id }}"
                                    data-action="mouseenter->map-markers#highlightMarker mouseleave->map-markers#unhighlightMarker">
                                <div class="relative aspect-3/2 border border-slate-100 rounded-xl bg-slate-50 overflow-hidden group" data-controller="carousel">
                                    {% set allPhotos = [] %}
                                    {% if property.mainPhoto.url is defined and property.mainPhoto.url %}
                                        {% set allPhotos = allPhotos|merge([property.mainPhoto]) %}
                                    {% endif %}
                                    {% for photo in property.photos %}
                                        {% if photo.url != property.mainPhoto.url|default('') %}
                                            {% set allPhotos = allPhotos|merge([photo]) %}
                                        {% endif %}
                                    {% endfor %}
                                    <div class="flex h-full transition-transform duration-300 ease-out cursor-grab active:cursor-grabbing" data-carousel-target="track">
                                        {% for photo in allPhotos[:5] %}
                                            <div class="w-full h-full shrink-0">
                                                <img
                                                    src="{{ photo.url }}?w=600&h=400&fit=crop&auto=format&q=80"
                                                    alt="{{ photo.alt|default(property.title|default('Bien immobilier')) }}"
                                                    {{ loop.first ? '' : 'loading="lazy"' }}
                                                    width="600"
                                                    height="400"
                                                    class="w-full h-full object-cover pointer-events-none select-none"
                                                    draggable="false"
                                                />
                                            </div>
                                        {% endfor %}
                                    </div>
                                    {% if allPhotos|length > 1 %}
                                        <div class="absolute bottom-2 left-1/2 -translate-x-1/2 flex gap-1.5 bg-gray-900/40 group-hover:bg-gray-900/70 transition duration-100 rounded-full px-1.5 py-1" data-carousel-target="dots">
                                            {% for photo in allPhotos[:5] %}
                                                <button
                                                    type="button"
                                                    class="size-1.5 rounded-full transition-colors duration-200 {{ loop.first ? 'bg-white' : 'bg-white/50' }}"
                                                    data-carousel-target="dot"
                                                    data-action="carousel#goTo"
                                                    data-index="{{ loop.index0 }}"
                                                ></button>
                                            {% endfor %}
                                        </div>
                                    {% endif %}
                                </div>

                                <div class="px-2 py-3 flex flex-col flex-1 space-y-4">
                                    <div class="flex justify-between items-center gap-x-2">
                                        {% if property.status == 'underOffer' %}
                                            {% set badgeClass = 'bg-amber-50 border-amber-100 text-amber-600' %}
                                            {% set badgeText %}<p class="font-semibold">{{ locale == 'fr' ? 'Offre en cours' : 'Under offer' }}</p>{% endset %}
                                        {% elseif property.status == 'rented' %}
                                            {% set badgeClass = 'bg-red-50 border-red-100 text-red-600' %}
                                            {% set badgeText %}<p class="font-semibold">{{ locale == 'fr' ? 'Non disponible' : 'Rented' }}</p>{% endset %}
                                        {% elseif property.availableDate is defined and property.availableDate %}
                                            {% set badgeClass = 'bg-green-50 border-green-100 text-green-600' %}
                                            {% set badgeText %}
                                                {% if property.availableDate|date('Y-m-d') <= 'now'|date('Y-m-d') %}
                                                    <p class="font-semibold">{{ locale == 'fr' ? 'Disponible immédiatement' : 'Available now' }}</p>
                                                {% else %}
                                                    <p>{{ locale == 'fr' ? 'À partir du' : 'From' }} <span class="font-semibold">{{ property.availableDate|date('d/m/Y') }}</span></p>
                                                {% endif %}
                                            {% endset %}
                                        {% else %}
                                            {% set badgeClass = null %}
                                        {% endif %}

                                        {% if badgeClass %}
                                            <div>
                                                <twig:Badge variant="primary" class="rounded-md border font-light gap-x-2 px-1 {{ badgeClass }}">
                                                    {% if property.agentPhoto is defined and property.agentPhoto %}
                                                        <img
                                                            src="{{ property.agentPhoto }}?w=48&h=48&fit=crop&auto=format&q=80"
                                                            alt=""
                                                            loading="lazy"
                                                            width="24"
                                                            height="24"
                                                            class="size-6 rounded-full outline outline-1 -outline-offset-1 outline-black/5"
                                                        />
                                                    {% endif %}
                                                    {{ badgeText|raw }}
                                                </twig:Badge>
                                            </div>
                                        {% endif %}
                                        <div class="bg-primary/10 rounded-full p-1.5">
                                            {{ ux_icon('material-symbols:verified-rounded', {'class': 'size-4 shrink-0 text-primary'}) }}
                                        </div>
                                    </div>
                                    <div class="space-y-1">
                                        <div>
                                            {% if property.monthlyRent %}
                                                <p class="text-primary text-2xl font-semibold">{{ property.monthlyRent|number_format(0, ',', ' ') }}€<span class="text-gray-600 text-sm font-light ml-1">/mois CC</span></p>
                                            {% else %}
                                                <p class="text-primary text-xl font-semibold">Prix sur demande</p>
                                            {% endif %}
                                        </div>
                                        <h3 class="font-semibold text-lg">Appartement 4 pièces</h3>
                                        <div>
                                            <address class="not-italic text-gray-500 text-sm flex items-center gap-x-1">
                                                {{ ux_icon('gg:pin', {'class': 'size-4 shrink-0'}) }}
                                                {{ property.address.city}},  {{ property.address.postalCode }} arrondissement
                                            </address>
                                        </div>
                                    </div>
                                    <div class="bg-neutral-50 rounded-lg px-2 py-3 grid grid-cols-3 divide-x divide-gray-200">
                                        <div class="flex items-center justify-center gap-x-1">
                                            {% if property.elevator %}
                                                {{ ux_icon('iconoir:elevator', {'class': 'size-5 text-gray-800 shrink-0'}) }}
                                                <p class="text-sm font-light">Yes</p>
                                            {% else %}
                                                {{ ux_icon('solar:box-linear', {'class': 'size-5 text-gray-800 shrink-0'}) }}
                                                <p class="text-sm font-light">{{ property.furnished == 'yes' ? (locale == 'fr' ? 'Oui' : 'Yes') : (locale == 'fr' ? 'Non' : 'No') }}</p>
                                            {% endif %}
                                        </div>
                                        <div class="flex items-center justify-center gap-x-1">
                                            {{ ux_icon('fluent:bed-24-regular', {'class': 'size-5 text-gray-800 shrink-0'}) }}
                                            <p class="text-sm font-light">{{ property.bedroomsLabel }}</p>
                                        </div>
                                        <div class="flex items-center justify-center gap-x-1">
                                            {{ ux_icon('wordpress:square', {'class': 'size-5 text-gray-800 shrink-0'}) }}
                                            <p class="text-sm font-light">{{ property.squareMeters }} m²</p>
                                        </div>
                                    </div>
                                </div>
                            </article>
                        {% endfor %}
                </div>

                {% if this.hasMore %}
                    <div class="flex justify-center mt-8">
                        <button
                            class="px-6 py-3 border border-slate-200 rounded-xl text-sm font-medium hover:bg-slate-50 transition-colors"
                            data-action="live#action"
                            data-live-action-param="more"
                        >
                            <span data-loading="action(more)|hide">Voir plus de biens</span>
                            <span data-loading="action(more)|show" class="hidden">Chargement...</span>
                        </button>
                    </div>
                {% endif %}
            </div>
            <aside class="rounded-3xl p-2 border border-neutral-200 transition-opacity duration-200" data-loading="action(updateBounds)|addClass(opacity-50)">
                {{ ux_map(map, {style: 'height: 100%;', 'class': 'rounded-2xl', 'data-controller': 'map-cluster map-restriction'}) }}
            </aside>
        </div>
    </section>
</div>
