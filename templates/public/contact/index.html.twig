{% extends 'public/base.html.twig' %}

{% block title %}{{ 'meta.contact.title'|trans }}{% endblock %}
{% block description %}{{ 'meta.contact.description'|trans }}{% endblock %}
{% block url %}{{ path('app_contact') }}{% endblock %}

{% block schema_page %}
{
    "@type": "ContactPage",
    "name": "{{ 'meta.contact.title'|trans|e('js') }}",
    "description": "{{ 'meta.contact.description'|trans|e('js') }}",
    "url": "{{ url('app_contact') }}",
    "mainEntity": {
        "@type": "LocalBusiness",
        "name": "Relocation In Paris",
        "url": "{{ url('app_home') }}",
        "telephone": "+33184804344",
        "email": "contact@relocation-in-paris.fr",
        "address": {
            "@type": "PostalAddress",
            "streetAddress": "155 Rue du Faubourg Saint-Denis",
            "addressLocality": "Paris",
            "postalCode": "75010",
            "addressCountry": "FR"
        },
        "openingHoursSpecification": {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
            "opens": "08:00",
            "closes": "20:00"
        }
    }
}
{% endblock %}

{% block body %}
    <img src="{{ asset('intl-tel-input/img/flags@2x.webp') }}" alt="" aria-hidden="true" decoding="async" fetchpriority="low" width="1" height="1" style="position:absolute;left:0;top:0;width:1px;height:1px;opacity:0;pointer-events:none;">
    <section aria-labelledby="contact-heading">
        <div class="max-w-7xl mx-auto lg:px-8 px-6 lg:py-16 py-12">
            <div class="max-w-2xl mx-auto flex flex-col justify-center items-center text-center space-y-4">
                <p class="text-center font-semibold text-primary font-secondary">{{ 'contact.title'|trans|raw }}</p>
                <h1 id="contact-heading" class="text-4xl lg:text-5xl/16 font-medium text-balance text-center">{{ 'contact.subTitle'|trans|raw }}</h1>
                <p class="text-slate-600 font-light text-pretty max-w-lg">{{ 'contact.text'|trans|raw }}</p>
            </div>
        </div>
    </section>

    <section class="max-w-6xl mx-auto lg:px-8 px-6 lg:pb-16 pb-12 mt-5">
        <div class="grid grid-cols-1 gap-12 lg:gap-24 lg:grid-cols-5">

            <aside class="col-span-2 space-y-7 lg:space-y-12 lg:order-1 order-2" aria-label="{{ 'contact.contactType.title'|trans }}">
                <div class="space-y-2">
                    <h2 class="text-3xl font-semibold text-primary">{{ 'contact.contactType.title'|trans|raw }}</h2>
                    <p class="text-slate-600 text-pretty">{{ 'contact.contactType.text'|trans|raw }}</p>
                </div>

                <ul class="lg:space-y-7 space-y-6 list-none">
                    <li class="flex flex-row items-start lg:gap-x-4 gap-x-3">
                        <div class="rounded-full p-2.5 bg-primary" aria-hidden="true">
                            {{ ux_icon('si:pin-line', {'class': 'size-5 shrink-0 text-white'}) }}
                        </div>
                        <div class="space-y-4">
                            <div class="space-y-2">
                                <twig:Badge variant="destructive">
                                    {{ 'contact.contactType.1.headOffice'|trans|raw }}
                                </twig:Badge>
                                <address class="not-italic space-y-0.5">
                                    <p class="font-semibold text-lg">155 Rue du Faubourg Saint-Denis</p>
                                    <p class="text-slate-600 font-light">75010 Paris, France</p>
                                </address>
                            </div>
                            <a href="https://share.google/DuM7reAcGSrmXQ65I" target="_blank" rel="noopener noreferrer"
                               class="text-primary hover:text-primary/80 transition duration-100 underline underline-offset-4 text-sm">
                                {{ 'contact.contactType.1.viewOn'|trans|raw }}
                            </a>
                        </div>
                    </li>

                    <li aria-hidden="true" class="h-[1px] bg-gradient-to-r from-slate-400/20 via-slate-500 to-slate-400/20 opacity-20"></li>

                    <li class="flex flex-row items-start lg:gap-x-4 gap-x-3">
                        <div class="rounded-full p-2.5 bg-primary" aria-hidden="true">
                            {{ ux_icon('iconoir:phone', {'class': 'size-5 shrink-0 text-white'}) }}
                        </div>
                        <div class="space-y-4">
                            <div class="space-y-2">
                                <a href="tel:+33184804344" class="font-semibold text-lg">+(33) 1 84 80 43 44</a>
                                <p class="text-slate-600 font-light">{{ 'contact.contactType.2.openHours'|trans|raw }}</p>
                            </div>
                            <p class="text-sm text-slate-600 font-light flex items-center gap-x-2">
                                {{ 'contact.contactType.2.whatsapp'|trans|raw }}
                                <a href="https://wa.me/33761719439" target="_blank" rel="noopener noreferrer"
                                   class="text-green-500 hover:text-green-400 transition duration-100 underline underline-offset-4 flex items-center gap-x-1">
                                    {{ ux_icon('simple-icons:whatsapp', {'class': 'size-3.5 shrink-0', 'aria-hidden': 'true'}) }}
                                    WhatsApp
                                </a>
                            </p>
                        </div>
                    </li>

                    <li aria-hidden="true" class="h-[1px] bg-gradient-to-r from-slate-400/20 via-slate-500 to-slate-400/20 opacity-20"></li>

                    <li class="flex flex-row items-start lg:gap-x-4 gap-x-3">
                        <div class="rounded-full p-2.5 bg-primary" aria-hidden="true">
                            {{ ux_icon('proicons:mail', {'class': 'size-5 shrink-0 text-white'}) }}
                        </div>
                        <div class="space-y-4">
                            <div class="space-y-1">
                                <a href="mailto:contact@relocation-in-paris.fr" class="font-semibold text-lg">contact@relocation-in-paris.fr</a>
                                <p class="text-slate-600 font-light">{{ 'contact.contactType.3.time'|trans|raw }}</p>
                            </div>
                        </div>
                    </li>
                </ul>
            </aside>

            <div class="col-span-3 lg:order-2 order-1" aria-labelledby="form-heading">
                <div class="rounded-2xl p-2 border border-neutral-200 shadow-lg">
                    <div class="p-3 lg:p-8 rounded-xl bg-linear-to-b from-neutral-100 to-neutral-100/0" id="contact-form" data-turbo="true">
                        <twig:Contact:ContactForm :form="contactForm" />
                    </div>
                </div>
            </div>

        </div>
    </section>
{% endblock %}
