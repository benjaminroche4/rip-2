{% extends 'base.html.twig' %}

{% block title %}{{ 'meta.pricing.title'|trans }}{% endblock %}
{% block description %}{{ 'meta.pricing.description'|trans }}{% endblock %}
{% block url %}{{ path('app_pricing') }}{% endblock %}

{% block body %}
    <section>
        <div class="max-w-7xl mx-auto lg:px-8 px-6 lg:py-16 py-12">
            <div class="max-w-2xl mx-auto flex flex-col justify-center items-center text-center space-y-4">
                <p class="text-center font-semibold text-primary font-secondary">{{ 'pricing.title'|trans|raw }}</p>
                <h1 id="contact-heading" class="text-4xl lg:text-5xl/16 font-medium text-balance text-center">{{ 'pricing.subTitle'|trans|raw }}</h1>
                <p class="text-slate-600 font-light text-pretty max-w-lg">{{ 'pricing.text'|trans|raw }}</p>
            </div>
        </div>
    </section>
    <section class="mx-auto lg:px-8 px-6 lg:pb-16 pb-12">
        <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
            <div class="rounded-2xl p-2 border border-slate-100 group order-2 md:order-1 max-w-lg mx-auto">
                <div class="mb-1.5 mt-0.5 text-center">
                    <p class="text-sm">{{ 'pricing.package.1.eyebrow'|trans|raw }}</p>
                </div>
                <div class="rounded-xl bg-linear-to-b from-neutral-100 to-neutral-100/0">
                    <div class="p-4 lg:p-6">
                        <div class="rounded-full p-3 bg-white inline-block">
                            {{ ux_icon('material-symbols:star-rounded', {'class':'size-7 text-gray-900 group-hover:text-primary transition duration-100'}) }}
                        </div>
                        <div class="pt-2 space-y-2">
                            <h3 class="text-2xl font-semibold">{{ 'pricing.package.1.title'|trans|raw }}</h3>
                            <p class="text-pretty font-light text-slate-600">{{ 'pricing.package.1.text'|trans|raw }}</p>
                            <p class="text-3xl font-semibold text-primary font-primary mt-6"><span class="mr-1">1</span>190€</p>
                        </div>
                    </div>
                    <div class="h-[1px] bg-gradient-to-r from-slate-400/20 via-slate-500 to-slate-400/20 opacity-20"></div>
                    <div class="p-4 lg:p-6">
                        <div class="space-y-3.5">
                            <div class="flex -space-x-1.5">
                                <img src="{{ asset('medias/team/team_1.webp') }}" alt="{{ 'ctaFooter.image.1.alt'|trans|raw }}" loading="eager" width="28" height="28" class="inline-block size-7 rounded-full outline outline-1 -outline-offset-1 outline-gray-700/10 ring-2 ring-white" />
                                <img src="{{ asset('medias/team/team_5.webp') }}" alt="{{ 'ctaFooter.image.2.alt'|trans|raw }}" loading="eager" width="28" height="28" class="inline-block size-7 rounded-full outline outline-1 -outline-offset-1 outline-gray-700/10 ring-2 ring-white" />
                                <img src="{{ asset('medias/team/team_3.webp') }}" alt="{{ 'ctaFooter.image.3.alt'|trans|raw }}" loading="eager" width="28" height="28" class="inline-block size-7 rounded-full outline outline-1 -outline-offset-1 outline-gray-700/10 ring-2 ring-white" />
                            </div>
                            <p class="text-base font-semibold text-pretty">{{ 'pricing.package.1.listing.include'|trans|raw }}</p>
                            <div class="space-y-3.5">
                                <div class="flex items-center space-x-2">
                                    <div class="bg-gray-100 rounded-full p-0.5">
                                        {{ ux_icon('material-symbols:check-small-rounded', {'class':'size-5 text-primary'}) }}
                                    </div>
                                    <p class="text-slate-800 font-light">{{ 'pricing.package.1.listing.1'|trans|raw }}</p>
                                </div>
                                <div class="flex items-center space-x-2">
                                    <div class="bg-gray-100 rounded-full p-0.5">
                                        {{ ux_icon('material-symbols:check-small-rounded', {'class':'size-5 text-primary'}) }}
                                    </div>
                                    <p class="text-slate-800 font-light">{{ 'pricing.package.1.listing.2'|trans|raw }}</p>
                                </div>
                                <div class="flex items-center space-x-2">
                                    <div class="bg-gray-100 rounded-full p-0.5">
                                        {{ ux_icon('material-symbols:check-small-rounded', {'class':'size-5 text-primary'}) }}
                                    </div>
                                    <p class="text-slate-800 font-light">{{ 'pricing.package.1.listing.3'|trans|raw }}</p>
                                </div>
                                <div class="flex items-center space-x-2">
                                    <div class="bg-gray-100 rounded-full p-0.5">
                                        {{ ux_icon('material-symbols:check-small-rounded', {'class':'size-5 text-primary'}) }}
                                    </div>
                                    <p class="text-slate-800 font-light">{{ 'pricing.package.1.listing.4'|trans|raw }}</p>
                                </div>
                                <div class="flex items-center space-x-2">
                                    <div class="bg-gray-100 rounded-full p-0.5">
                                        {{ ux_icon('material-symbols:check-small-rounded', {'class':'size-5 text-primary'}) }}
                                    </div>
                                    <p class="text-slate-800 font-light">{{ 'pricing.package.1.listing.5'|trans|raw }}</p>
                                </div>
                                <div class="flex items-center space-x-2">
                                    <div class="bg-gray-100 rounded-full p-0.5">
                                        {{ ux_icon('material-symbols:check-small-rounded', {'class':'size-5 text-primary'}) }}
                                    </div>
                                    <p class="text-slate-800 font-light">{{ 'pricing.package.1.listing.6'|trans|raw }}</p>
                                </div>
                            </div>
                            <div class="mt-6">
                                <twig:Button variant="outline" as="a" size="lg" class="w-full" href="{{ path('app_contact') }}">
                                    {{ 'pricing.package.1.button'|trans|raw }}
                                </twig:Button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="rounded-2xl p-2 border border-[#EB9CB0] group bg-linear-to-b from-[#FFE5EB] to-[#FFE5EB]/0 order-1 md:order-2 max-w-lg mx-auto">
                <div class="mb-1.5 mt-0.5 text-center text-primary">
                    <p class="text-sm flex items-center gap-x-2 justify-center">
                        {{ ux_icon('akar-icons:thunder', {'class':'size-3 text-primary'}) }}
                        {{ 'pricing.package.2.eyebrow'|trans|raw }}
                    </p>
                </div>
                <div class="rounded-xl bg-linear-to-b bg-white">
                    <div class="p-4 lg:p-6">
                        <div class="rounded-full p-3 bg-[#FFF4F6]  inline-block">
                            {{ ux_icon('tabler:crown-filled', {'class':'size-7 text-primary'}) }}
                        </div>
                        <div class="pt-2 space-y-2">
                            <h3 class="text-2xl font-semibold">{{ 'pricing.package.2.title'|trans|raw }}</h3>
                            <p class="text-pretty font-light text-slate-600">{{ 'pricing.package.2.text'|trans|raw }}</p>
                            <p class="text-3xl font-semibold text-primary font-primary mt-6"><span class="mr-1">2</span>190€</p>
                        </div>
                    </div>
                    <div class="h-[1px] bg-gradient-to-r from-slate-400/20 via-slate-500 to-slate-400/20 opacity-20"></div>
                    <div class="p-4 lg:p-6">
                        <div class="space-y-3.5">
                            <div class="flex -space-x-1.5">
                                <img src="{{ asset('medias/team/team_1.webp') }}" alt="{{ 'ctaFooter.image.1.alt'|trans|raw }}" loading="eager" width="28" height="28" class="inline-block size-7 rounded-full outline outline-1 -outline-offset-1 outline-gray-700/10 ring-2 ring-white" />
                                <img src="{{ asset('medias/team/team_5.webp') }}" alt="{{ 'ctaFooter.image.2.alt'|trans|raw }}" loading="eager" width="28" height="28" class="inline-block size-7 rounded-full outline outline-1 -outline-offset-1 outline-gray-700/10 ring-2 ring-white" />
                                <img src="{{ asset('medias/team/team_3.webp') }}" alt="{{ 'ctaFooter.image.3.alt'|trans|raw }}" loading="eager" width="28" height="28" class="inline-block size-7 rounded-full outline outline-1 -outline-offset-1 outline-gray-700/10 ring-2 ring-white" />
                            </div>
                            <p class="text-base font-semibold text-pretty">{{ 'pricing.package.2.listing.include'|trans|raw }}</p>
                            <div class="space-y-3.5">
                                <div class="flex items-center space-x-2">
                                    <div class="bg-[#FFF4F6] rounded-full p-0.5">
                                        {{ ux_icon('material-symbols:check-small-rounded', {'class':'size-5 text-primary'}) }}
                                    </div>
                                    <p class="text-slate-800 font-light">{{ 'pricing.package.2.listing.1'|trans|raw }}</p>
                                </div>
                                <div class="flex items-center space-x-2">
                                    <div class="bg-[#FFF4F6] rounded-full p-0.5">
                                        {{ ux_icon('material-symbols:check-small-rounded', {'class':'size-5 text-primary'}) }}
                                    </div>
                                    <p class="text-slate-800 font-light">{{ 'pricing.package.2.listing.2'|trans|raw }}</p>
                                </div>
                                <div class="flex items-center space-x-2">
                                    <div class="bg-[#FFF4F6] rounded-full p-0.5">
                                        {{ ux_icon('material-symbols:check-small-rounded', {'class':'size-5 text-primary'}) }}
                                    </div>
                                    <p class="text-slate-800 font-light">{{ 'pricing.package.2.listing.3'|trans|raw }}</p>
                                </div>
                                <div class="flex items-center space-x-2">
                                    <div class="bg-[#FFF4F6] rounded-full p-0.5">
                                        {{ ux_icon('material-symbols:check-small-rounded', {'class':'size-5 text-primary'}) }}
                                    </div>
                                    <p class="text-slate-800 font-light">{{ 'pricing.package.2.listing.4'|trans|raw }}</p>
                                </div>
                                <div class="flex items-center space-x-2">
                                    <div class="bg-[#FFF4F6] rounded-full p-0.5">
                                        {{ ux_icon('material-symbols:check-small-rounded', {'class':'size-5 text-primary'}) }}
                                    </div>
                                    <p class="text-slate-800 font-light">{{ 'pricing.package.2.listing.5'|trans|raw }}</p>
                                </div>
                                <div class="flex items-center space-x-2">
                                    <div class="bg-[#FFF4F6] rounded-full p-0.5">
                                        {{ ux_icon('material-symbols:check-small-rounded', {'class':'size-5 text-primary'}) }}
                                    </div>
                                    <p class="text-slate-800 font-light">{{ 'pricing.package.2.listing.6'|trans|raw }}</p>
                                </div>
                            </div>
                            <div class="mt-6">
                                <twig:Button variant="default" as="a" size="lg" class="w-full" href="{{ path('app_contact') }}">
                                    {{ 'pricing.package.2.button'|trans|raw }}
                                </twig:Button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="max-w-5xl mx-auto mt-8">
            <div class="relative overflow-hidden bg-primary rounded-2xl lg:p-10 py-8 px-6">
                <div class="space-y-2">
                    <h3 class="font-semibold text-white text-2xl text-pretty">{{ 'pricing.package.other.title'|trans|raw }}</h3>
                    <p class="text-slate-300 font-light text-pretty max-w-lg">{{ 'pricing.package.other.text'|trans|raw }}</p>
                    <div class="mt-6 inline-block">
                        <twig:Button variant="secondary" as="a" size="lg" class="w-full" href="{{ path('app_contact') }}">
                            <img
                                src="{{ asset('medias/team/team_1.webp') }}"
                                alt="{{ 'header.menu.findTenant.imgAlt'|trans|raw }}"
                                loading="lazy"
                                width="24"
                                height="24"
                                class="size-6 rounded-full outline outline-1 -outline-offset-1 outline-black/5"
                            />
                            {{ 'pricing.package.other.button'|trans|raw }}
                        </twig:Button>
                    </div>
                </div>
