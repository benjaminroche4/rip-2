{% extends 'base.html.twig' %}

{% block title %}{{ 'meta.findAccommodation.title'|trans }}{% endblock %}
{% block description %}{{ 'meta.findAccommodation.description'|trans }}{% endblock %}
{% block url %}{{ path('app_service_find_accommodation') }}{% endblock %}

{% block schema_page %}
    {% include '_partials/schema/service.html.twig' with {
        routeName: 'app_service_find_accommodation',
        metaPrefix: 'findAccommodation',
        image: 'medias/website/relocation-in-paris-9.webp',
    } only %}
{% endblock %}

{% block body %}
    <section class="max-w-7xl mx-auto lg:px-8 px-6 lg:py-16 py-8">
        <div class="max-w-2xl mx-auto flex flex-col justify-center text-center space-y-4">
            <h1 class="text-center font-semibold text-primary font-secondary">{{ 'findAccommodation.title'|trans|raw }}</h1>
            <h2 class="text-4xl lg:text-5xl/16 font-medium text-balance">{{ 'findAccommodation.subTitle'|trans|raw }}</h2>
            <p class="mx-auto max-w-lg text-center font-normal text-neutral-600 text-pretty justify-center text-pretty">
                {{ 'findAccommodation.text'|trans|raw }}
            </p>
            <div class="border border-neutral-100 rounded-full px-4 py-1.5 flex items-center justify-center gap-x-2
            text-sm text-slate-600  mx-auto bg-white shadow-lg shadow-gray-300/30">
                <div class="flex justify-center items-center -space-x-1">
                    <span class="max-[382px]:hidden">{{ ux_icon('material-symbols:star-rounded', {'class':'size-5 text-yellow-500 shrink-0'}) }}</span>
                    <span class="max-[382px]:hidden">{{ ux_icon('material-symbols:star-rounded', {'class':'size-5 text-yellow-500 shrink-0'}) }}</span>
                    <span class="max-[382px]:hidden">{{ ux_icon('material-symbols:star-rounded', {'class':'size-5 text-yellow-500 shrink-0'}) }}</span>
                    <span class="max-[382px]:hidden">{{ ux_icon('material-symbols:star-rounded', {'class':'size-5 text-yellow-500 shrink-0'}) }}</span>
                    <span>{{ ux_icon('material-symbols:star-rounded', {'class':'size-5 text-yellow-500 shrink-0'}) }}</span>
                </div>
                <p>{{ 'findAccommodation.trust.1'|trans|raw }} <a href="https://share.google/oE0GyLX8xNnTNdX84" target="_blank" class="underline underline-offset-4 decoration-slate-400/80 hover:decoration-primary decoration-dotted hover:text-primary transition duration-100">+300 {{ 'findAccommodation.trust.2'|trans|raw }} </a></p>
                <span>{{ ux_icon('material-icon-theme:google', {'class':'size-4 text-yellow-500 shrink-0'}) }}</span>
            </div>
        </div>
        <div class="max-w-5xl mx-auto mt-12">
            <img width="546" height="350" loading="eager" src="{{ asset('medias/website/relocation-in-paris-9.webp') }}" alt="Relocation In Paris, trouver un logement à Paris" class="w-full aspect-3/2 lg:h-[400px] object-cover rounded-2xl" />
        </div>
    </section>
    <section class="max-w-7xl mx-auto lg:px-8 px-6 lg:py-16 py-12 bg-white">
        <div class="max-w-4xl mx-auto">
            <div
                data-controller="vertical-timeline"
                data-vertical-timeline-threshold-value="0.5"
                class="relative"
            >
                {# Vertical Progress Rail #}
                <div class="absolute left-4 lg:left-8 top-0 bottom-0 w-0.5 bg-gray-200" data-vertical-timeline-target="rail">
                    <div
                        data-vertical-timeline-target="progressBar"
                        class="absolute top-0 left-0 w-full bg-gradient-to-b from-primary via-primary/90 to-primary/80 transition-all duration-500 ease-out"
                        style="height: 0%;"
                    ></div>
                </div>

                {# Timeline Steps #}
                <div class="relative space-y-12 lg:space-y-16">
                    {# Step 1 #}
                    <div
                        data-vertical-timeline-target="step"
                        class="relative pl-12 lg:pl-20 transition-all duration-400"
                    >
                        <div class="absolute left-1.5 lg:left-5.5 top-0 flex items-center justify-center w-5 h-5 rounded-full bg-white border-2 border-gray-300 transition-all duration-300"
                             data-vertical-timeline-target="dot">
                            <div class="w-1.5 h-1.5 rounded-full bg-gray-300 transition-all duration-300" data-vertical-timeline-target="dotInner"></div>
                        </div>
                        <div class="transition-opacity duration-300" style="opacity: 0.4;">
                            <div class="flex flex-col sm:flex-row items-baseline gap-3 mb-2">
                                <div class="text-sm font-mono font-semibold text-primary/40 transition-all duration-300 bg-gray-50 p-2 rounded-xl" data-vertical-timeline-target="stepNumber">01</div>
                                <h3 class="text-xl lg:text-2xl font-semibold text-gray-900 transition-colors duration-300">{{ 'findAccommodation.timeline.steps.1.title'|trans|raw }}</h3>
                            </div>
                            <p class="text-base text-gray-600 leading-relaxed">{{ 'findAccommodation.timeline.steps.1.description'|trans|raw }}</p>
                        </div>
                    </div>

                    {# Step 2 #}
                    <div
                        data-vertical-timeline-target="step"
                        class="relative pl-12 lg:pl-20 transition-all duration-400"
                    >
                        <div class="absolute left-1.5 lg:left-5.5 top-2 flex items-center justify-center w-5 h-5 rounded-full bg-white border-2 border-gray-300 transition-all duration-300"
                             data-vertical-timeline-target="dot">
                            <div class="w-1.5 h-1.5 rounded-full bg-gray-300 transition-all duration-300" data-vertical-timeline-target="dotInner"></div>
                        </div>
                        <div class="transition-opacity duration-300" style="opacity: 0.4;">
                            <div class="flex flex-col sm:flex-row items-baseline gap-3 mb-2">
                                <div class="text-sm font-mono font-semibold text-primary/40 transition-all duration-300 bg-gray-50 p-2 rounded-xl" data-vertical-timeline-target="stepNumber">02</div>
                                <h3 class="text-xl lg:text-2xl font-semibold text-gray-900 transition-colors duration-300">{{ 'findAccommodation.timeline.steps.2.title'|trans|raw }}</h3>
                            </div>
                            <p class="text-base text-gray-600 leading-relaxed">{{ 'findAccommodation.timeline.steps.2.description'|trans|raw }}</p>
                            <div class="max-w-lg mt-8">
                                <div class="grid max-[331px]:grid-cols-1 min-[331px]:grid-cols-2 md:grid-cols-3 gap-4">
                                    <div class="bg-white border border-slate-100 rounded-xl p-4 flex flex-col items-center justify-center gap-2 transition duration-100 hover:border-primary/20 shadow-lg shadow-gray-300/30">
                                        {{ ux_icon('mdi:paris', {'class':'size-8 text-primary'}) }}
                                        <h4 class="text-xs sm:text-sm text-center text-gray-600 text-balance">
                                            {{ 'findAccommodation.timeline.steps.2.cards.1'|trans }}
                                        </h4>
                                    </div>
                                    <div class="bg-white border border-slate-100 rounded-xl p-4 flex flex-col items-center justify-center gap-2 transition duration-100 hover:border-primary/20 shadow-lg shadow-gray-300/30">
                                        {{ ux_icon('solar:calendar-outline', {'class':'size-8 text-primary'}) }}
                                        <h4 class="text-xs sm:text-sm text-center text-gray-600 text-balance">
                                            {{ 'findAccommodation.timeline.steps.2.cards.2'|trans }}
                                        </h4>
                                    </div>
                                    <div class="bg-white border border-slate-100 rounded-xl p-4 flex flex-col items-center justify-center gap-2 transition duration-100 hover:border-primary/20 shadow-lg shadow-gray-300/30">
                                        {{ ux_icon('cil:couch', {'class':'size-8 text-primary'}) }}
                                        <h4 class="text-xs sm:text-sm text-center text-gray-600 text-balance">
                                            {{ 'findAccommodation.timeline.steps.2.cards.3'|trans }}
                                        </h4>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    {# Step 3 #}
                    <div
                        data-vertical-timeline-target="step"
                        class="relative pl-12 lg:pl-20 transition-all duration-400"
                    >
                        <div class="absolute left-1.5 lg:left-5.5 top-2 flex items-center justify-center w-5 h-5 rounded-full bg-white border-2 border-gray-300 transition-all duration-300"
                             data-vertical-timeline-target="dot">
                            <div class="w-1.5 h-1.5 rounded-full bg-gray-300 transition-all duration-300" data-vertical-timeline-target="dotInner"></div>
                        </div>
                        <div class="transition-opacity duration-300" style="opacity: 0.4;">
                            <div class="flex flex-col sm:flex-row items-baseline gap-3 mb-2">
                                <div class="text-sm font-mono font-semibold text-primary/40 transition-all duration-300 bg-gray-50 p-2 rounded-xl" data-vertical-timeline-target="stepNumber">03</div>
                                <h3 class="text-xl lg:text-2xl font-semibold text-gray-900 transition-colors duration-300">{{ 'findAccommodation.timeline.steps.3.title'|trans|raw }}</h3>
                            </div>
                            <p class="text-base text-gray-600 leading-relaxed">{{ 'findAccommodation.timeline.steps.3.description'|trans|raw }}</p>
                        </div>
                    </div>

                    {# Step 4 #}
                    <div
                        data-vertical-timeline-target="step"
                        class="relative pl-12 lg:pl-20 transition-all duration-400"
                    >
                        <div class="absolute left-1.5 lg:left-5.5 top-2 flex items-center justify-center w-5 h-5 rounded-full bg-white border-2 border-gray-300 transition-all duration-300"
                             data-vertical-timeline-target="dot">
                            <div class="w-1.5 h-1.5 rounded-full bg-gray-300 transition-all duration-300" data-vertical-timeline-target="dotInner"></div>
                        </div>
                        <div class="transition-opacity duration-300" style="opacity: 0.4;">
                            <div class="flex flex-col sm:flex-row items-baseline gap-3 mb-2">
                                <div class="text-sm font-mono font-semibold text-primary/40 transition-all duration-300 bg-gray-50 p-2 rounded-xl" data-vertical-timeline-target="stepNumber">04</div>
                                <h3 class="text-xl lg:text-2xl font-semibold text-gray-900 transition-colors duration-300">{{ 'findAccommodation.timeline.steps.4.title'|trans|raw }}</h3>
                            </div>
                            <p class="text-base text-gray-600 leading-relaxed">{{ 'findAccommodation.timeline.steps.4.description'|trans|raw }}</p>
                            <div class="max-w-sm mt-8">
                                <div class="grid max-[331px]:grid-cols-1 min-[331px]:grid-cols-2 gap-4">
                                    <div class="bg-white border border-slate-100 rounded-xl p-4 flex flex-col items-center justify-center gap-2 transition duration-100 hover:border-primary/20 shadow-lg shadow-gray-300/30">
                                        {{ ux_icon('lineicons:phone', {'class':'size-8 text-primary'}) }}
                                        <h4 class="text-xs sm:text-sm text-center text-gray-600 text-balance">
                                            {{ 'findAccommodation.timeline.steps.4.cards.1'|trans }}
                                        </h4>
                                    </div>
                                    <div class="bg-white border border-slate-100 rounded-xl p-4 flex flex-col items-center justify-center gap-2 transition duration-100 hover:border-primary/20 shadow-lg shadow-gray-300/30">
                                        {{ ux_icon('icon-park-outline:eyes', {'class':'size-8 text-primary'}) }}
                                        <h4 class="text-xs sm:text-sm text-center text-gray-600 text-balance">
                                            {{ 'findAccommodation.timeline.steps.4.cards.2'|trans }}
                                        </h4>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    {# Step 5 #}
                    <div
                        data-vertical-timeline-target="step"
                        class="relative pl-12 lg:pl-20 transition-all duration-400"
                    >
                        <div class="absolute left-1.5 lg:left-5.5 top-2 flex items-center justify-center w-5 h-5 rounded-full bg-white border-2 border-gray-300 transition-all duration-300"
                             data-vertical-timeline-target="dot">
                            <div class="w-1.5 h-1.5 rounded-full bg-gray-300 transition-all duration-300" data-vertical-timeline-target="dotInner"></div>
                        </div>
                        <div class="transition-opacity duration-300" style="opacity: 0.4;">
                            <div class="flex flex-col sm:flex-row items-baseline gap-3 mb-2">
                                <div class="text-sm font-mono font-semibold text-primary/40 transition-all duration-300 bg-gray-50 p-2 rounded-xl" data-vertical-timeline-target="stepNumber">05</div>
                                <h3 class="text-xl lg:text-2xl font-semibold text-gray-900 transition-colors duration-300">{{ 'findAccommodation.timeline.steps.5.title'|trans|raw }}</h3>
                            </div>
                            <p class="text-base text-gray-600 leading-relaxed">{{ 'findAccommodation.timeline.steps.5.description'|trans|raw }}</p>
                        </div>
                    </div>

                    {# Step 6 #}
                    <div
                        data-vertical-timeline-target="step"
                        class="relative pl-12 lg:pl-20 transition-all duration-400"
                    >
                        <div class="absolute left-1.5 lg:left-5.5 top-2 flex items-center justify-center w-5 h-5 rounded-full bg-white border-2 border-gray-300 transition-all duration-300"
                             data-vertical-timeline-target="dot">
                            <div class="w-1.5 h-1.5 rounded-full bg-gray-300 transition-all duration-300" data-vertical-timeline-target="dotInner"></div>
                        </div>
                        <div class="transition-opacity duration-300" style="opacity: 0.4;">
                            <div class="flex flex-col sm:flex-row items-baseline gap-3 mb-2">
                                <div class="text-sm font-mono font-semibold text-primary/40 transition-all duration-300 bg-gray-50 p-2 rounded-xl" data-vertical-timeline-target="stepNumber">06</div>
                                <h3 class="text-xl lg:text-2xl font-semibold text-gray-900 transition-colors duration-300">{{ 'findAccommodation.timeline.steps.6.title'|trans|raw }}</h3>
                            </div>
                            <p class="text-base text-gray-600 leading-relaxed">{{ 'findAccommodation.timeline.steps.6.description'|trans|raw }}</p>
                        </div>
                    </div>

                    {# Step 7 #}
                    <div
                        data-vertical-timeline-target="step"
                        class="relative pl-12 lg:pl-20 transition-all duration-400"
                    >
                        <div class="absolute left-1.5 lg:left-5.5 top-2 flex items-center justify-center w-5 h-5 rounded-full bg-white border-2 border-gray-300 transition-all duration-300"
                             data-vertical-timeline-target="dot">
                            <div class="w-1.5 h-1.5 rounded-full bg-gray-300 transition-all duration-300" data-vertical-timeline-target="dotInner"></div>
                        </div>
                        <div class="transition-opacity duration-300" style="opacity: 0.4;">
                            <div class="flex flex-col sm:flex-row items-baseline gap-3 mb-2">
                                <div class="text-sm font-mono font-semibold text-primary/40 transition-all duration-300 bg-gray-50 p-2 rounded-xl" data-vertical-timeline-target="stepNumber">07</div>
                                <h3 class="text-xl lg:text-2xl font-semibold text-gray-900 transition-colors duration-300">{{ 'findAccommodation.timeline.steps.7.title'|trans|raw }}</h3>
                            </div>
                            <p class="text-base text-gray-600 leading-relaxed">{{ 'findAccommodation.timeline.steps.7.description'|trans|raw }}</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="mt-12 lg:mt-20 flex items-center justify-center">
            <twig:Button variant="default" as="a" size="lg" href="{{ path('app_contact') }}">
                {{ 'home.heroSection.button'|trans|raw }}
            </twig:Button>
        </div>
    </section>
    <twig:Section:SolutionGrid
        keyPrefix="findAccommodation.solution"
        :icons="['gg:search', 'hugeicons:diamond-02', 'mdi:paper-check-outline', 'humbleicons:key', 'icon-park-outline:people', 'mdi:paris']"
    />
    <twig:Section:AdvantageList
        keyPrefix="findAccommodation.advantage"
        imageSrc="medias/website/relocation-paris-6.webp"
        imageAlt="Relocation In Paris, votre agence de relocation à Paris"
    />
    <section class="max-w-2xl mx-auto lg:max-w-7xl px-6 lg:px-8 lg:py-16 py-12">
        <div class="lg:grid lg:grid-cols-12 lg:gap-8">
            <div class="lg:col-span-5">
                <div class="space-y-3 max-w-md">
                    <p class="font-semibold text-primary font-secondary">{{ 'home.faq.title'|trans|raw }}</p>
                    <h2 class="text-pretty text-3xl font-semibold font-secondary tracking-tight text-gray-900 sm:text-4xl">{{ 'home.faq.subTitle'|trans|raw }}</h2>
                    <p class="text-neutral-600">{{ 'home.faq.text'|trans({'%url%': path('app_faq')})|raw }}</p>
                </div>
            </div>
            <div class="mt-10 lg:col-span-7 lg:mt-0">
                <twig:Section:FaqAccordion keyPrefix="home.faq.question" :keys="[7, 8, 3, 4, 9, 6]" />
            </div>
        </div>
    </section>
    <twig:Section:ctaFooter />
{% endblock %}
