{% extends 'public/base.html.twig' %}

{% block title %}{{ 'meta.findTenant.title'|trans }}{% endblock %}
{% block description %}{{ 'meta.findTenant.description'|trans }}{% endblock %}
{% block url %}{{ path('app_service_find_tenant') }}{% endblock %}

{% block schema_page %}
    {% include '_partials/schema/service.html.twig' with {
        routeName: 'app_service_find_tenant',
        metaPrefix: 'findTenant',
    } only %}
{% endblock %}

{% block body %}
    <section class="max-w-7xl mx-auto lg:px-8 px-6 lg:py-16 py-8">
        <div class="max-w-2xl mx-auto flex flex-col justify-center text-center space-y-4">
            <twig:Section:PageHeader
                caption="findTenant.title"
                subtitle="findTenant.subTitle"
                intro="findTenant.text"
            />
            <twig:Section:GoogleTrustBadge keyPrefix="findAccommodation.trust" />
        </div>
        <div class="max-w-5xl mx-auto mt-12">
            <img width="546" height="350" loading="eager" src="{{ asset('medias/website/relocation-in-paris-10.webp') }}" alt="Relocation In Paris, trouver un locataire à Paris" class="w-full aspect-3/2 lg:h-[400px] object-cover rounded-2xl" />
        </div>
    </section>
    <section class="max-w-7xl mx-auto lg:px-8 px-6 lg:py-16 py-12 bg-white">
        <div class="max-w-4xl mx-auto">
            <div
                data-controller="vertical-timeline"
                data-vertical-timeline-threshold-value="0.5"
                class="relative"
            >
                {# Vertical Progress Rail #}
                <div class="absolute left-4 lg:left-8 top-0 bottom-0 w-0.5 bg-gray-200" data-vertical-timeline-target="rail">
                    <div
                        data-vertical-timeline-target="progressBar"
                        class="absolute top-0 left-0 w-full bg-gradient-to-b from-primary via-primary/90 to-primary/80 transition-all duration-500 ease-out"
                        style="height: 0%;"
                    ></div>
                </div>

                {# Timeline Steps #}
                <div class="relative space-y-12 lg:space-y-16">
                    {# Step 1 #}
                    <div
                        data-vertical-timeline-target="step"
                        class="relative pl-12 lg:pl-20 transition-all duration-400"
                    >
                        <div class="absolute left-1.5 lg:left-5.5 top-0 flex items-center justify-center w-5 h-5 rounded-full bg-white border-2 border-gray-300 transition-all duration-300"
                             data-vertical-timeline-target="dot">
                            <div class="w-1.5 h-1.5 rounded-full bg-gray-300 transition-all duration-300" data-vertical-timeline-target="dotInner"></div>
                        </div>
                        <div class="transition-opacity duration-300" style="opacity: 0.4;">
                            <div class="flex flex-col sm:flex-row items-baseline gap-3 mb-2">
                                <div class="text-sm font-mono font-semibold text-primary/40 transition-all duration-300 bg-gray-50 p-2 rounded-xl" data-vertical-timeline-target="stepNumber">01</div>
                                <h3 class="text-xl lg:text-2xl font-semibold text-gray-900 transition-colors duration-300">{{ 'findTenant.steps.1.title'|trans|raw }}</h3>
                            </div>
                            <p class="text-base text-gray-600 leading-relaxed">{{ 'findTenant.steps.1.text'|trans|raw }}</p>
                        </div>
                    </div>

                    {# Step 2 #}
                    <div
                        data-vertical-timeline-target="step"
                        class="relative pl-12 lg:pl-20 transition-all duration-400"
                    >
                        <div class="absolute left-1.5 lg:left-5.5 top-2 flex items-center justify-center w-5 h-5 rounded-full bg-white border-2 border-gray-300 transition-all duration-300"
                             data-vertical-timeline-target="dot">
                            <div class="w-1.5 h-1.5 rounded-full bg-gray-300 transition-all duration-300" data-vertical-timeline-target="dotInner"></div>
                        </div>
                        <div class="transition-opacity duration-300" style="opacity: 0.4;">
                            <div class="flex flex-col sm:flex-row items-baseline gap-3 mb-2">
                                <div class="text-sm font-mono font-semibold text-primary/40 transition-all duration-300 bg-gray-50 p-2 rounded-xl" data-vertical-timeline-target="stepNumber">02</div>
                                <h3 class="text-xl lg:text-2xl font-semibold text-gray-900 transition-colors duration-300">{{ 'findTenant.steps.2.title'|trans|raw }}</h3>
                            </div>
                            <p class="text-base text-gray-600 leading-relaxed">{{ 'findTenant.steps.2.text'|trans|raw }}</p>
                            <div class="max-w-lg mt-8">
                                <div class="grid max-[331px]:grid-cols-1 min-[331px]:grid-cols-2 md:grid-cols-3 gap-4">
                                    <div class="bg-white border border-slate-100 rounded-xl p-4 flex flex-col items-center justify-center gap-2 transition duration-100 hover:border-primary/20 shadow-lg shadow-gray-300/30">
                                        {{ ux_icon('solar:camera-linear', {'class':'size-8 text-primary'}) }}
                                        <h4 class="text-xs sm:text-sm text-center text-gray-600 text-balance">
                                            {{ 'findTenant.steps.2.cards.1.text'|trans }}
                                        </h4>
                                    </div>
                                    <div class="bg-white border border-slate-100 rounded-xl p-4 flex flex-col items-center justify-center gap-2 transition duration-100 hover:border-primary/20 shadow-lg shadow-gray-300/30">
                                        {{ ux_icon('majesticons:image-frame-line', {'class':'size-8 text-primary'}) }}
                                        <h4 class="text-xs sm:text-sm text-center text-gray-600 text-balance">
                                            {{ 'findTenant.steps.2.cards.2.text'|trans }}
                                        </h4>
                                    </div>
                                    <div class="bg-white border border-slate-100 rounded-xl p-4 flex flex-col items-center justify-center gap-2 transition duration-100 hover:border-primary/20 shadow-lg shadow-gray-300/30">
                                        {{ ux_icon('mdi:magic', {'class':'size-8 text-primary'}) }}
                                        <h4 class="text-xs sm:text-sm text-center text-gray-600 text-balance">
                                            {{ 'findTenant.steps.2.cards.3.text'|trans }}
                                        </h4>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    {# Step 3 #}
                    <div
                        data-vertical-timeline-target="step"
                        class="relative pl-12 lg:pl-20 transition-all duration-400"
                    >
                        <div class="absolute left-1.5 lg:left-5.5 top-2 flex items-center justify-center w-5 h-5 rounded-full bg-white border-2 border-gray-300 transition-all duration-300"
                             data-vertical-timeline-target="dot">
                            <div class="w-1.5 h-1.5 rounded-full bg-gray-300 transition-all duration-300" data-vertical-timeline-target="dotInner"></div>
                        </div>
                        <div class="transition-opacity duration-300" style="opacity: 0.4;">
                            <div class="flex flex-col sm:flex-row items-baseline gap-3 mb-2">
                                <div class="text-sm font-mono font-semibold text-primary/40 transition-all duration-300 bg-gray-50 p-2 rounded-xl" data-vertical-timeline-target="stepNumber">03</div>
                                <h3 class="text-xl lg:text-2xl font-semibold text-gray-900 transition-colors duration-300">{{ 'findTenant.steps.3.title'|trans|raw }}</h3>
                            </div>
                            <p class="text-base text-gray-600 leading-relaxed">{{ 'findTenant.steps.3.text'|trans|raw }}</p>
                            <div class="max-w-sm mt-8">
                                <div class="grid max-[331px]:grid-cols-1 min-[331px]:grid-cols-2 gap-4">
                                    <div class="bg-white border border-slate-100 rounded-xl p-4 flex flex-col items-center justify-center gap-2 transition duration-100 hover:border-primary/20 shadow-lg shadow-gray-300/30">
                                        {{ ux_icon('hugeicons:user-group-03', {'class':'size-8 text-primary'}) }}
                                        <h4 class="text-xs sm:text-sm text-center text-gray-600 text-balance">
                                            {{ 'findTenant.steps.3.cards.1.text'|trans }}
                                        </h4>
                                    </div>
                                    <div class="bg-white border border-slate-100 rounded-xl p-4 flex flex-col items-center justify-center gap-2 transition duration-100 hover:border-primary/20 shadow-lg shadow-gray-300/30">
                                        {{ ux_icon('streamline-ultimate:megaphone', {'class':'size-8 text-primary'}) }}
                                        <h4 class="text-xs sm:text-sm text-center text-gray-600 text-balance">
                                            {{ 'findTenant.steps.3.cards.2.text'|trans }}
                                        </h4>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    {# Step 4 #}
                    <div
                        data-vertical-timeline-target="step"
                        class="relative pl-12 lg:pl-20 transition-all duration-400"
                    >
                        <div class="absolute left-1.5 lg:left-5.5 top-2 flex items-center justify-center w-5 h-5 rounded-full bg-white border-2 border-gray-300 transition-all duration-300"
                             data-vertical-timeline-target="dot">
                            <div class="w-1.5 h-1.5 rounded-full bg-gray-300 transition-all duration-300" data-vertical-timeline-target="dotInner"></div>
                        </div>
                        <div class="transition-opacity duration-300" style="opacity: 0.4;">
                            <div class="flex flex-col sm:flex-row items-baseline gap-3 mb-2">
                                <div class="text-sm font-mono font-semibold text-primary/40 transition-all duration-300 bg-gray-50 p-2 rounded-xl" data-vertical-timeline-target="stepNumber">04</div>
                                <h3 class="text-xl lg:text-2xl font-semibold text-gray-900 transition-colors duration-300">{{ 'findTenant.steps.4.title'|trans|raw }}</h3>
                            </div>
                            <p class="text-base text-gray-600 leading-relaxed">{{ 'findTenant.steps.4.text'|trans|raw }}</p>
                        </div>
                    </div>

                    {# Step 5 #}
                    <div
                        data-vertical-timeline-target="step"
                        class="relative pl-12 lg:pl-20 transition-all duration-400"
                    >
                        <div class="absolute left-1.5 lg:left-5.5 top-2 flex items-center justify-center w-5 h-5 rounded-full bg-white border-2 border-gray-300 transition-all duration-300"
                             data-vertical-timeline-target="dot">
                            <div class="w-1.5 h-1.5 rounded-full bg-gray-300 transition-all duration-300" data-vertical-timeline-target="dotInner"></div>
                        </div>
                        <div class="transition-opacity duration-300" style="opacity: 0.4;">
                            <div class="flex flex-col sm:flex-row items-baseline gap-3 mb-2">
                                <div class="text-sm font-mono font-semibold text-primary/40 transition-all duration-300 bg-gray-50 p-2 rounded-xl" data-vertical-timeline-target="stepNumber">05</div>
                                <h3 class="text-xl lg:text-2xl font-semibold text-gray-900 transition-colors duration-300">{{ 'findTenant.steps.5.title'|trans|raw }}</h3>
                            </div>
                            <p class="text-base text-gray-600 leading-relaxed">{{ 'findTenant.steps.5.text'|trans|raw }}</p>
                        </div>
                    </div>

                </div>
            </div>
        </div>
        <div class="mt-12 lg:mt-20 flex items-center justify-center">
            <twig:Button variant="default" as="a" size="lg" href="{{ path('app_contact') }}">
                {{ 'home.heroSection.button'|trans|raw }}
            </twig:Button>
        </div>
    </section>
    <twig:Section:SolutionGrid
        keyPrefix="findTenant.solution"
        :icons="['gg:search', 'solar:camera-linear', 'fluent:premium-20-regular', 'tabler:user-check', 'material-symbols:door-open-outline', 'material-symbols:key-outline-rounded']"
    />
    <twig:Section:AdvantageList
        keyPrefix="findTenant.advantage"
        imageSrc="medias/website/relocation-in-paris-8.webp"
        imageAlt="Relocation In Paris, trouver un locataire"
    />
    <section class="bg-white py-24 sm:py-32">
        <div class="mx-auto max-w-5xl px-6 lg:px-8">
            <div class="pb-12 lg:pb-16 space-y-3 mx-auto space-y-3 text-center max-w-xl">
                <h2 class="font-semibold text-primary font-secondary">{{ 'findTenant.price.title'|trans|raw }}</h2>
                <h3 class="text-3xl font-medium text-balance">{{ 'findTenant.price.subTitle'|trans|raw }}</h3>
            </div>
            <div class="mx-auto max-w-xl rounded-3xl ring-1 ring-gray-200 lg:mx-0 lg:flex lg:max-w-none">
                <div class="p-8 sm:p-10 lg:flex-auto">
                    <h4 class="text-2xl font-semibold tracking-tight text-gray-900">
                        {{ 'findTenant.price.text1'|trans|raw }}
                    </h4>
                    <p class="mt-6 text-base/7 text-gray-600">
                        {{ 'findTenant.price.text2'|trans|raw }}
                    </p>
                    <div class="mt-10 flex items-center gap-x-4">
                        <h4 class="flex-none text-sm/6 font-semibold text-primary">
                            {{ 'findTenant.price.guarantee.title'|trans|raw }}
                        </h4>
                        <div class="h-px flex-auto bg-gray-100"></div>
                    </div>
                    <ul role="list" class="mt-8 grid gap-4 text-sm/6 text-gray-600 grid-cols-2 sm:gap-6">
                        <li class="flex gap-x-3">
                            {{ ux_icon('material-symbols:check-rounded', {'class':'size-6 flex-none shrink-0 text-green-600'}) }}
                            {{ 'findTenant.price.guarantee.1'|trans|raw }}
                        </li>
                        <li class="flex gap-x-3">
                            {{ ux_icon('material-symbols:check-rounded', {'class':'size-6 flex-none shrink-0 text-green-600'}) }}
                            {{ 'findTenant.price.guarantee.3'|trans|raw }}
                        </li>
                        <li class="flex gap-x-3">
                            {{ ux_icon('material-symbols:check-rounded', {'class':'size-6 flex-none shrink-0 text-green-600'}) }}
                            {{ 'findTenant.price.guarantee.4'|trans|raw }}
                        </li>
                        <li class="flex gap-x-3">
                            {{ ux_icon('material-symbols:check-rounded', {'class':'size-6 flex-none shrink-0 text-green-600'}) }}
                            {{ 'findTenant.price.guarantee.5'|trans|raw }}
                        </li>
                        <li class="flex gap-x-3">
                            {{ ux_icon('material-symbols:check-rounded', {'class':'size-6 flex-none shrink-0 text-green-600'}) }}
                            {{ 'findTenant.price.guarantee.6'|trans|raw }}
                        </li>
                    </ul>
                </div>
                <div class="-mt-2 p-2 lg:mt-0 lg:w-full lg:max-w-md lg:shrink-0">
                    <div class="rounded-2xl bg-slate-50 py-10 h-full text-center ring-1 ring-inset ring-gray-900/5 lg:flex lg:flex-col lg:justify-center lg:py-16">
                        <div class="mx-auto max-w-xs px-8">
                            <p class="mt-6 flex items-baseline justify-center gap-x-0.5">
                                <span data-pricing-tabs-target="percentage" class="text-5xl font-semibold tracking-tight text-gray-900">80</span>
                                <span class="text-4xl font-semibold tracking-wide text-gray-900">%</span>
                            </p>
                            <p class="mt-6 text-balance text-sm/5 text-gray-600 uppercase">{{ 'findTenant.price.text3'|trans|raw }}</p>
                            <twig:Button variant="default" as="a" size="lg" class="mt-6" href="{{ path('app_contact') }}">
                                {{ 'propertyManagement.price.fees.button'|trans|raw }}
                            </twig:Button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
    <section class="max-w-7xl mx-auto lg:px-8 px-6 lg:py-16 py-12">
        <div class="max-w-3xl mx-auto">
            <div class="pb-12 lg:pb-16 space-y-3 mx-auto space-y-3 text-center">
                <h2 class="font-semibold text-primary font-secondary">{{ 'home.faq.title'|trans|raw }}</h2>
                <h3 class="text-3xl font-medium text-pretty">{{ 'home.faq.subTitle'|trans|raw }}</h3>
            </div>
            <twig:Section:FaqAccordion keyPrefix="findTenant.faq.question" :keys="1..5" />
        </div>
    </section>
    <twig:Section:CtaFooter />
{% endblock %}
