<!DOCTYPE html>
<html lang="{{ app.request.locale }}" class="h-full">
    <head>
        <meta charset="UTF-8">

        <!-- Google Tag Manager -->
        <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
                    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
                j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
                'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
            })(window,document,'script','dataLayer','GTM-TSHQL7Q6');</script>
        <!-- End Google Tag Manager -->

        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <meta name="theme-color" content="#FFFFFF">

        <title>Relocation In Paris - {% block title %}{% endblock %}</title>
        <meta name="description" content="{% block description %}{% endblock %}">
        {% block meta_robots %}<meta name="robots" content="noindex, nofollow">{% endblock %}
        <link rel="canonical" href="{{ site_url }}{% block url %}{% endblock %}" />

        {# Per-page critical asset preload (e.g. LCP hero image). Empty by default. #}
        {% block head_preload %}{% endblock %}

        {# OG image captured once so the meta partial receives the resolved value #}
        {% set pageOgImage %}{% block og_image %}{{ asset('medias/banner/relocation-in-paris-banner.webp') }}{% endblock %}{% endset %}

        {# Hreflang: empty by default. Auth routes are localised asymmetrically
           (/inscription vs /register), so each template must override this
           block with explicit path(_locale: …) calls instead of relying on
           the naive locale-substitution fallback used on public pages. #}
        {% block hreflang %}{% endblock %}

        {% include '_partials/meta.html.twig' with {
            pageTitle: block('title'),
            pageDescription: block('description'),
            pageUrl: block('url'),
            pageOgImage: pageOgImage|trim,
        } only %}

        {% block stylesheets %}
            {{ encore_entry_link_tags('app') }}
        {% endblock %}

        {% block javascripts %}
            {{ encore_entry_script_tags('app') }}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body class="h-full">
        <noscript>
            <iframe src="https://www.googletagmanager.com/ns.html?id=GTM-TSHQL7Q6"
                    height="0" width="0" style="display:none;visibility:hidden">
            </iframe>
        </noscript>
        <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-[100] focus:bg-primary focus:text-white focus:px-4 focus:py-2 focus:rounded-lg focus:shadow-lg focus:outline-none focus:ring-2 focus:ring-primary/50 focus:ring-offset-2">
            {{ 'a11y.skipToContent'|trans }}
        </a>
        <main id="main-content" tabindex="-1" class="flex min-h-full">
            {% block body %}{% endblock %}
        </main>
    </body>
</html>
