{% extends 'public/base_auth.html.twig' %}

{% block title %}{{ 'meta.register.verify.title'|trans }}{% endblock %}
{% block description %}{{ 'meta.register.verify.description'|trans }}{% endblock %}
{% block url %}{{ path('app_register_verify_code', {_locale: app.request.locale}) }}{% endblock %}

{% block hreflang %}
    <link rel="alternate" hreflang="fr" href="{{ site_url }}{{ path('app_register_verify_code', {_locale: 'fr'}) }}" />
    <link rel="alternate" hreflang="en" href="{{ site_url }}{{ path('app_register_verify_code', {_locale: 'en'}) }}" />
    <link rel="alternate" hreflang="x-default" href="{{ site_url }}{{ path('app_register_verify_code', {_locale: 'fr'}) }}" />
{% endblock %}

{% block head_preload %}
    <link rel="preload" as="image" href="{{ asset('medias/website/rip_1_register.webp') }}" media="(min-width: 1024px)">
{% endblock %}

{% set currentRoute = app.request.attributes.get('_route') %}
{% set currentParameters = app.request.attributes.get('_route_params') %}

{% block body %}
    {% set codeInvalid = form.code.vars.submitted and not form.code.vars.valid %}
    <section class="relative overflow-hidden flex w-full flex-col justify-center px-8 py-12 lg:w-1/2">
        <twig:Section:GridBackground :auth="true" />
        <div class="mx-auto w-full max-w-xl lg:w-full">
            <header class="flex justify-between items-center gap-4">
                {# Logo doubles as the escape hatch on this page — if the email
                   the user signed up with is wrong or never arrives, clicking
                   the logo logs them out (rather than just navigating away
                   while still authenticated), so they can re-register or come
                   back later with a fresh login. The EmailVerificationListener
                   would otherwise loop them straight back here. #}
                <a href="{{ logout_path() }}">
                    <img
                        src="{{ asset('medias/logos/logo_red.svg') }}"
                        width="141"
                        height="32"
                        loading="eager"
                        alt="{{ 'header.logo.alt'|trans|raw }}"
                        class="shrink-0 h-8 w-auto"
                    />
                </a>
                <twig:Button
                    variant="outline"
                    popovertarget="desktop-lang"
                    size="icon-lg"
                    aria-label="{{ 'header.lang.select'|trans|raw }}"
                    class="aria-expanded:bg-neutral-100 aria-expanded:text-primary hover:text-primary rounded-lg shadow-none border-none hover:bg-neutral-100 transition duration-100 flex items-center gap-x-2"
                >
                    {{ ux_icon('proicons:globe', {'class': 'size-6', 'aria-hidden': 'true'}) }}
                </twig:Button>
                <el-popover
                    id="desktop-lang"
                    anchor="bottom"
                    popover
                    class="m-0 w-screen max-w-max overflow-visible bg-transparent p-0 px-4 transition [--anchor-gap:theme(spacing.5)] [transition-behavior:allow-discrete] backdrop:bg-transparent open:flex data-[closed]:translate-y-1 data-[closed]:opacity-0 data-[enter]:duration-200 data-[leave]:duration-150 data-[enter]:ease-out data-[leave]:ease-in"
                >
                    <div class="w-screen max-w-[142px] flex-auto rounded-2xl space-y-1.5 bg-white p-3 text-sm/6 shadow-lg outline outline-1 outline-gray-900/5">
                        <a
                            href="{{ path(currentRoute, currentParameters|merge({'_locale': 'fr'})) }}"
                            hreflang="fr"
                            lang="fr"
                            class="{% if app.request.locale == 'fr' %}bg-neutral-100 text-primary font-semibold{% endif %} relative rounded-lg px-4 py-2 hover:bg-neutral-100 block text-sm/7 text-gray-900 cursor-pointer flex justify-between items-center"
                        >
                            <span class="flex items-center gap-x-3">
                                {{ ux_icon('circle-flags:fr', {'class': 'size-5 rounded-full', 'aria-hidden': 'true'}) }}
                                {{ 'header.lang.type.fr'|trans|raw }}
                            </span>
                        </a>
                        <a
                            href="{{ path(currentRoute, currentParameters|merge({'_locale': 'en'})) }}"
                            hreflang="en"
                            lang="en"
                            class="{% if app.request.locale == 'en' %}bg-neutral-100 text-primary font-semibold{% endif %} relative rounded-lg px-4 py-2 hover:bg-neutral-100 block text-sm/7 text-gray-900 cursor-pointer flex justify-between items-center"
                        >
                            <span class="flex items-center gap-x-3">
                                {{ ux_icon('circle-flags:en', {'class': 'size-5 rounded-full', 'aria-hidden': 'true'}) }}
                                {{ 'header.lang.type.en'|trans|raw }}
                            </span>
                        </a>
                    </div>
                </el-popover>
            </header>
            <div class="flex flex-col justify-center items-center w-full space-y-2">
                <p class="sr-only">{{ 'register.step.indicator'|trans({'%current%': 3, '%total%': 3}) }}</p>
                <h1 class="mt-12 text-2xl/9 font-semibold tracking-tight text-gray-900 text-balance text-center">
                    {{ 'register.verify.code.title'|trans|raw }}
                </h1>
                <p class="font-light text-neutral-400 text-pretty text-center">
                    {{ 'register.verify.code.subTitle'|trans|raw }}{% if email %}
                        <span class="block font-medium text-neutral-900">{{ email }}</span>
                    {% endif %}
                </p>
            </div>
        </div>
        <div class="mt-10 mx-auto w-full max-w-sm">
            {% for flashMessage in app.flashes('register_success') %}
                <twig:Alert class="max-w-md mb-4 border-green-200 bg-green-50 text-green-900">
                    <twig:ux:icon name="lucide:check-circle-2" class="size-4" />
                    <twig:Alert:Title>{{ (flashMessage ~ 'Title')|trans|raw }}</twig:Alert:Title>
                    <twig:Alert:Description>
                        {{ flashMessage|trans|raw }}
                    </twig:Alert:Description>
                </twig:Alert>
            {% endfor %}
            {% for flashMessage in app.flashes('register_error') %}
                <twig:Alert class="max-w-md mb-4 border-amber-200 bg-amber-50 text-amber-900">
                    <twig:ux:icon name="lucide:triangle-alert" class="size-4" />
                    <twig:Alert:Title>{{ (flashMessage ~ 'Title')|trans|raw }}</twig:Alert:Title>
                    <twig:Alert:Description>
                        {{ flashMessage|trans|raw }}
                    </twig:Alert:Description>
                </twig:Alert>
            {% endfor %}

            {{ form_start(form, {'attr': {
                'class': 'space-y-6',
                'novalidate': 'novalidate',
                'data-controller': 'otp-input',
            }}) }}
                {{ form_widget(form.code, {'attr': {'data-otp-input-target': 'hidden'}}) }}

                <fieldset
                    aria-describedby="otp-code-error"
                    aria-invalid="{{ codeInvalid ? 'true' : 'false' }}"
                >
                    <legend class="sr-only">{{ 'register.verify.code.label'|trans|raw }}</legend>
                    <div class="grid grid-cols-6 gap-2 sm:gap-3 *:aspect-square *:w-full *:rounded-lg *:border *:bg-white *:text-center *:text-xl *:font-semibold *:text-gray-900 *:tabular-nums *:focus:outline-2 *:-outline-offset-1 *:focus:outline-primary sm:*:text-2xl {{ codeInvalid ? '*:border-red-500' : '*:border-gray-300' }}">
                        {% for i in 0..5 %}
                            <input
                                type="text"
                                inputmode="numeric"
                                autocomplete="one-time-code"
                                maxlength="1"
                                aria-label="{{ 'register.verify.code.label'|trans }} {{ i + 1 }} / 6"
                                aria-invalid="{{ codeInvalid ? 'true' : 'false' }}"
                                data-otp-input-target="digit"
                                data-action="input->otp-input#onInput keydown->otp-input#onKeydown paste->otp-input#onPaste"
                                {% if i == 0 %}autofocus{% endif %}
                            />
                        {% endfor %}
                    </div>
                </fieldset>

                <p
                    id="otp-code-error"
                    role="alert"
                    class="-mt-3 text-pretty text-center text-xs text-red-600{% if not codeInvalid %} hidden{% endif %}"
                >
                    {%- if codeInvalid -%}
                        {%- for err in form.code.vars.errors -%}
                            {{ err.message|trans }}
                        {%- endfor -%}
                    {%- endif -%}
                </p>

                <twig:Button type="submit" variant="default" size="lg" class="w-full cursor-pointer disabled:cursor-not-allowed disabled:opacity-80" data-otp-input-target="submit">
                    <span data-otp-input-target="submitLabel">{{ 'register.verify.code.submit'|trans|raw }}</span>
                    <span data-otp-input-target="submitLoading" hidden class="items-center gap-2">
                        <twig:Spinner class="text-white" />
                        {{ 'register.verify.code.verifying'|trans|raw }}
                    </span>
                </twig:Button>

                {% if form._token is defined %}
                    {{ form_widget(form._token) }}
                {% endif %}
            {{ form_end(form, {'render_rest': false}) }}

            <form
                method="POST"
                action="{{ path('app_register_resend_code') }}"
                data-controller="resend-countdown"
                data-resend-countdown-available-at-value="{{ resendAvailableAt ?? 0 }}"
                data-resend-countdown-cooldown-value="60"
                class="mt-6 flex items-center justify-center gap-1.5 text-center text-sm"
            >
                <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('app_register_resend_code') }}" />
                <span class="text-neutral-500">{{ 'register.verify.code.help'|trans|raw }}</span>
                <span class="flex items-center gap-0.5">
                    <button
                        type="submit"
                        data-resend-countdown-target="button"
                        class="cursor-pointer font-medium text-gray-800 hover:text-primary disabled:cursor-not-allowed disabled:opacity-60"
                    >
                        {{ 'register.verify.code.resend'|trans|raw }}
                    </button>
                    <span
                        data-resend-countdown-target="remaining"
                        class="tabular-nums text-neutral-400"
                        hidden
                        aria-live="polite"
                    ></span>
                </span>
            </form>

            {% if resendUsed %}
                <p class="mt-3 text-center text-xs text-neutral-500">{{ 'register.verify.code.spam'|trans|raw }}</p>
            {% endif %}
        </div>
    </section>
    <aside class="relative hidden w-0 flex-1 lg:block" aria-hidden="true">
        <img
            src="{{ asset('medias/website/rip_1_register.webp') }}"
            alt=""
            width="960"
            height="1080"
            loading="eager"
            class="absolute inset-0 size-full object-cover"
        />
        <div class="absolute inset-0 bg-black/10"></div>
    </aside>
{% endblock %}
