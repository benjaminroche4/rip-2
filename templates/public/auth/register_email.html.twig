<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html dir="ltr" lang="{{ app.request.locale|default('fr') }}">
<head>
    <meta content="text/html; charset=UTF-8" http-equiv="Content-Type" />
    <meta content="width=device-width" name="viewport" />
    <meta content="IE=edge" http-equiv="X-UA-Compatible" />
    <meta name="x-apple-disable-message-reformatting" />
    <meta content="telephone=no,address=no,email=no,date=no,url=no" name="format-detection" />
    <link rel="preload" as="image" href="https://resend-attachments.s3.amazonaws.com/y8VsZ3nZ1GDIWiz" />
    <link rel="preload" as="image" href="https://resend-attachments.s3.amazonaws.com/16d42dd0-bce1-40e8-b0fb-29790baccd42" />
    <link rel="preload" as="image" href="https://resend.com/static/email/social-linkedin.png" />
    <meta name="color-scheme" content="light dark" />
    <meta name="supported-color-schemes" content="light dark" />
    <title>{{ 'register.confirmationEmail.intro'|trans }}</title>
    <style>
        @media (prefers-color-scheme: dark) {
            body, .email-body { background-color: #111111 !important; }
            .email-card { background-color: #1e1e1e !important; border-color: #333333 !important; }
            .email-card td { color: #e4e4e4 !important; }
            .email-card h2, .email-card h3 { color: #f5f5f5 !important; }
            .box-gray { background-color: #2a2a2a !important; border-color: #3a3a3a !important; }
            .box-white { background-color: #252525 !important; }
            .box-code { background-color: #0f0f0f !important; border-color: #3a3a3a !important; }
            .code-digits { color: #ffffff !important; }
            .box-amber { background-color: #2a1f05 !important; border-color: #6b4f10 !important; color: #fde68a !important; }
            .box-amber strong { color: #fde68a !important; }
            .label-muted { color: #9ca3af !important; }
            .text-muted { color: #9ca3af !important; }
            hr { border-top-color: #3a3a3a !important; }
        }
        @media only screen and (max-width: 480px) {
            .code-digits { font-size: 44px !important; letter-spacing: 0.18em !important; }
        }
    </style>
</head>
<body class="email-body" style="background-color:#f4f4f4">
    {% set fontStack = "-apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', 'Fira Sans', 'Droid Sans', 'Helvetica Neue', sans-serif" %}
    {% set monoStack = "ui-monospace, SFMono-Regular, 'SF Mono', Menlo, Consolas, 'Liberation Mono', monospace" %}

    <table width="100%" border="0" cellpadding="0" cellspacing="0" role="presentation" align="center">
        <tbody>
            <tr>
                <td>
                    <table width="100%" border="0" cellpadding="0" cellspacing="0" role="presentation" align="center"
                        style="font-family:{{ fontStack }};font-size:1.077em;min-height:100%;line-height:155%">
                        <tbody>
                            <tr>
                                <td>
                                    <table class="email-card" width="100%" border="0" cellpadding="0" cellspacing="0" role="presentation" align="center"
                                        style="max-width:600px;width:100%;padding:40px 20px;border:1px solid #e2e2e2;border-radius:12px;background-color:#ffffff;font-family:{{ fontStack }}">
                                        <tbody>
                                            <tr>
                                                <td>
                                                    <img
                                                        src="https://resend-attachments.s3.amazonaws.com/y8VsZ3nZ1GDIWiz"
                                                        alt="Logo Relocation in Paris"
                                                        width="166" height="38"
                                                        style="display:block;outline:none;border:none;text-decoration:none;max-width:100%;border-radius:0" />

                                                    <p style="margin:0;padding:0.5em 0"><br /></p>

                                                    <h2 style="margin:0;padding:0.389em 0 0;font-size:1.8em;line-height:1.44;font-weight:600;text-align:center">
                                                        {{ 'register.confirmationEmail.greeting'|trans({'%firstName%': firstName})|raw }}
                                                    </h2>

                                                    <p style="margin:0;padding:1em 0 0;font-size:1em;line-height:160%;text-align:center">
                                                        {{ 'register.confirmationEmail.intro'|trans|raw }}
                                                    </p>

                                                    <p style="margin:0;padding:0.5em 0;text-align:center"><br /></p>

                                                    <table class="box-gray" width="100%" border="0" cellpadding="0" cellspacing="0" role="presentation"
                                                        style="background-color:#F7F7F7;border:1px solid #E5E5E5;border-radius:12px;padding:10px">
                                                        <tbody>
                                                            <tr>
                                                                <td>
                                                                    <table class="box-code box-white" width="100%" border="0" cellpadding="0" cellspacing="0" role="presentation"
                                                                        style="background-color:#ffffff;border:1px dashed #d4d4d4;border-radius:12px;padding:24px 12px">
                                                                        <tbody>
                                                                            <tr>
                                                                                <td align="center" style="text-align:center">
                                                                                    <p class="code-digits"
                                                                                       style="margin:0;padding:0;font-family:{{ monoStack }};font-size:56px;line-height:1.1;font-weight:700;letter-spacing:0.22em;color:#111111;text-align:center;-webkit-user-select:all;user-select:all;text-indent:0.22em">{{ code }}</p>
                                                                                </td>
                                                                            </tr>
                                                                            <tr>
                                                                                <td align="center" style="text-align:center;padding-top:14px">
                                                                                    <p class="text-muted" style="margin:0;padding:0;font-size:12px;line-height:1.4;color:#737373;text-align:center">
                                                                                        {{ 'register.confirmationEmail.copyHint'|trans|raw }}
                                                                                    </p>
                                                                                </td>
                                                                            </tr>
                                                                        </tbody>
                                                                    </table>
                                                                </td>
                                                            </tr>
                                                        </tbody>
                                                    </table>

                                                    <p style="margin:0;padding:0.5em 0;text-align:center"><br /></p>

                                                    <p class="box-amber" style="margin:0;padding:12px;background-color:#FFFBEB;border:1px solid #FDE68A;border-radius:12px;font-size:1em;text-align:center;color:#92400E">
                                                        <strong>{{ 'register.confirmationEmail.expires'|trans|raw }}</strong>
                                                    </p>

                                                    <p style="margin:0;padding:0.5em 0;text-align:center"><br /></p>

                                                    <table width="100%" border="0" cellpadding="0" cellspacing="0" role="presentation" align="center">
                                                        <tbody>
                                                            <tr>
                                                                <td align="center">
                                                                    <img
                                                                        src="https://resend-attachments.s3.amazonaws.com/16d42dd0-bce1-40e8-b0fb-29790baccd42"
                                                                        alt="Relocation in Paris"
                                                                        width="124" height="88"
                                                                        style="display:block;outline:none;border:none;text-decoration:none;max-width:100%;border-radius:8px" />
                                                                </td>
                                                            </tr>
                                                        </tbody>
                                                    </table>

                                                    <p class="text-muted" style="margin:0;padding:16px 0;font-size:1em;text-align:center;color:#737373">
                                                        {{ 'register.confirmationEmail.tagline'|trans|raw }}
                                                    </p>

                                                    <hr style="width:100%;border:none;border-top:2px solid #eaeaea;margin:16px 0 0" />

                                                    <p class="text-muted" style="margin:0;padding:2em 0;font-size:1em;text-align:center;color:#737373">
                                                        155 Rue du Faubourg Saint-Denis<br />75010 Paris &ndash; France
                                                    </p>

                                                    <table width="100%" border="0" cellpadding="0" cellspacing="0" role="presentation" align="center">
                                                        <tbody>
                                                            <tr>
                                                                <td align="center">
                                                                    <a href="https://www.linkedin.com/company/relocation-in-paris/" rel="noopener noreferrer" target="_blank">
                                                                        <img
                                                                            src="https://resend.com/static/email/social-linkedin.png"
                                                                            alt="LinkedIn"
                                                                            width="32" height="32"
                                                                            style="display:block;outline:none;border:none;text-decoration:none" />
                                                                    </a>
                                                                </td>
                                                            </tr>
                                                        </tbody>
                                                    </table>

                                                    <p style="margin:0;padding:0.5em 0"><br /></p>
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </td>
            </tr>
        </tbody>
    </table>
</body>
</html>
