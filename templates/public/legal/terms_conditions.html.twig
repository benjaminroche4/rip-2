{% extends 'base.html.twig' %}

{% block title %}{{ 'meta.termsConditions.title'|trans }}{% endblock %}
{% block description %}{{ 'meta.termsConditions.description'|trans }}{% endblock %}
{% block url %}{{ path('app_terms_and_conditions') }}{% endblock %}

{% block schema_page %},
    {
        "@type": "WebPage",
        "@id": "{{ site_url }}{{ path('app_terms_and_conditions') }}#webpage",
        "url": "{{ site_url }}{{ path('app_terms_and_conditions') }}",
        "name": "{{ 'meta.termsConditions.title'|trans }}",
        "description": "{{ 'meta.termsConditions.description'|trans }}",
        "isPartOf": { "@id": "{{ site_url }}/#website" },
        "about": { "@id": "{{ site_url }}/#organization" },
        "inLanguage": "{{ app.request.locale == 'fr' ? 'fr-FR' : 'en-GB' }}",
        "specialty": "TermsOfService"
    }
{% endblock %}

{% block body %}
    <section aria-label="{{ 'termsConditions.title'|trans }}" class="max-w-7xl mx-auto lg:px-8 px-6 lg:py-16 py-12">
        <div class="max-w-2xl mx-auto flex flex-col justify-center text-center space-y-4">
            <h1 class="text-center font-semibold text-primary font-secondary">
                {{ 'termsConditions.title'|trans|raw }}
            </h1>
            <p class="text-4xl lg:text-5xl/16 font-medium text-balance">
                {{ 'termsConditions.subTitle'|trans|raw }}
            </p>
        </div>
    </section>

    <section aria-label="{{ 'termsConditions.card.1.title'|trans }}" class="max-w-4xl mx-auto lg:px-8 px-6 mb-12 lg:mb-16 space-y-12">
        <article class="max-w-2xl gap-5 sm:gap-6 mx-auto flex flex-col sm:flex-row bg-neutral-100 border border-neutral-200 rounded-2xl p-4 sm:p-6 group hover:border-primary transition duration-100">
            <div class="sm:block hidden bg-white rounded-lg p-2 group-hover:bg-primary transition duration-100 self-start shrink-0">
                {{ ux_icon('tabler:world-map', {'class':'size-7 shrink-0 text-primary group-hover:text-white transition duration-100'}) }}
            </div>
            <div class="flex-1 space-y-4">
                <div class="space-y-2">
                    <twig:Badge variant="default" class="rounded-full">
                        {{ 'termsConditions.card.1.badge'|trans|raw }}
                    </twig:Badge>
                    <h2 class="font-semibold text-lg text-pretty">{{ 'termsConditions.card.1.title'|trans|raw }}</h2>
                    <p class="text-neutral-600 font-regular text-pretty">
                        {{ 'termsConditions.card.1.text'|trans|raw }}
                    </p>
                </div>
                <div class="h-[1px] bg-gradient-to-r from-slate-400/20 via-slate-500 to-slate-400/20 opacity-20"></div>
                <div class="flex justify-between items-center gap-x-6">
                    <div>
                        <p class="text-neutral-600 text-sm">
                            {{ 'termsConditions.card.1.text2'|trans|raw }} :
                            <span class="font-medium">
                                {{ 'termsConditions.card.1.updatedAt'|trans|raw }}
                            </span>
                        </p>
                    </div>
                    <twig:Button variant="default" as="a" href="{{ path('app_terms_download') }}">
                        {{ 'termsConditions.card.1.button'|trans|raw }}
                        {{ ux_icon('material-symbols:download-rounded', {'class':'size-4 shrink-0'}) }}
                    </twig:Button>
                </div>
            </div>
        </article>
    </section>
{% endblock %}
