                    </svg>
                </div>
                <h1 class="mx-auto max-w-2xl text-center text-5xl font-medium tracking-tight text-gray-900 lg:text-start lg:text-6xl/16 text-pretty">
                    {{ 'home.heroSection.title'|trans|raw }}
                </h1>
                <p class="mx-auto mt-5 max-w-lg text-center font-normal text-neutral-600 lg:mx-0 lg:text-start text-pretty">
                    {{ 'home.heroSection.subTitle'|trans|raw }}
                </p>
                <div class="mt-8 flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-6">
                    <twig:Button variant="default" as="a" size="lg" href="{{ path('app_contact') }}">
                        {{ 'home.heroSection.button'|trans|raw }}
                    </twig:Button>
                </div>
                <div class="grid grid-cols-1 min-[390px]:grid-cols-2 sm:grid-cols-3 gap-5 mt-10 mx-auto lg:mx-0">
                    <div class="flex items-center gap-3 justify-center lg:justify-start">
                        {{ ux_icon('gravity-ui:thunderbolt', {'class':'size-5 text-primary shrink-0'}) }}
                        <p class="text-slate-800 text-sm font-medium">{{ 'home.heroSection.service.1'|trans|raw }}</p>
                    </div>
                    <div class="flex items-center gap-3  justify-center lg:justify-start">
                        {{ ux_icon('mdi:world', {'class':'size-5 text-primary shrink-0'}) }}
                        <p class="text-slate-800 text-sm font-medium">{{ 'home.heroSection.service.2'|trans|raw }}</p>
                    </div>
                    <div class="flex items-center gap-3 justify-center lg:justify-start min-[390px]:col-span-2 sm:col-span-1">
                        {{ ux_icon('humbleicons:key', {'class':'size-5 text-primary shrink-0'}) }}
                        <p class="text-slate-800 text-sm font-medium">{{ 'home.heroSection.service.3'|trans|raw }}</p>
                    </div>
                </div>
            </div>
            <div class="h-[300px] lg:h-[600px]">
                <video
                    class="w-full h-full object-cover rounded-2xl"
                    autoplay
                    muted
                    loop
                    playsinline
                    fetchpriority="high"
                    preload="auto"
                    poster="{{ asset('medias/website/rip_paris.webp') }}"
                >
                    <source src="{{ asset('medias/videos/relocation-in-paris.webm') }}" class="object-cover" type="video/webm">
                    <source src="{{ asset('medias/videos/relocation-in-paris.mp4') }}" class="object-cover" type="video/mp4">
                </video>
            </div>
        </div>
    </section>
