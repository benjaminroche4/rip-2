            <div class="mx-auto flex h-full w-full max-w-xl flex-col justify-center">
                <div class="flex items-center justify-center space-x-3 pb-10 lg:justify-start" aria-hidden="true">
                    <svg viewBox="0 0 30 50" xmlns="http://www.w3.org/2000/svg" class="size-9">
