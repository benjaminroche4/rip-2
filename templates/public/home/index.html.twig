{% extends 'base.html.twig' %}

{% block title %}{{ 'meta.home.title'|trans }}{% endblock %}
{% block description %}{{ 'meta.home.description'|trans }}{% endblock %}
{% block url %}{{ path('app_home') }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="preload" as="image" href="{{ asset('medias/website/rip_paris.webp') }}" fetchpriority="high">
{% endblock %}

{% set isFr = app.request.locale == 'fr' %}

{% block schema_page %}
    ,{
        "@type": "WebPage",
        "@id": "https://relocation-in-paris.fr/{{ app.request.locale }}/#homepage",
        "url": "https://relocation-in-paris.fr/{{ app.request.locale }}",
        "name": "{{ 'meta.home.title'|trans|e('js') }}",
        "description": "{{ 'meta.home.description'|trans|e('js') }}",
        "inLanguage": "{{ app.request.locale == 'fr' ? 'fr-FR' : 'en-GB' }}",
        "isPartOf": { "@id": "https://relocation-in-paris.fr/#website" },
        "about": { "@id": "https://relocation-in-paris.fr/#organization" },
        "primaryImageOfPage": {
            "@type": "ImageObject",
            "url": "https://relocation-in-paris.fr/medias/banner/relocation-in-paris-banner.webp"
        }
    }
{% endblock %}

{% block body %}
    <section class="max-w-7xl mx-auto px-6 lg:px-8 relative z-10">
