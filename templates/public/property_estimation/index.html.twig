{% extends 'base.html.twig' %}

{% block title %}{{ 'meta.landlords.title'|trans }}{% endblock %}
{% block description %}{{ 'meta.landlords.description'|trans }}{% endblock %}
{% block url %}{{ path('app_service_landlords') }}{% endblock %}

{% block schema_page %}
    ,{
        "@type": "Service",
        "@id": "{{ site_url }}{{ path('app_service_landlords') }}/#service",
        "url": "{{ site_url }}{{ path('app_service_landlords') }}",
        "name": "{{ 'meta.landlords.title'|trans|e('js') }}",
        "description": "{{ 'meta.landlords.description'|trans|e('js') }}",
        "provider": { "@id": "{{ site_url }}/#organization" },
        "areaServed": {
            "@type": "City",
            "name": "Paris"
        }
    }
{% endblock %}

{% block google_maps %}
    <script async defer src="https://maps.googleapis.com/maps/api/js?key={{ google_maps_api_key }}&libraries=places&language=fr"></script>
{% endblock %}

