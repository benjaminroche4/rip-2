<turbo-stream action="replace" target="estimation-card">
    <template>
        {% set fr = (success.lang == 'fr') %}

        <div id="estimation-card" class="max-w-lg mx-auto">
            <div class="rounded-2xl p-2 border border-neutral-200 shadow-lg bg-white">
                <div
                    data-controller="scroll-into-view"
                    class="scroll-mt-6 p-4 lg:p-8 rounded-xl bg-linear-to-b from-neutral-100 to-neutral-100/0"
                    role="status"
                    aria-live="polite"
                >
                    <div class="flex flex-col items-center text-center">
                        <div class="p-3 bg-white inline-block rounded-full shadow-sm">
                            {{ ux_icon('mynaui:check-circle-one', {'class': 'size-7 shrink-0 text-green-600', 'aria-hidden': 'true'}) }}
                        </div>
                        <div class="space-y-1 mt-3 max-w-sm">
                            <h2 class="text-2xl font-semibold text-pretty">
                                {{ 'propertyManagement.form.success.title'|trans|raw }}
                            </h2>
                            <p class="text-slate-600 font-light text-pretty">
                                {{ 'propertyManagement.form.success.text'|trans|raw }}
                            </p>
                        </div>
                    </div>

                    <div class="mt-6 lg:mt-8 rounded-xl border border-gray-100 bg-gray-50 p-4 space-y-4">
                        <p class="text-center text-sm font-medium">
                            {{ 'propertyManagement.form.success.box.advisor'|trans|raw }}
                        </p>

                        <div class="flex flex-col items-center text-center gap-3 rounded-lg bg-white p-4">
                            <img
                                src="{{ asset('medias/team/team_1.webp') }}"
                                alt="{{ 'propertyManagement.form.success.box.altPhoto'|trans|raw }}"
                                width="88" height="88"
                                loading="lazy"
                                class="size-22 rounded-full object-cover outline outline-1 -outline-offset-1 outline-gray-200 ring-2 ring-white"
                            />
                            <div class="space-y-0.5">
                                <p class="font-semibold leading-tight">Julien L.</p>
                                <p class="text-slate-600 text-xs font-light text-pretty">
                                    {{ 'propertyManagement.form.success.box.expertJob'|trans|raw }}
                                </p>
                                <div class="flex items-center justify-center gap-x-1.5 pt-1" aria-label="{{ fr ? 'Langues parlées : français, anglais' : 'Languages spoken: French, English' }}">
                                    {{ ux_icon('circle-flags:lang-fr', {'class': 'size-4 shrink-0 rounded-full', 'aria-hidden': 'true'}) }}
                                    {{ ux_icon('circle-flags:lang-en', {'class': 'size-4 shrink-0 rounded-full', 'aria-hidden': 'true'}) }}
                                </div>
                            </div>
                        </div>

                        <div class="rounded-lg border border-green-100 bg-green-50 p-3 text-center space-y-1">
                            <p class="text-xs text-slate-600">
                                {{ 'propertyManagement.form.success.box.callBack.text'|trans|raw }}
                            </p>
                            <p class="font-semibold text-base text-green-700">
                                {{ 'propertyManagement.form.success.box.callBack.time'|trans|raw }}
                            </p>
                            <p class="text-xs text-slate-500">
                                {{ 'propertyManagement.form.success.box.callBack.info'|trans|raw }}
                            </p>
                        </div>

                        <div class="rounded-lg border border-gray-100 bg-white p-3 text-center space-y-0.5">
                            <p class="text-xs text-slate-600">
                                {{ 'propertyManagement.form.success.box.number.text'|trans|raw }}
                            </p>
                            <p class="font-semibold text-base">{{ success.phoneNumber }}</p>
                        </div>

                        <p class="text-slate-600 text-xs text-pretty flex items-start justify-center gap-2">
                            {{ ux_icon('uiw:information-o', {'class': 'size-3 shrink-0 mt-0.5', 'aria-hidden': 'true'}) }}
                            {{ 'propertyManagement.form.success.goodToKnow.text'|trans|raw }}
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </template>
</turbo-stream>
