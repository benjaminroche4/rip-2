{% extends 'base.html.twig' %}

{% block title %}{{ 'meta.marketplace.title'|trans }}{% endblock %}
{% block description %}{{ 'meta.marketplace.description'|trans }}{% endblock %}
{% block url %}{{ path('app_property') }}{% endblock %}

{% set baseUrl = 'https://relocation-in-paris.fr' %}
{% set pageUrl = baseUrl ~ path('app_property') %}

{% block schema_page %}
    ,{
        "@type": "CollectionPage",
        "@id": "{{ pageUrl }}/#collectionpage",
        "url": "{{ pageUrl }}",
        "name": "{{ 'meta.marketplace.title'|trans|e('js') }}",
        "description": "{{ 'meta.marketplace.description'|trans|e('js') }}",
        "inLanguage": "{{ locale == 'fr' ? 'fr-FR' : 'en-GB' }}",
        "isPartOf": { "@id": "{{ baseUrl }}/#website" },
        "about": { "@id": "{{ baseUrl }}/#organization" },
        "publisher": { "@id": "{{ baseUrl }}/#organization" },
        "primaryImageOfPage": {
            "@type": "ImageObject",
            "url": "{{ baseUrl }}/medias/banner/relocation-in-paris-banner.webp"
        },
        "breadcrumb": { "@id": "{{ pageUrl }}/#breadcrumb" },
        "mainEntity": { "@id": "{{ pageUrl }}/#itemlist" }
    },
    {
        "@type": "BreadcrumbList",
        "@id": "{{ pageUrl }}/#breadcrumb",
        "itemListElement": [
            {
                "@type": "ListItem",
                "position": 1,
                "name": "{{ 'marketplace.list.schema.breadcrumb.home'|trans|e('js') }}",
                "item": "{{ baseUrl }}/{{ locale }}"
            },
            {
                "@type": "ListItem",
                "position": 2,
                "name": "{{ 'marketplace.list.schema.breadcrumb.properties'|trans|e('js') }}",
                "item": "{{ pageUrl }}"
            }
        ]
    },
    {
        "@type": "ItemList",
        "@id": "{{ pageUrl }}/#itemlist",
        "name": "{{ 'marketplace.list.schema.itemlist.name'|trans|e('js') }}",
        "numberOfItems": {{ schemaPropertiesTotal }},
        "itemListOrder": "https://schema.org/ItemListOrderDescending"
        {% if schemaProperties|length > 0 %}
        ,"itemListElement": [
            {% for property in schemaProperties %}
                {
                    "@type": "ListItem",
                    "position": {{ loop.index }},
                    "url": "{{ pageUrl }}#{{ property.slug|default(property._id) }}",
                    "item": {
                        "@type": "Apartment",
                        "@id": "{{ pageUrl }}#{{ property.slug|default(property._id) }}",
                        "name": "{{ ((property.propertyTypeName ?? 'marketplace.list.schema.apartment.fallback'|trans) ~ (property.rooms ? ' ' ~ ('marketplace.list.schema.apartment.rooms'|trans({ '%count%': property.rooms })) : ''))|e('js') }}",
                        "url": "{{ pageUrl }}#{{ property.slug|default(property._id) }}"
                        {% if property.image %}
                        ,"image": "{{ property.image }}?w=1200&h=800&fit=crop&auto=format&q=80"
                        {% endif %}
                        {% if property.rooms %}
                        ,"numberOfRooms": {{ property.rooms }}
                        {% endif %}
                        {% if property.bedrooms %}
                        ,"numberOfBedroomsTotal": {{ property.bedrooms }}
                        {% endif %}
                        {% if property.squareMeters %}
                        ,"floorSize": {
                            "@type": "QuantitativeValue",
                            "value": {{ property.squareMeters }},
                            "unitCode": "MTK"
                        }
                        {% endif %}
                        ,"address": {
                            "@type": "PostalAddress",
                            "addressLocality": "{{ property.address.city|default('Paris')|e('js') }}",
                            "postalCode": "{{ property.address.postalCode|default('')|e('js') }}",
                            "addressRegion": "Île-de-France",
                            "addressCountry": "FR"
                        }
                        {% if property.monthlyRent and not property.priceOnRequest %}
                        ,"offers": {
                            "@type": "Offer",
                            "url": "{{ pageUrl }}#{{ property.slug|default(property._id) }}",
                            "price": {{ property.monthlyRent }},
                            "priceCurrency": "EUR",
                            "priceSpecification": {
                                "@type": "UnitPriceSpecification",
                                "price": {{ property.monthlyRent }},
                                "priceCurrency": "EUR",
                                "referenceQuantity": {
                                    "@type": "QuantitativeValue",
                                    "value": 1,
                                    "unitCode": "MON"
                                }
                            },
                            "availability": "{{ property.status == 'rented' ? 'https://schema.org/SoldOut' : 'https://schema.org/InStock' }}",
                            "seller": { "@id": "{{ baseUrl }}/#organization" }
                        }
                        {% endif %}
                    }
                }{{ not loop.last ? ',' }}
            {% endfor %}
        ]
        {% endif %}
    }
{% endblock %}

{% block body %}
    {{ component('MarketplaceSearch', { locale: locale }) }}
{% endblock %}
