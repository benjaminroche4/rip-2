{% extends 'base.html.twig' %}

{% block title %}{{ 'meta.marketplace.title'|trans|default('Nos biens') }}{% endblock %}
{% block description %}{{ 'meta.marketplace.description'|trans|default('Découvrez tous nos biens immobiliers disponibles à Paris.') }}{% endblock %}
{% block url %}{{ path('app_property') }}{% endblock %}

{% block body %}

    <section class="max-w-7xl mx-auto lg:px-8 px-6 lg:py-16 py-12">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-x-12">
            <div>
                {% if properties is empty %}
                    <div class="text-center py-20 text-neutral-500">
                        <p class="text-lg">{{ 'marketplace.list.empty'|trans|default('Aucun bien disponible pour le moment.') }}</p>
                    </div>
                {% else %}
                    <p class="text-sm text-neutral-500 mb-8">
                        {{ totalCount }} {{ totalCount > 1 ? ('marketplace.list.count_plural'|trans|default('biens')) : ('marketplace.list.count_singular'|trans|default('bien')) }}
                    </p>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        {% for property in properties %}

                            <article class="flex flex-col border border-slate-100 rounded-2xl overflow-hidden bg-white">

                                {# Photo #}
                                <div class="relative overflow-hidden aspect-3/2 bg-slate-100">
                                    {% if property.mainPhoto %}
                                        <img
                                            src="{{ property.mainPhoto }}?w=600&h=400&fit=crop&auto=format&q=80"
                                            alt="{{ property.mainPhotoAlt|default(property.title|default('Bien immobilier')) }}"
                                            loading="lazy"
                                            width="600"
                                            height="400"
                                            class="w-full h-full object-cover"
                                        />
                                    {% else %}
                                        <div class="w-full h-full flex items-center justify-center bg-slate-100">
                                            Housse
                                        </div>
                                    {% endif %}

                                    {# Badges top-left #}
                                    <div class="absolute top-3 left-3 flex flex-wrap gap-1.5">


                                    </div>

                                    {# Photo count badge top-right #}
                                    {% if property.photoCount is defined and property.photoCount > 1 %}
                                        <div class="absolute top-3 right-3">
                                            <twig:Badge variant="secondary" class="gap-x-1">
                                                {{ property.photoCount }}
                                            </twig:Badge>
                                        </div>
                                    {% endif %}

                                    {# Status badge bottom-left #}
                                    {% if property.status is defined %}
                                        <div class="absolute bottom-3 left-3">
                                            {% if property.status == 'available' %}
                                                <twig:Badge variant="destructive">
                                                    <span class="size-1.5 rounded-full bg-green-500 inline-block mr-1"></span>
                                                    {{ 'marketplace.status.available'|trans|default('Disponible') }}
                                                </twig:Badge>
                                            {% elseif property.status == 'under_offer' %}
                                                <twig:Badge variant="destructive">
                                                    <span class="size-1.5 rounded-full bg-amber-500 inline-block mr-1"></span>
                                                    {{ 'marketplace.status.under_offer'|trans|default('Offre en cours') }}
                                                </twig:Badge>
                                            {% elseif property.status == 'rented' %}
                                                <twig:Badge variant="destructive">
                                                    <span class="size-1.5 rounded-full bg-red-500 inline-block mr-1"></span>
                                                    {{ 'marketplace.status.rented'|trans|default('Loué') }}
                                                </twig:Badge>
                                            {% endif %}
                                        </div>
                                    {% endif %}
                                </div>

                                {# Card body #}
                                <div class="p-5 flex flex-col flex-1 space-y-4">

                                    {# Reference & Location #}
                                    <div class="flex items-start justify-between gap-2">
                                        <div>
                                            {% if property.address is defined and property.address %}
                                                <p class="font-semibold text-base text-neutral-900 leading-snug">
                                                    {{ property.address.street ?: property.address.city }}{% if property.address.city and property.address.street %}, {{ property.address.city }}{% endif %}
                                                </p>
                                                {% if property.address.postalCode %}
                                                    <p class="text-sm text-neutral-500">{{ property.address.postalCode }}</p>
                                                {% endif %}
                                            {% elseif property.title %}
                                                <p class="font-semibold text-base text-neutral-900">{{ property.title }}</p>
                                            {% endif %}
                                        </div>
                                        {% if property.uniqueId %}
                                            <span class="text-xs text-neutral-400 shrink-0 mt-0.5">{{ property.uniqueId }}</span>
                                        {% endif %}
                                    </div>

                                    {# Short description #}
                                    {% if property.shortDescription %}
                                        <p class="text-sm text-neutral-600 line-clamp-2">{{ property.shortDescription }}</p>
                                    {% endif %}

                                    {# Key stats #}
                                    <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-neutral-600">
                                        {% if property.surface %}
                                            <span class="flex items-center gap-1">
                                            {{ ux_icon('streamline-ultimate:expand-diagonal', {'class': 'size-3.5 shrink-0 text-neutral-400'}) }}
                                                {{ property.surface }} m²
                                        </span>
                                        {% endif %}
                                        {% if property.rooms %}
                                            <span class="flex items-center gap-1">
                                            {{ ux_icon('streamline-ultimate:door', {'class': 'size-3.5 shrink-0 text-neutral-400'}) }}
                                                {{ property.rooms }} {{ property.rooms > 1 ? ('marketplace.rooms_plural'|trans|default('pièces')) : ('marketplace.room_singular'|trans|default('pièce')) }}
                                        </span>
                                        {% endif %}
                                        {% if property.bedrooms %}
                                            <span class="flex items-center gap-1">
                                            {{ ux_icon('streamline-ultimate:single-bed', {'class': 'size-3.5 shrink-0 text-neutral-400'}) }}
                                                {{ property.bedrooms }} {{ property.bedrooms > 1 ? ('marketplace.bedrooms_plural'|trans|default('ch.')) : ('marketplace.bedroom_singular'|trans|default('ch.')) }}
                                        </span>
                                        {% endif %}
                                    </div>

                                    {# Rental type tags #}
                                    {% set rentalTypes = [] %}
                                    {% if property.longTerm %}{% set rentalTypes = rentalTypes|merge(['marketplace.rental.long_term'|trans|default('Long terme')]) %}{% endif %}
                                    {% if property.midTerm %}{% set rentalTypes = rentalTypes|merge(['marketplace.rental.mid_term'|trans|default('Moyen terme')]) %}{% endif %}
                                    {% if property.shortTerm is defined and property.shortTerm %}{% set rentalTypes = rentalTypes|merge(['marketplace.rental.short_term'|trans|default('Court terme')]) %}{% endif %}
                                    {% if rentalTypes|length > 0 %}
                                        <div class="flex flex-wrap gap-1.5">
                                            {% for type in rentalTypes %}
                                                <twig:Badge variant="secondary">{{ type }}</twig:Badge>
                                            {% endfor %}
                                        </div>
                                    {% endif %}

                                    {# Price #}
                                    <div class="mt-auto pt-3 border-t border-slate-100 flex items-center justify-between">
                                        <div>
                                            {% if property.monthlyRent %}
                                                <p class="text-lg font-semibold text-neutral-900">
                                                    {{ property.monthlyRent|number_format(0, ',', ' ') }}
                                                    {{ property.currency == 'EUR' ? '€' : (property.currency|default('€')) }}
                                                    <span class="text-sm font-normal text-neutral-500">/ {{ 'marketplace.price.per_month'|trans|default('mois') }}</span>
                                                </p>
                                            {% else %}
                                                <p class="text-sm text-neutral-500">{{ 'marketplace.price.on_request'|trans|default('Prix sur demande') }}</p>
                                            {% endif %}
                                        </div>
                                        <span class="font-medium text-primary flex items-center gap-x-1.5 text-sm">
                                        {{ 'marketplace.list.see_more'|trans|default('Voir') }}
                                            {{ ux_icon('streamline-ultimate:arrow-right', {'class': 'size-3 shrink-0'}) }}
                                    </span>
                                    </div>
                                </div>
                            </article>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
            <div class="rounded-3xl p-2 border border-neutral-200" data-controller="map-markers">
                {{ ux_map(map, {style: 'height: 100%;', 'class':'rounded-2xl'}) }}
            </div>
        </div>
    </section>
{% endblock %}
