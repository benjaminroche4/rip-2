{% extends 'base.html.twig' %}

{% block title %}{{ 'meta.marketplace.title'|trans|default('Nos biens') }}{% endblock %}
{% block description %}{{ 'meta.marketplace.description'|trans|default('Découvrez tous nos biens immobiliers disponibles à Paris.') }}{% endblock %}
{% block url %}{{ path('app_property') }}{% endblock %}

{% block body %}

    <section class="max-w-7xl mx-auto lg:px-8 px-6 lg:py-16 py-12">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-x-12">
            <div>
                {% if properties is empty %}
                    <div class="text-center py-20 text-neutral-500">
                        <p class="text-lg">{{ 'marketplace.list.empty'|trans|default('Aucun bien disponible pour le moment.') }}</p>
                    </div>
                {% else %}
                    <p class="text-sm text-neutral-500 mb-8">
                        {{ totalCount }} {{ totalCount > 1 ? ('marketplace.list.count_plural'|trans|default('biens')) : ('marketplace.list.count_singular'|trans|default('bien')) }}
                    </p>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        {% for property in properties %}
                            <article class="flex flex-col border border-slate-200 rounded-2xl bg-white p-1.5">
                                <div class="relative aspect-3/2 border border-slate-100 rounded-xl bg-slate-50">
                                    <img
                                        src="{{ property.mainPhoto }}?w=600&h=400&fit=crop&auto=format&q=80"
                                        alt="{{ property.mainPhotoAlt|default(property.title|default('Bien immobilier')) }}"
                                        loading="lazy"
                                        width="600"
                                        height="400"
                                        class="w-full h-full object-cover rounded-xl">
                                </div>

                                <div class="px-2 py-3 flex flex-col flex-1 space-y-4">
                                    <div class="space-y-1">
                                        <div>
                                            <p class="text-primary text-xl font-semibold">1 149€<span class="text-gray-600 text-sm font-light ml-1">/mois CC</span></p>
                                        </div>
                                        <h3 class="font-semibold">Appartement 4 pièces</h3>
                                        <div>
                                            <address class="not-italic text-gray-500 text-sm flex items-center gap-x-1">
                                                {{ ux_icon('gg:pin', {'class': 'size-4 shrink-0'}) }}
                                                Paris, 16è arrondissement
                                            </address>
                                        </div>
                                    </div>
                                    <div class="bg-neutral-50 rounded-xl p-2 grid grid-cols-3 divide-x divide-gray-200">
                                        <div class="flex items-center justify-center gap-x-1">
                                            {{ ux_icon('iconoir:elevator', {'class': 'size-5 text-gray-800 shrink-0'}) }}
                                            <p class="text-sm font-light">Yes</p>
                                        </div>
                                        <div class="flex items-center justify-center gap-x-1">
                                            {{ ux_icon('ic:outline-bed', {'class': 'size-5 text-gray-800 shrink-0'}) }}
                                            <p class="text-sm font-light">Studio</p>
                                        </div>
                                        <div class="flex items-center justify-center gap-x-1">
                                            {{ ux_icon('wordpress:square', {'class': 'size-5 text-gray-800 shrink-0'}) }}
                                            <p class="text-sm font-light">102 m²</p>
                                        </div>
                                    </div>
                                </div>
                            </article>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
            <aside class="rounded-3xl p-2 border border-neutral-200" data-controller="map-markers map-restriction">
                {{ ux_map(map, {style: 'height: 100%;', 'class':'rounded-2xl'}) }}
            </aside>
        </div>
    </section>
{% endblock %}
