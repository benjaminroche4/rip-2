{% extends 'base.html.twig' %}

{% block title %}{{ property.title }}{% endblock %}
{% block description %}{{ property.shortDescription|default(property.title) }}{% endblock %}
{% block url %}{{ property_show_path(property, locale) }}{% endblock %}

{% set baseUrl = 'https://relocation-in-paris.fr' %}
{% set pageUrl = baseUrl ~ property_show_path(property, locale) %}

{% block og_image %}{{ property.mainPhoto.url is defined and property.mainPhoto.url ? property.mainPhoto.url ~ '?w=1200&h=630&fit=crop&auto=format&fm=webp&q=80' : asset('medias/banner/relocation-in-paris-banner.webp') }}{% endblock %}

{% block schema_page %}
    ,{
        "@type": "Apartment",
        "@id": "{{ pageUrl }}/#property",
        "url": "{{ pageUrl }}",
        "name": "{{ property.title|e('js') }}",
        "description": "{{ (property.shortDescription|default(property.title))|e('js') }}",
        "inLanguage": "{{ locale == 'fr' ? 'fr-FR' : 'en-GB' }}",
        "isPartOf": { "@id": "{{ baseUrl }}/#website" }
        {% if property.mainPhoto.url is defined and property.mainPhoto.url %}
        ,"image": "{{ property.mainPhoto.url }}?w=1200&h=800&fit=crop&auto=format&fm=webp&q=80"
        {% endif %}
        {% if property.rooms %}
        ,"numberOfRooms": {{ property.rooms }}
        {% endif %}
        {% if property.bedrooms %}
        ,"numberOfBedrooms": {{ property.bedrooms }}
        {% endif %}
        {% if property.squareMeters %}
        ,"floorSize": {
            "@type": "QuantitativeValue",
            "value": {{ property.squareMeters }},
            "unitCode": "MTK"
        }
        {% endif %}
        ,"address": {
            "@type": "PostalAddress",
            "streetAddress": "{{ (property.address.street|default(''))|e('js') }}",
            "addressLocality": "{{ (property.address.city|default('Paris'))|e('js') }}",
            "postalCode": "{{ (property.address.postalCode|default(''))|e('js') }}",
            "addressRegion": "Île-de-France",
            "addressCountry": "FR"
        }
        {% if property.monthlyRent and not property.priceOnRequest|default(false) %}
        ,"offers": {
            "@type": "Offer",
            "url": "{{ pageUrl }}",
            "price": {{ property.monthlyRent }},
            "priceCurrency": "EUR",
            "priceSpecification": {
                "@type": "UnitPriceSpecification",
                "price": {{ property.monthlyRent }},
                "priceCurrency": "EUR",
                "referenceQuantity": {
                    "@type": "QuantitativeValue",
                    "value": 1,
                    "unitCode": "MON"
                }
            },
            "availability": "{{ property.status == 'rented' ? 'https://schema.org/SoldOut' : 'https://schema.org/InStock' }}",
            "seller": { "@id": "{{ baseUrl }}/#organization" }
        }
        {% endif %}
    },
    {
        "@type": "BreadcrumbList",
        "@id": "{{ pageUrl }}/#breadcrumb",
        "itemListElement": [
            {
                "@type": "ListItem",
                "position": 1,
                "name": "{{ 'marketplace.list.schema.breadcrumb.home'|trans|e('js') }}",
                "item": "{{ baseUrl }}/{{ locale }}"
            },
            {
                "@type": "ListItem",
                "position": 2,
                "name": "{{ 'marketplace.list.schema.breadcrumb.properties'|trans|e('js') }}",
                "item": "{{ baseUrl }}{{ path('app_property') }}"
            },
            {
                "@type": "ListItem",
                "position": 3,
                "name": "{{ property.title|e('js') }}",
                "item": "{{ pageUrl }}"
            }
        ]
    }
{% endblock %}

{% block body %}
    <section class="max-w-7xl mx-auto lg:px-8 px-6 lg:pb-16 pb-10 lg:pt-8 pt-6">
        <twig:Breadcrumb class="mb-8">
            <twig:Breadcrumb:List>
                <twig:Breadcrumb:Item>
                    <twig:Breadcrumb:Link href="{{ path('app_property') }}">
                        {{ 'marketplace.list.schema.breadcrumb.properties'|trans }}
                    </twig:Breadcrumb:Link>
                </twig:Breadcrumb:Item>
                <twig:Breadcrumb:Separator />
                <twig:Breadcrumb:Item>
                    {{ property.listingTypeName|default(locale == 'fr' ? 'Location' : 'Rental') }}
                </twig:Breadcrumb:Item>
                <twig:Breadcrumb:Separator />
                <twig:Breadcrumb:Item>
                    {{ property.propertyTypeName|default(locale == 'fr' ? 'Bien' : 'Property') }}
                </twig:Breadcrumb:Item>
                <twig:Breadcrumb:Separator />
                <twig:Breadcrumb:Item>
                    {{ property.address.city }}
                </twig:Breadcrumb:Item>
                <twig:Breadcrumb:Separator />
                <twig:Breadcrumb:Item>
                    <twig:Breadcrumb:Link href="{{ path('app_property') }}">
                        {{ property.address.postalCode|arrondissement(locale) }}
                    </twig:Breadcrumb:Link>
                </twig:Breadcrumb:Item>
                <twig:Breadcrumb:Separator />
                <twig:Breadcrumb:Item>
                    <twig:Breadcrumb:Page>{{ property.title }}</twig:Breadcrumb:Page>
                </twig:Breadcrumb:Item>
            </twig:Breadcrumb:List>
        </twig:Breadcrumb>
        {% set gridPhotos = [] %}
        {% set galleryPhotos = [] %}
        {% if property.mainPhoto.url is defined and property.mainPhoto.url %}
            {% set gridPhotos = gridPhotos|merge([property.mainPhoto]) %}
            {% set galleryPhotos = galleryPhotos|merge([property.mainPhoto]) %}
        {% endif %}
        {% for photo in property.photos|default([]) %}
            {% if photo.url and photo.url != property.mainPhoto.url|default('') %}
                {% if gridPhotos|length < 4 %}
                    {% set gridPhotos = gridPhotos|merge([photo]) %}
                {% endif %}
                {% set galleryPhotos = galleryPhotos|merge([photo]) %}
            {% endif %}
        {% endfor %}

        <section
            class="bg-neutral-50 rounded-2xl p-2"
            data-controller="gallery"
            data-gallery-photos-value="{{ galleryPhotos|map(p => {url: p.url, alt: p.alt|default(property.title)})|json_encode|e('html_attr') }}"
        >
            <div class="grid grid-cols-8 gap-3">
                <div class="col-span-3">
                    {% if gridPhotos[0] is defined %}
                        <button type="button" data-action="gallery#open" data-gallery-index-param="0" class="relative w-full h-full cursor-pointer focus-visible:ring-2 focus-visible:ring-primary/50 focus-visible:outline-none focus-visible:rounded-xl after:absolute after:inset-0 after:rounded-xl after:bg-black/0 hover:after:bg-black/20 after:transition after:duration-100">
                            <img
                                src="{{ gridPhotos[0].url }}?w=900&h=600&fit=crop&auto=format&fm=webp&q=80"
                                srcset="{{ gridPhotos[0].url }}?w=600&h=400&fit=crop&auto=format&fm=webp&q=80 600w,
                                        {{ gridPhotos[0].url }}?w=900&h=600&fit=crop&auto=format&fm=webp&q=80 900w,
                                        {{ gridPhotos[0].url }}?w=1200&h=800&fit=crop&auto=format&fm=webp&q=80 1200w"
                                sizes="(max-width: 1024px) 100vw, 37.5vw"
                                alt="{{ gridPhotos[0].alt|default(property.title) }}"
                                width="900"
                                height="600"
                                draggable="false"
                                class="w-full h-full object-cover rounded-xl"
                            />
                        </button>
                    {% endif %}
                </div>
                <div class="col-span-2 flex flex-col gap-3">
                    {% if gridPhotos[1] is defined %}
                        <button type="button" data-action="gallery#open" data-gallery-index-param="1" class="relative flex-1 min-h-0 w-full cursor-pointer focus-visible:ring-2 focus-visible:ring-primary/50 focus-visible:outline-none focus-visible:rounded-xl after:absolute after:inset-0 after:rounded-xl after:bg-black/0 hover:after:bg-black/20 after:transition after:duration-100">
                            <img
                                src="{{ gridPhotos[1].url }}?w=600&h=400&fit=crop&auto=format&fm=webp&q=80"
                                srcset="{{ gridPhotos[1].url }}?w=400&h=267&fit=crop&auto=format&fm=webp&q=80 400w,
                                        {{ gridPhotos[1].url }}?w=600&h=400&fit=crop&auto=format&fm=webp&q=80 600w"
                                sizes="(max-width: 1024px) 50vw, 25vw"
                                alt="{{ gridPhotos[1].alt|default(property.title) }}"
                                width="600"
                                height="400"
                                loading="lazy"
                                decoding="async"
                                draggable="false"
                                class="w-full h-full rounded-xl object-cover"
                            />
                        </button>
                    {% endif %}
                    {% if gridPhotos[2] is defined %}
                        <button type="button" data-action="gallery#open" data-gallery-index-param="2" class="relative flex-1 min-h-0 w-full cursor-pointer focus-visible:ring-2 focus-visible:ring-primary/50 focus-visible:outline-none focus-visible:rounded-xl after:absolute after:inset-0 after:rounded-xl after:bg-black/0 hover:after:bg-black/20 after:transition after:duration-100">
                            <img
                                src="{{ gridPhotos[2].url }}?w=600&h=400&fit=crop&auto=format&fm=webp&q=80"
                                srcset="{{ gridPhotos[2].url }}?w=400&h=267&fit=crop&auto=format&fm=webp&q=80 400w,
                                        {{ gridPhotos[2].url }}?w=600&h=400&fit=crop&auto=format&fm=webp&q=80 600w"
                                sizes="(max-width: 1024px) 50vw, 25vw"
                                alt="{{ gridPhotos[2].alt|default(property.title) }}"
                                width="600"
                                height="400"
                                loading="lazy"
                                decoding="async"
                                draggable="false"
                                class="w-full h-full rounded-xl object-cover"
                            />
                        </button>
                    {% endif %}
                </div>
                <div class="col-span-3 relative">
                    {% if gridPhotos[3] is defined %}
                        <button type="button" data-action="gallery#open" data-gallery-index-param="3" class="relative w-full h-full cursor-pointer focus-visible:ring-2 focus-visible:ring-primary/50 focus-visible:outline-none focus-visible:rounded-xl after:absolute after:inset-0 after:rounded-xl after:bg-black/0 hover:after:bg-black/20 after:transition after:duration-100">
                            <img
                                src="{{ gridPhotos[3].url }}?w=900&h=600&fit=crop&auto=format&fm=webp&q=80"
                                srcset="{{ gridPhotos[3].url }}?w=600&h=400&fit=crop&auto=format&fm=webp&q=80 600w,
                                        {{ gridPhotos[3].url }}?w=900&h=600&fit=crop&auto=format&fm=webp&q=80 900w,
                                        {{ gridPhotos[3].url }}?w=1200&h=800&fit=crop&auto=format&fm=webp&q=80 1200w"
                                sizes="(max-width: 1024px) 100vw, 37.5vw"
                                alt="{{ gridPhotos[3].alt|default(property.title) }}"
                                width="900"
                                height="600"
                                loading="lazy"
                                decoding="async"
                                draggable="false"
                                class="w-full h-full object-cover rounded-xl"
                            />
                        </button>
                    {% endif %}
                    <twig:Button variant="secondary" size="sm" class="absolute bottom-3 right-3 z-10" data-action="gallery#open" data-gallery-index-param="0">
                        {{ ux_icon('iconoir:view-grid') }}
                        Show all photos ({{ galleryPhotos|length }})
                    </twig:Button>
                </div>
            </div>

            {# Gallery dialog #}
            <dialog
                data-gallery-target="dialog"
                data-action="click->gallery#closeOnClickOutside"
                class="fixed inset-0 z-50 m-0 h-full w-full max-h-full max-w-full bg-black/95 backdrop:bg-transparent open:flex open:items-center open:justify-center"
            >
                <div class="relative flex items-center justify-center w-full h-full px-4 py-12">
                    {# Close #}
                    <button
                        type="button"
                        data-action="gallery#close"
                        class="absolute top-4 right-4 z-10 size-10 flex items-center justify-center rounded-full bg-white/10 hover:bg-white/20 text-white transition duration-100 cursor-pointer focus-visible:ring-2 focus-visible:ring-primary/50 focus-visible:outline-none"
                    >
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="size-6"><path d="M6 18 18 6M6 6l12 12" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </button>

                    {# Prev #}
                    <button
                        type="button"
                        data-action="gallery#prev"
                        class="absolute left-4 z-10 size-10 flex items-center justify-center rounded-full bg-white/10 hover:bg-white/20 text-white transition duration-100 cursor-pointer focus-visible:ring-2 focus-visible:ring-primary/50 focus-visible:outline-none"
                    >
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-5"><path d="m15 18-6-6 6-6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </button>

                    {# Image #}
                    <div class="flex flex-col items-center gap-6 max-h-full w-full">
                        <img
                            data-gallery-target="image"
                            src=""
                            alt=""
                            draggable="false"
                            style="touch-action: none"
                            class="max-h-[calc(100vh-14rem)] max-w-full object-contain select-none rounded-lg transition-all duration-300 ease-out cursor-grab"
                        />

                        {# Thumbnails #}
                        <div class="w-full max-w-4xl px-4">
                            <div class="flex flex-col items-center gap-2">
                                <span
                                    data-gallery-target="counter"
                                    class="text-white/50 text-xs font-medium"
                                ></span>
                                <div
                                    data-gallery-target="thumbnails"
                                    class="flex flex-nowrap gap-2 p-1 scroll-p-1 w-full overflow-x-auto scrollbar-hide scroll-smooth"
                                ></div>
                            </div>
                        </div>
                    </div>

                    {# Next #}
                    <button
                        type="button"
                        data-action="gallery#next"
                        class="absolute right-4 z-10 size-10 flex items-center justify-center rounded-full bg-white/10 hover:bg-white/20 text-white transition duration-100 cursor-pointer focus-visible:ring-2 focus-visible:ring-primary/50 focus-visible:outline-none"
                    >
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-5"><path d="m9 18 6-6-6-6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </button>
                </div>
            </dialog>
        </section>

        <section class="pt-8">
            <div class="grid grid-cols-8 gap-12">
                <div class="col-span-5 lg:space-y-15 space-y-10">
                    <div class="space-y-8">
                        <div class="space-y-4">
                            <h1 class="text-2xl lg:text-3xl font-semibold font-secondary text-pretty">{{ property.title }}</h1>
                            <div class="flex items-center divide-x divide-gray-200">
                                <div class="pr-4">
                                    <p class="text-gray-500 flex items-center gap-x-1">
                                        {{ ux_icon('gg:pin', {'class': 'size-4 shrink-0'}) }}
                                        {% if property.address.street is defined and property.address.street %}
                                            {{ property.address.street }},
                                        {% endif %}
                                        {{ property.address.city }}, {{ property.address.postalCode|arrondissement(locale) }}
                                    </p>
                                </div>
                                {% if (property.metro is defined and property.metro is not empty) or (property.rer is defined and property.rer is not empty) %}
                                    <div class="flex items-center gap-4 pl-4">
                                        {% if property.metro is defined and property.metro is not empty %}
                                            <div class="flex items-center gap-2">
                                                <div class="flex -space-x-1 overflow-hidden">
                                                    {% for line in property.metro %}
                                                        <twig:Transport:Line :line="line" class="ring-2 ring-white" />
                                                    {% endfor %}
                                                </div>
                                            </div>
                                        {% endif %}
                                        {% if property.rer is defined and property.rer is not empty %}
                                            <div class="flex items-center gap-2">
                                                <div class="flex -space-x-1 overflow-hidden">
                                                    {% for line in property.rer %}
                                                        <twig:Transport:Line :line="line" class="ring-2 ring-white" />
                                                    {% endfor %}
                                                </div>
                                            </div>
                                        {% endif %}
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                        <div class="rounded-2xl py-3 px-5 bg-neutral-50">
                            <div class="grid grid-cols-3 divide-x divide-gray-200">
                                <div class="pr-6 space-y-2">
                                    <p class="font-light text-neutral-600 text-sm">Bedroom</p>
                                    <div class="flex items-center gap-2">
                                        {{ ux_icon('fluent:bed-24-regular', {'class':'size-7 text-gray-800', 'aria-hidden':'true'}) }}
                                        <p>3</p>
                                    </div>
                                </div>
                                <div class="px-6 space-y-2">
                                    <p class="font-light text-neutral-600 text-sm">Meublé</p>
                                    <div class="flex items-center gap-2">
                                        {{ ux_icon('iconoir:sofa', {'class':'size-7 text-gray-800', 'aria-hidden':'true'}) }}
                                        <p>Oui</p>
                                    </div>
                                </div>
                                <div class="pl-6 space-y-2">
                                    <p class="font-light text-neutral-600 text-sm">Surface</p>
                                    <div class="flex items-center gap-2">
                                        {{ ux_icon('wordpress:square', {'class':'size-7 text-gray-800', 'aria-hidden':'true'}) }}
                                        <p>125 m²</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    {% if property.description is defined and property.description is not empty %}
                        <div class="space-y-3" data-controller="expandable">
                            <h3 class="font-semibold font-secondary">{{ locale == 'fr' ? 'Description' : 'Description' }}</h3>
                            <div data-expandable-target="content" class="prose prose-sm max-w-none text-gray-600 line-clamp-6">
                                {{ property.description|sanity_to_html }}
                            </div>
                            <button
                                type="button"
                                data-action="expandable#expand"
                                data-expandable-target="trigger"
                                class="font-semibold text-gray-900 cursor-pointer hover:underline underline-offset-4"
                            >
                                ... {{ locale == 'fr' ? 'Voir plus' : 'Show more' }}
                            </button>
                        </div>
                    {% endif %}
                    {% if property.equipment is defined and property.equipment is not empty %}
                        {% set equipmentMap = {
                            wifi: { icon: 'boxicons:wifi', label: 'Wi-Fi' },
                            airConditioning: { icon: 'iconoir:snow-flake', label: (locale == 'fr' ? 'Climatisation' : 'Air conditioning') },
                            balcony: { icon: 'mdi:balcony', label: (locale == 'fr' ? 'Balcon' : 'Balcony') },
                            concierge: { icon: 'iconoir:bell', label: (locale == 'fr' ? 'Concierge' : 'Concierge') },
                            dishwasher: { icon: 'material-symbols:dishwasher-gen-outline-sharp', label: (locale == 'fr' ? 'Lave-vaisselle' : 'Dishwasher') },
                            dryer: { icon: 'boxicons:dryer', label: (locale == 'fr' ? 'Sèche-linge' : 'Dryer') },
                            elevator: { icon: 'iconoir:elevator', label: (locale == 'fr' ? 'Ascenseur' : 'Elevator') },
                            intercom: { icon: 'iconoir:phone', label: (locale == 'fr' ? 'Interphone' : 'Intercom') },
                            microwave: { icon: 'mdi:microwave', label: (locale == 'fr' ? 'Micro-ondes' : 'Microwave') },
                            parking: { icon: 'iconoir:parking', label: (locale == 'fr' ? 'Parking' : 'Parking') },
                            television: { icon: 'iconoir:tv', label: (locale == 'fr' ? 'Télévision' : 'Television') },
                            washingMachine: { icon: 'iconoir:washing-machine', label: (locale == 'fr' ? 'Lave-linge' : 'Washing machine') },
                        } %}
                        <div class="space-y-5">
                            <h3 class="font-semibold font-secondary">{{ locale == 'fr' ? 'Ce que ce bien offre' : 'What this property offers' }}</h3>
                            <div class="grid grid-cols-2 lg:grid-cols-3 gap-6">
                                {% for key, info in equipmentMap %}
                                    {% if property.equipment[key]|default(false) %}
                                        <div class="flex items-center gap-2">
                                            {{ ux_icon(info.icon, {'class':'size-5 text-primary', 'aria-hidden':'true'}) }}
                                            <p>{{ info.label }}</p>
                                        </div>
                                    {% endif %}
                                {% endfor %}
                            </div>
                        </div>
                    {% endif %}
                </div>


                <div class="bg-neutral-50 col-span-3 rounded-2xl p-4">
                    <div>
                        <p class="text-2xl font-semibold text-primary">1200<span class="text-gray-900 font-light text-sm">/mois</span></p>
                    </div>
                </div>
            </div>
        </section>

{% endblock %}
