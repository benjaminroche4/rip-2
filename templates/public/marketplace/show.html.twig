{% extends 'public/base.html.twig' %}

{% set baseUrl = site_url %}
{% set pageUrl = baseUrl ~ property_show_path(property, locale) %}

{# SEO title generated by PropertyUrlExtension — reused in sitemap + JSON-LD for consistency #}
{% set _seoTitle = property_display_title(property, locale) %}

{% block title %}{{ _seoTitle }}{% endblock %}
{% block description %}{{ property.metaDescription }}{% endblock %}
{% block url %}{{ property_show_path(property, locale) }}{% endblock %}

{# noindex for rented properties so old listings don't pollute the index #}
{% block meta_robots %}
    {% if property.status == 'rented' %}
        <meta name="robots" content="noindex, follow">
    {% else %}
        <meta name="robots" content="index, follow">
    {% endif %}
{% endblock %}

{# Preload the above-the-fold main photo to improve LCP #}
{% block head_preload %}
    {% if property.mainPhoto.url is defined and property.mainPhoto.url %}
        <link rel="preload" as="image"
              href="{{ property.mainPhoto.url }}?w=900&h=900&fit=crop&auto=format&fm=webp&q=80"
              imagesrcset="{{ property.mainPhoto.url }}?w=600&h=600&fit=crop&auto=format&fm=webp&q=80 600w,
                           {{ property.mainPhoto.url }}?w=900&h=900&fit=crop&auto=format&fm=webp&q=80 900w,
                           {{ property.mainPhoto.url }}?w=1200&h=1200&fit=crop&auto=format&fm=webp&q=80 1200w"
              imagesizes="(max-width: 1024px) 100vw, 48rem"
              fetchpriority="high">
    {% endif %}
{% endblock %}

{% block og_image %}{{ property.mainPhoto.url is defined and property.mainPhoto.url ? property.mainPhoto.url ~ '?w=1200&h=630&fit=crop&auto=format&fm=webp&q=80' : asset('medias/banner/relocation-in-paris-banner.webp') }}{% endblock %}

{# Hreflang: use alternate property's actual URL since slugs differ per locale #}
{% block hreflang %}
    {% set _frParams = locale == 'fr' ? property_show_path_params(property, 'fr') : (property.alternateProperty ? property_show_path_params(property.alternateProperty, 'fr') : property_show_path_params(property, 'fr')) %}
    {% set _enParams = locale == 'en' ? property_show_path_params(property, 'en') : (property.alternateProperty ? property_show_path_params(property.alternateProperty, 'en') : property_show_path_params(property, 'en')) %}
    <link rel="alternate" hreflang="fr" href="{{ url('app_property_show', _frParams) }}" />
    <link rel="alternate" hreflang="en" href="{{ url('app_property_show', _enParams) }}" />
    <link rel="alternate" hreflang="x-default" href="{{ url('app_property_show', _frParams) }}" />
{% endblock %}

{% block schema_page %}
    {% include '_partials/schema/property.html.twig' with {
        property: property,
        locale: locale,
        pageUrl: pageUrl,
        baseUrl: baseUrl,
        seoTitle: _seoTitle,
    } only %}
{% endblock %}

{% block body %}
    <div
        data-controller="mobile-sheet"
        data-mobile-sheet-open-class="max-lg:!translate-y-0 max-lg:!opacity-100 max-lg:!pointer-events-auto"
    >
    <section class="max-w-7xl mx-auto lg:px-8 px-6 lg:pb-16 pb-24 lg:pt-8 pt-6">
        {# Mobile: compact back link (the full breadcrumb is hard to use on narrow screens) #}
        <div class="lg:hidden mb-3">
            <a href="{{ path('app_property') }}" class="inline-flex items-center gap-x-1 text-sm text-neutral-600 hover:text-primary transition duration-100">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" class="size-4"><path d="m15 18-6-6 6-6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                {{ 'marketplace.list.schema.breadcrumb.properties'|trans }}
            </a>
        </div>

        {# Desktop: full breadcrumb — keeps all SEO signals and rich context #}
        <twig:Breadcrumb class="hidden lg:block mb-8">
            <twig:Breadcrumb:List>
                <twig:Breadcrumb:Item>
                    <twig:Breadcrumb:Link href="{{ path('app_property') }}">
                        {{ 'marketplace.list.schema.breadcrumb.properties'|trans }}
                    </twig:Breadcrumb:Link>
                </twig:Breadcrumb:Item>
                <twig:Breadcrumb:Separator />
                <twig:Breadcrumb:Item>
                    {{ property.listingTypeName|default('marketplace.show.breadcrumb.listing'|trans) }}
                </twig:Breadcrumb:Item>
                <twig:Breadcrumb:Separator />
                <twig:Breadcrumb:Item>
                    {{ property.propertyTypeName|default('marketplace.show.breadcrumb.property'|trans) }}
                </twig:Breadcrumb:Item>
                <twig:Breadcrumb:Separator />
                <twig:Breadcrumb:Item>
                    {{ property.address.city }}
                </twig:Breadcrumb:Item>
                <twig:Breadcrumb:Separator />
                <twig:Breadcrumb:Item>
                    <twig:Breadcrumb:Link href="{{ path('app_property') }}">
                        {{ property.address.postalCode|arrondissement(locale) }}
                    </twig:Breadcrumb:Link>
                </twig:Breadcrumb:Item>
                <twig:Breadcrumb:Separator />
                <twig:Breadcrumb:Item>
                    <twig:Breadcrumb:Page>{{ property.title }}</twig:Breadcrumb:Page>
                </twig:Breadcrumb:Item>
            </twig:Breadcrumb:List>
        </twig:Breadcrumb>
        <article itemscope itemtype="https://schema.org/Apartment">
        <twig:Marketplace:PropertyGallery :property="property" :locale="locale" />

        <section class="pt-6 lg:pt-8">
            <div class="grid lg:grid-cols-8 gap-8 lg:gap-12">
                <div class="lg:col-span-5 min-w-0 lg:space-y-15 space-y-10">
                    <div class="space-y-8">
                        {% if is_granted('ROLE_ADMIN') %}
                        <div class="rounded-2xl p-4 bg-neutral-50" data-controller="collapsible" data-collapsible-open-value="true">
                            <button type="button" data-action="collapsible#toggle" class="w-full flex items-center justify-between cursor-pointer select-none">
                                <span class="font-secondary flex items-center gap-x-2">
                                    {{ ux_icon('eos-icons:admin-outlined', {'class': 'size-5 shrink-0'}) }}
                                    {{ 'marketplace.show.admin.title'|trans }}
                                </span>
                                <span class="bg-white rounded-full p-2 shrink-0">
                                    <svg data-collapsible-target="chevron" class="w-4 h-4 transition-transform duration-300 ease-in-out" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
                                </span>
                            </button>
                            <div data-collapsible-target="content">
                                <div class="rounded-2xl border border-slate-200 divide-y divide-gray-200 mt-3">
                                    <div class="grid sm:grid-cols-2 divide-y sm:divide-y-0 sm:divide-x divide-gray-200">
                                        <div class="p-4 space-y-2">
                                            <p class="font-light text-neutral-600 text-sm">{{ 'marketplace.show.admin.publishedOn'|trans }}</p>
                                            <p class="text-sm">{{ property.createdAt ? property.createdAt|format_datetime('long', 'short', locale: locale) : '—' }}</p>
                                        </div>
                                        <div class="p-4 space-y-2">
                                            <p class="font-light text-neutral-600 text-sm">{{ 'marketplace.show.admin.lastUpdated'|trans }}</p>
                                            <p class="text-sm">{{ property.updatedAt ? property.updatedAt|format_datetime('long', 'short', locale: locale) : '—' }}</p>
                                        </div>
                                    </div>
                                    {% if property.internalNotes is defined and property.internalNotes %}
                                        <div class="p-4 space-y-2">
                                            <p class="font-light text-neutral-600 text-sm">{{ 'marketplace.show.admin.internalNote'|trans }}</p>
                                            <p class="text-sm">{{ property.internalNotes }}</p>
                                        </div>
                                    {% endif %}
                                    {% if property.tenant is defined and property.tenant %}
                                        {% set tenant = property.tenant %}
                                        {% set isPro = tenant.tenantType == 'professional' %}
                                        <div class="p-4 space-y-3">
                                            <p class="font-light text-neutral-600 text-sm">
                                                {{ 'marketplace.show.admin.tenantLabel'|trans }}
                                            </p>
                                            <div class="grid sm:grid-cols-2 gap-4">
                                                <div class="flex items-start gap-x-3">
                                                    {% if isPro and tenant.logo %}
                                                        <img
                                                            src="{{ tenant.logo }}?w=96&h=96&fit=crop&auto=format&fm=webp&q=75"
                                                            alt="{{ tenant.logoAlt|default(tenant.companyName|default(tenant.fullName)) }}"
                                                            width="48"
                                                            height="48"
                                                            class="size-10 rounded-full object-cover bg-neutral-100 shrink-0"
                                                            loading="lazy"
                                                        >
                                                    {% endif %}
                                                    <div class="space-y-0.5 flex flex-col text-sm min-w-0">
                                                        <p class="text-neutral-600">
                                                            {{ isPro ? 'marketplace.show.admin.professional'|trans : 'marketplace.show.admin.individual'|trans }}
                                                        </p>
                                                        {% if isPro and tenant.companyName %}
                                                            <p class="break-words">{{ tenant.companyName }}</p>
                                                            {% if tenant.fullName %}
                                                                <p class="break-words">{{ tenant.fullName }}</p>
                                                            {% endif %}
                                                        {% elseif tenant.fullName %}
                                                            <p class="break-words">{{ tenant.fullName }}</p>
                                                        {% endif %}
                                                    </div>
                                                </div>
                                                <div class="space-y-1 text-sm min-w-0 sm:pl-6 sm:border-l sm:border-gray-200">
                                                    {% if tenant.email %}
                                                        <p>
                                                            <a href="mailto:{{ tenant.email }}" class="hover:underline">{{ tenant.email }}</a>
                                                        </p>
                                                    {% endif %}
                                                    {% if tenant.phone %}
                                                        <p>
                                                            <a href="tel:{{ tenant.phone|replace({' ': '', '.': '', '-': ''}) }}" class="hover:underline">{{ tenant.phone }}</a>
                                                        </p>
                                                    {% endif %}
                                                    {% if isPro and tenant.website %}
                                                        <p>
                                                            <a href="{{ tenant.website }}" target="_blank" rel="noopener noreferrer" class="hover:underline break-all">{{ tenant.website|replace({'https://': '', 'http://': ''})|trim('/') }}</a>
                                                        </p>
                                                    {% endif %}
                                                </div>
                                            </div>
                                        </div>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                        {% endif %}
                        <div class="space-y-4">
                            <h1 class="text-2xl lg:text-3xl font-semibold font-secondary text-pretty">{{ property.title }}</h1>
                            <div class="flex flex-wrap items-center gap-y-2 sm:divide-x sm:divide-gray-200">
                                <div class="sm:pr-4 w-full sm:w-auto">
                                    <p class="text-gray-500 flex items-start gap-x-1">
                                        {{ ux_icon('gg:pin', {'class': 'size-4 shrink-0 mt-1'}) }}
                                        <span class="text-pretty break-words min-w-0">
                                            {% if property.address.street is defined and property.address.street %}
                                                {{ property.address.street }},
                                            {% endif %}
                                            {{ property.address.city }}, {{ property.address.postalCode|arrondissement(locale) }}
                                        </span>
                                    </p>
                                </div>
                                {% if (property.metro is defined and property.metro is not empty) or (property.rer is defined and property.rer is not empty) %}
                                    <div class="flex items-center gap-4 sm:pl-4">
                                        {% if property.metro is defined and property.metro is not empty %}
                                            <div class="flex items-center gap-2">
                                                <div class="flex -space-x-1 overflow-hidden">
                                                    {% for line in property.metro %}
                                                        <twig:Transport:Line :line="line" class="ring-2 ring-white" />
                                                    {% endfor %}
                                                </div>
                                            </div>
                                        {% endif %}
                                        {% if property.rer is defined and property.rer is not empty %}
                                            <div class="flex items-center gap-2">
                                                <div class="flex -space-x-1 overflow-hidden">
                                                    {% for line in property.rer %}
                                                        <twig:Transport:Line :line="line" class="ring-2 ring-white" />
                                                    {% endfor %}
                                                </div>
                                            </div>
                                        {% endif %}
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                        <div class="rounded-2xl py-3 md:py-3 px-4 sm:px-5 bg-neutral-50">
                            <div class="grid md:grid-cols-3 divide-y md:divide-y-0 md:divide-x divide-gray-200">
                                <div class="py-4 md:py-0 md:pr-6 space-y-2">
                                    <p class="font-light text-neutral-600 text-sm">{{ 'marketplace.show.propertyKey.bedrooms'|trans }}</p>
                                    <div class="flex items-center gap-2">
                                        {{ ux_icon('fluent:bed-24-regular', {'class':'size-7 text-gray-800', 'aria-hidden':'true'}) }}
                                        <p class="capitalize">{{ property.bedroomsLabel|default(property.bedrooms|default('-')) }}</p>
                                    </div>
                                </div>
                                <div class="py-4 md:py-0 md:px-6 space-y-2">
                                    <p class="font-light text-neutral-600 text-sm">{{ 'marketplace.show.propertyKey.furnished'|trans }}</p>
                                    <div class="flex items-center gap-2">
                                        {{ ux_icon('iconoir:sofa', {'class':'size-7 text-gray-800', 'aria-hidden':'true'}) }}
                                        <p>{{ property.furnished == 'yes' ? 'marketplace.list.card.furnished.yes'|trans|raw : 'marketplace.list.card.furnished.no'|trans|raw }}</p>
                                    </div>
                                </div>
                                <div class="py-4 md:py-0 md:pl-6 space-y-2">
                                    <p class="font-light text-neutral-600 text-sm">{{ 'marketplace.show.propertyKey.surface'|trans }}</p>
                                    <div class="flex items-center gap-2">
                                        {{ ux_icon('wordpress:square', {'class':'size-7 text-gray-800', 'aria-hidden':'true'}) }}
                                        <p>{{ property.squareMeters|default('-') }} m²</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    {% if property.description is defined and property.description is not empty %}
                        <div class="space-y-3" data-controller="expandable">
                            <h2 class="text-lg font-semibold font-secondary">{{ 'marketplace.show.description.title'|trans }}</h2>
                            <div data-expandable-target="content" class="prose prose-sm max-w-none text-gray-600 line-clamp-6 break-words [&_img]:max-w-full [&_img]:h-auto [&_pre]:overflow-x-auto [&_table]:block [&_table]:overflow-x-auto">
                                {{ property.description|sanity_to_html }}
                            </div>
                            <button
                                type="button"
                                data-action="expandable#expand"
                                data-expandable-target="trigger"
                                class="font-semibold text-gray-900 cursor-pointer hover:underline underline-offset-4"
                            >
                                ... {{ 'marketplace.show.description.showMore'|trans }}
                            </button>
                        </div>
                    {% endif %}
                    {% if property.equipment is defined and property.equipment is not empty %}
                        {% set equipmentMap = {
                            wifi: { icon: 'boxicons:wifi', label: 'marketplace.show.equipment.wifi'|trans },
                            airConditioning: { icon: 'iconoir:snow-flake', label: 'marketplace.show.equipment.airConditioning'|trans },
                            balcony: { icon: 'mdi:balcony', label: 'marketplace.show.equipment.balcony'|trans },
                            concierge: { icon: 'iconoir:bell', label: 'marketplace.show.equipment.concierge'|trans },
                            dishwasher: { icon: 'material-symbols:dishwasher-gen-outline-sharp', label: 'marketplace.show.equipment.dishwasher'|trans },
                            dryer: { icon: 'boxicons:dryer', label: 'marketplace.show.equipment.dryer'|trans },
                            elevator: { icon: 'iconoir:elevator', label: 'marketplace.show.equipment.elevator'|trans },
                            intercom: { icon: 'lucide-lab:intercom', label: 'marketplace.show.equipment.intercom'|trans },
                            microwave: { icon: 'mdi:microwave', label: 'marketplace.show.equipment.microwave'|trans },
                            parking: { icon: 'iconoir:parking', label: 'marketplace.show.equipment.parking'|trans },
                            television: { icon: 'iconoir:tv', label: 'marketplace.show.equipment.television'|trans },
                            washingMachine: { icon: 'iconoir:washing-machine', label: 'marketplace.show.equipment.washingMachine'|trans },
                            naturalLight: { icon: 'iconoir:sun-light', label: 'marketplace.show.equipment.naturalLight'|trans },
                            doubleGlazing: { icon: 'tabler:window', label: 'marketplace.show.equipment.doubleGlazing'|trans },
                            cellar: { icon: 'tabler:stairs-down', label: 'marketplace.show.equipment.cellar'|trans },
                            bathtub: { icon: 'iconoir:bathroom', label: 'marketplace.show.equipment.bathtub'|trans },
                            wheelchairAccess: { icon: 'iconoir:accessibility', label: 'marketplace.show.equipment.wheelchairAccess'|trans },
                            bikeStorage: { icon: 'iconoir:bicycle', label: 'marketplace.show.equipment.bikeStorage'|trans },
                            workspace: { icon: 'fluent:desk-48-regular', label: 'marketplace.show.equipment.workspace'|trans },
                        } %}
                        {% set exposureMap = {
                            north: 'marketplace.show.exposure.north'|trans,
                            south: 'marketplace.show.exposure.south'|trans,
                            east: 'marketplace.show.exposure.east'|trans,
                            west: 'marketplace.show.exposure.west'|trans,
                        } %}
                        {% set viewMap = {
                            courtyard: 'marketplace.show.view.courtyard'|trans,
                            street: 'marketplace.show.view.street'|trans,
                        } %}
                        <div class="space-y-5">
                            <h2 class="text-lg font-semibold font-secondary">{{ 'marketplace.show.equipment.title'|trans }}</h2>
                            <div class="grid grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6">
                                {% if property.floor is defined and property.floor %}
                                    <div class="flex items-center gap-2">
                                        {{ ux_icon('iconoir:building', {'class':'size-5 text-primary', 'aria-hidden':'true'}) }}
                                        <p>{{ 'marketplace.show.building.floor'|trans }} {{ property.floor }}{% if property.totalFloors %}/{{ property.totalFloors }}{% endif %}</p>
                                    </div>
                                {% endif %}
                                {% if property.constructionYear is defined and property.constructionYear %}
                                    <div class="flex items-center gap-2">
                                        {{ ux_icon('iconoir:calendar', {'class':'size-5 text-primary', 'aria-hidden':'true'}) }}
                                        <p>{{ 'marketplace.show.building.construction'|trans }} {{ property.constructionYear }}</p>
                                    </div>
                                {% endif %}
                                {% if property.renovationYear is defined and property.renovationYear %}
                                    <div class="flex items-center gap-2">
                                        {{ ux_icon('iconoir:tools', {'class':'size-5 text-primary', 'aria-hidden':'true'}) }}
                                        <p>{{ 'marketplace.show.building.renovation'|trans }} {{ property.renovationYear }}</p>
                                    </div>
                                {% endif %}
                                {% if property.exposure is defined and property.exposure and exposureMap[property.exposure] is defined %}
                                    <div class="flex items-center gap-2">
                                        {{ ux_icon('iconoir:compass', {'class':'size-5 text-primary', 'aria-hidden':'true'}) }}
                                        <p>{{ 'marketplace.show.exposure.label'|trans }} {{ exposureMap[property.exposure] }}</p>
                                    </div>
                                {% endif %}
                                {% if property.view is defined and property.view and viewMap[property.view] is defined %}
                                    <div class="flex items-center gap-2">
                                        {{ ux_icon('iconoir:eye', {'class':'size-5 text-primary', 'aria-hidden':'true'}) }}
                                        <p>{{ 'marketplace.show.view.label'|trans }} {{ viewMap[property.view]|lower }}</p>
                                    </div>
                                {% endif %}
                                {% for key, info in equipmentMap %}
                                    {% if property.equipment[key]|default(false) %}
                                        <div class="flex items-center gap-2">
                                            {{ ux_icon(info.icon, {'class':'size-5 text-primary', 'aria-hidden':'true'}) }}
                                            <p>{{ info.label }}</p>
                                        </div>
                                    {% endif %}
                                {% endfor %}
                            </div>
                        </div>
                    {% endif %}
                    {% if map is not null %}
                        <div class="space-y-5" data-controller="map-dialog">
                            <h2 class="text-lg font-semibold font-secondary">{{ 'marketplace.show.location.title'|trans }}</h2>
                            <div class="relative rounded-3xl lg:p-2 border border-neutral-200" data-controller="lazy-map">
                                {# Placeholder (skeleton) shown until the section enters the viewport #}
                                <div
                                    data-lazy-map-target="placeholder"
                                    class="h-96 w-full rounded-2xl bg-neutral-100 animate-pulse"
                                    aria-hidden="true"
                                ></div>
                                {# Actual Google Maps markup, inert inside <template> until cloned into the DOM #}
                                <template data-lazy-map-target="content">
                                    <div class="pointer-events-none">
                                        {{ ux_map(map, {style: 'height: 24rem; width: 100%;', 'class': 'rounded-2xl overflow-hidden'}) }}
                                    </div>
                                </template>
                                <button
                                    type="button"
                                    data-action="map-dialog#open"
                                    aria-label="{{ 'marketplace.show.dialog.expandMap'|trans }}"
                                    class="absolute inset-0 lg:inset-2 cursor-pointer rounded-2xl focus-visible:ring-2 focus-visible:ring-primary/50 focus-visible:outline-none hover:bg-black/5 transition-colors duration-100"
                                ></button>
                                <span
                                    class="pointer-events-none absolute top-4 right-4 lg:top-6 lg:right-6 z-10 size-10 flex items-center justify-center rounded-full bg-white shadow-md text-gray-700"
                                >
                                    {{ ux_icon('iconoir:expand', {'class':'size-5', 'aria-hidden':'true'}) }}
                                </span>
                            </div>

                            {# Map dialog #}
                            <dialog
                                data-map-dialog-target="dialog"
                                data-action="click->map-dialog#closeOnClickOutside"
                                tabindex="-1"
                                class="fixed inset-0 z-50 m-0 h-full w-full max-h-full max-w-full bg-black/95 backdrop:bg-transparent open:flex open:items-center open:justify-center focus:outline-none"
                            >
                                <div class="relative flex items-center justify-center w-full h-full lg:px-4 lg:py-12">
                                    <button
                                        type="button"
                                        data-action="map-dialog#close"
                                        aria-label="{{ 'marketplace.show.dialog.close'|trans }}"
                                        class="absolute top-4 right-4 z-10 size-10 flex items-center justify-center rounded-full bg-white text-gray-700 shadow-lg hover:bg-neutral-100 lg:bg-white/10 lg:text-white lg:shadow-none lg:hover:bg-white/20 transition duration-100 cursor-pointer focus-visible:ring-2 focus-visible:ring-primary/50 focus-visible:outline-none"
                                    >
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" class="size-6"><path d="M6 18 18 6M6 6l12 12" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                    </button>
                                    <div class="w-full h-full lg:max-w-6xl lg:rounded-2xl overflow-hidden">
                                        {{ ux_map(map, {style: 'height: 100%; width: 100%;'}) }}
                                    </div>
                                </div>
                            </dialog>
                        </div>
                    {% endif %}
                    {% if property.faq is defined and property.faq is not empty %}
                        <div class="space-y-5">
                            <h2 class="text-lg font-semibold font-secondary">{{ 'marketplace.show.faq.title'|trans }}</h2>
                            <twig:Accordion id="property-faq" defaultValue="{{ ['item-0'] }}">
                                {% for item in property.faq %}
                                    <twig:Accordion:Item value="item-{{ loop.index0 }}">
                                        <twig:Accordion:Trigger>{{ item.question }}</twig:Accordion:Trigger>
                                        <twig:Accordion:Content>
                                            {{ item.answer }}
                                        </twig:Accordion:Content>
                                    </twig:Accordion:Item>
                                {% endfor %}
                            </twig:Accordion>
                        </div>
                    {% endif %}
                    <div class="space-y-5">
                        <h2 class="text-lg font-semibold font-secondary">{{ 'marketplace.show.goodToKnow.title'|trans }}</h2>
                        <div class="rounded-2xl px-4 py-2 sm:p-5 bg-neutral-50">
                            <div class="grid md:grid-cols-3 divide-y md:divide-y-0 md:divide-x divide-gray-200">
                                <div class="py-4 md:py-0 md:pr-6 space-y-2">
                                    <div class="bg-white p-2 rounded-md inline-block">
                                        {{ ux_icon('solar:shield-check-linear', {'class':'size-6 text-gray-800', 'aria-hidden':'true'}) }}
                                    </div>
                                    <p class="text-base">{{ 'marketplace.show.goodToKnow.verified.title'|trans }}</p>
                                    <p class="font-light text-neutral-600 text-sm text-pretty">{{ 'marketplace.show.goodToKnow.verified.description'|trans }}</p>
                                </div>
                                <div class="py-4 md:py-0 md:px-6 space-y-2">
                                    <div class="bg-white p-2 rounded-md inline-block">
                                        {{ ux_icon('uil:lock', {'class':'size-6 text-gray-800', 'aria-hidden':'true'}) }}
                                    </div>
                                    <p class="text-base">{{ 'marketplace.show.goodToKnow.secure.title'|trans }}</p>
                                    <p class="font-light text-neutral-600 text-sm text-pretty">{{ 'marketplace.show.goodToKnow.secure.description'|trans }}</p>
                                </div>
                                <div class="py-4 md:py-0 md:pl-6 space-y-2">
                                    <div class="bg-white p-2 rounded-md inline-block">
                                        {{ ux_icon('solar:user-outline', {'class':'size-6 text-gray-800', 'aria-hidden':'true'}) }}
                                    </div>
                                    <p class="text-base">{{ 'marketplace.show.goodToKnow.agent.title'|trans }}</p>
                                    <p class="font-light text-neutral-600 text-sm text-pretty">{{ 'marketplace.show.goodToKnow.agent.description'|trans }}</p>
                                </div>
                            </div>
                        </div>
                    </div>
                    {% if property.tags is defined and property.tags is not empty %}
                        <div class="flex flex-wrap gap-2">
                            {% for tag in property.tags %}
                                <twig:Badge variant="secondary" class="capitalize">
                                    {{ tag }}
                                </twig:Badge>
                            {% endfor %}
                        </div>
                    {% endif %}
                </div>

                <aside class="lg:col-span-3 min-w-0" aria-label="{{ 'marketplace.show.sidebar.propertyDetails'|trans }}">
                    <div
                        data-mobile-sheet-target="sheet"
                        class="space-y-6 lg:sticky lg:top-4 max-lg:fixed max-lg:bottom-0 max-lg:inset-x-0 max-lg:z-50 max-lg:translate-y-full max-lg:opacity-0 max-lg:pointer-events-none max-lg:transition-all max-lg:duration-300 max-lg:bg-white max-lg:rounded-t-2xl max-lg:max-h-[85vh] max-lg:overflow-y-auto max-lg:shadow-2xl"
                    >
                        {# Mobile sheet close button #}
                        <button
                            type="button"
                            data-action="mobile-sheet#close"
                            aria-label="{{ 'marketplace.show.dialog.close'|trans }}"
                            class="lg:hidden absolute top-3 right-3 z-10 size-9 flex items-center justify-center rounded-full bg-white shadow-md text-gray-700 hover:bg-neutral-100 transition duration-100 cursor-pointer focus-visible:ring-2 focus-visible:ring-primary/50 focus-visible:outline-none"
                        >
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" class="size-5"><path d="M6 18 18 6M6 6l12 12" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        </button>
                        <div class="rounded-2xl p-4 sm:p-5 bg-neutral-50 divide-y divide-gray-200 [&>*]:py-4 [&>*:first-child]:pt-0 [&>*:last-child]:pb-0">
                            <div class="flex flex-wrap items-end gap-x-2 gap-y-2">
                                {% if property.monthlyRent and not property.priceOnRequest|default(false) %}
                                    <p class="text-2xl sm:text-3xl font-semibold text-primary">
                                        {{ property.monthlyRent|number_format(0, ',', ' ') }}€
                                        <span class="text-gray-600 font-light text-base">/{{ 'marketplace.list.card.price.month'|trans|raw }}</span>
                                    </p>
                                    {% if property.chargesIncludes|default(false) %}
                                        <div class="px-2 py-0.5 rounded-full bg-white text-xs">
                                            {{ 'marketplace.list.card.price.chargesIncludes'|trans|raw }}
                                        </div>
                                    {% endif %}
                                {% else %}
                                    <p class="text-xl sm:text-2xl font-semibold text-primary">
                                        {{ 'marketplace.list.card.price.onDemand'|trans|raw }}
                                    </p>
                                {% endif %}
                            </div>
                            <div class="space-y-7">
                                <div class="space-y-4">
                                    <div class="flex justify-between items-center">
                                        <h2 class="text-lg font-semibold font-secondary">{{ 'marketplace.show.sidebar.propertyDetails'|trans }}</h2>
                                        <p class="text-xs font-light text-gray-400">PR5058</p>
                                    </div>
                                    <div class="rounded-2xl border border-slate-200 mt-3 divide-y divide-gray-200">
                                        <div class="p-4 space-y-2">
                                            <p class="font-light text-neutral-600 text-sm">{{ 'marketplace.show.sidebar.availability'|trans }}</p>
                                            {% if property.status == 'underOffer' %}
                                                <p class="text-amber-600">{{ 'marketplace.list.card.status.underOffer'|trans }}</p>
                                            {% elseif property.status == 'rented' %}
                                                <p class="text-red-600">{{ 'marketplace.list.card.status.rented'|trans }}</p>
                                            {% elseif property.availableDate is defined and property.availableDate %}
                                                {% if property.availableDate|date('Y-m-d') <= 'now'|date('Y-m-d') %}
                                                    <p class="text-green-600">{{ 'marketplace.list.card.status.available'|trans }}</p>
                                                {% else %}
                                                    <p class="text-slate-600">{{ 'marketplace.list.card.status.soon'|trans }} <span class="font-semibold">{{ property.availableDate|date('d/m/Y') }}</span></p>
                                                {% endif %}
                                            {% endif %}
                                        </div>
                                        {% if property.leaseType is defined and property.leaseType %}
                                            {% set leaseTypesMap = {
                                                civilCode: 'marketplace.show.lease.types.civilCode'|trans,
                                                furnished: 'marketplace.show.lease.types.furnished'|trans,
                                                mobility: 'marketplace.show.lease.types.mobility'|trans,
                                                alur: 'marketplace.show.lease.types.alur'|trans,
                                                noLease: 'marketplace.show.lease.types.noLease'|trans,
                                            } %}
                                            {% set leaseTypeKeys = property.leaseType is iterable ? property.leaseType : [property.leaseType] %}
                                            {% set leaseTypeLabels = [] %}
                                            {% for key in leaseTypeKeys %}
                                                {% set leaseTypeLabels = leaseTypeLabels|merge([leaseTypesMap[key]|default(key)]) %}
                                            {% endfor %}
                                            <div class="p-4 space-y-2">
                                                <p class="font-light text-neutral-600 text-sm">
                                                    {{ 'marketplace.show.sidebar.leaseTypeLabel'|trans }}
                                                </p>
                                                <p class="text-sm">{{ leaseTypeLabels|join(', ') }}</p>
                                            </div>
                                        {% endif %}
                                        {% if property.midTerm|default(false) or property.longTerm|default(false) %}
                                            <div class="p-4 space-y-2">
                                                <p class="font-light text-neutral-600 text-sm">{{ 'marketplace.show.sidebar.rentalDuration'|trans }}</p>
                                                <ul role="list" class="space-y-1.5">
                                                    {% if property.midTerm|default(false) %}
                                                        <li class="flex items-center gap-2 text-sm">
                                                            {{ ux_icon('iconoir:check', {'class': 'size-4 text-primary shrink-0'}) }}
                                                            {{ 'marketplace.show.sidebar.mediumTerm'|trans }} <span class="text-gray-600 font-light">- {{ 'marketplace.show.sidebar.mediumTermRange'|trans }}</span>
                                                        </li>
                                                    {% endif %}
                                                    {% if property.longTerm|default(false) %}
                                                        <li class="flex items-center gap-2 text-sm">
                                                            {{ ux_icon('iconoir:check', {'class': 'size-4 text-primary shrink-0'}) }}
                                                            {{ 'marketplace.show.sidebar.longTerm'|trans }} <span class="text-neutral-600 font-light text-sm">- {{ 'marketplace.show.sidebar.longTermRange'|trans }}</span>
                                                        </li>
                                                    {% endif %}
                                                </ul>
                                            </div>
                                        {% endif %}
                                    </div>
                                </div>
                                {% if is_granted('ROLE_ADMIN') and property.extraFees is defined and property.extraFees is not empty %}
                                    {% set feeTypesMap = {
                                        agencyFees: 'marketplace.show.fees.types.agencyFees'|trans,
                                        securityDeposit: 'marketplace.show.fees.types.securityDeposit'|trans,
                                        cleaningFee: 'marketplace.show.fees.types.cleaningFee'|trans,
                                        registrationFee: 'marketplace.show.fees.types.registrationFee'|trans,
                                        guarantorFee: 'marketplace.show.fees.types.guarantorFee'|trans,
                                        relocationFee: 'marketplace.show.fees.types.relocationFee'|trans,
                                        applicationFee: 'marketplace.show.fees.types.applicationFee'|trans,
                                        inventoryFee: 'marketplace.show.fees.types.inventoryFee'|trans,
                                    } %}
                                    {% set totalFees = 0 %}
                                    {% for fee in property.extraFees %}
                                        {% set totalFees = totalFees + (fee.amount|default(0)) %}
                                    {% endfor %}
                                    <div>
                                        <h2 class="text-lg font-semibold font-secondary">{{ 'marketplace.show.fees.title'|trans }}</h2>
                                        <div class="rounded-2xl border border-slate-200 mt-3 divide-y divide-gray-200">
                                            <div class="p-4 space-y-3">
                                                {% for fee in property.extraFees %}
                                                    <div class="flex justify-between items-center gap-2">
                                                        <p class="text-neutral font-light text-sm">{{ feeTypesMap[fee.feeType]|default(fee.feeType) }}</p>
                                                        <p>{{ fee.amount|number_format(0, ',', ' ') }}€</p>
                                                    </div>
                                                {% endfor %}
                                            </div>
                                            <div class="p-4 flex justify-between items-end">
                                                <div>
                                                    <p class="font-semibold">{{ 'marketplace.show.fees.total'|trans }}</p>
                                                    <p class="text-xs font-light text-slate-600">{{ 'marketplace.show.fees.noHidden'|trans }}</p>
                                                </div>
                                                <p class="font-semibold">{{ totalFees|number_format(0, ',', ' ') }}€</p>
                                            </div>
                                        </div>
                                    </div>
                                {% endif %}
                                <div class="w-full">
                                    <twig:Button variant="default" as="a" size="lg" href="{{ path('app_pricing') }}" class="w-full gap-x-3">
                                        {% if property.agentPhoto|default(false) %}
                                            <div class="relative">
                                                <span class="absolute inset-0 flex items-center justify-center" aria-hidden="true">
                                                    <span class="absolute inline-flex size-5 animate-ping rounded-full bg-[#FFE5EB] opacity-90"></span>
                                                </span>
                                                <img
                                                    src="{{ property.agentPhoto }}?w=48&h=48&fit=crop&auto=format&fm=webp&q=70"
                                                    alt="{{ property.agentName|default('') }}"
                                                    loading="lazy"
                                                    width="24"
                                                    height="24"
                                                    class="relative z-10 inline-block size-6 bg-white rounded-full outline outline-1 -outline-offset-1 outline-black/5 ring-1 ring-white"
                                                />
                                            </div>
                                        {% else %}
                                            <img
                                                src="{{ asset('medias/team/team_1.webp') }}"
                                                alt="{{ 'header.menu.findTenant.imgAlt'|trans|raw }}"
                                                loading="lazy"
                                                width="24"
                                                height="24"
                                                class="size-6 rounded-full outline outline-1 -outline-offset-1 outline-black/5"
                                            />
                                        {% endif %}
                                        {{ 'marketplace.show.cta.scheduleVisit'|trans }}
                                    </twig:Button>
                                </div>
                            </div>
                        </div>
                    </div>
                </aside>
            </div>
        </section>
        </article>
    </section>

        {# Mobile backdrop #}
        <div
            data-mobile-sheet-target="backdrop"
            data-action="click->mobile-sheet#close"
            class="lg:hidden fixed inset-0 z-40 bg-black/60 opacity-0 pointer-events-none transition-opacity duration-300"
        ></div>

        {# Mobile sticky bottom bar (trigger) #}
        <div class="lg:hidden fixed bottom-0 inset-x-0 z-30 bg-white border-t border-neutral-200 px-6 lg:px-8 py-3 flex items-center justify-between gap-4 shadow-t-xl rounded-t-2xl">
            <div class="min-w-0">
                {% if property.monthlyRent and not property.priceOnRequest|default(false) %}
                    <p class="text-2xl font-semibold text-primary tabular-nums">
                        {{ property.monthlyRent|number_format(0, ',', ' ') }}€<span class="text-gray-600 font-light text-sm">/{{ 'marketplace.list.card.price.month'|trans|raw }}</span>
                    </p>
                {% else %}
                    <p class="text-xl font-semibold text-primary">
                        {{ 'marketplace.list.card.price.onDemand'|trans|raw }}
                    </p>
                {% endif %}
            </div>
            <twig:Button variant="default" size="default" data-action="mobile-sheet#open" class="shrink-0">
                {{ 'marketplace.show.cta.viewDetails'|trans }}
            </twig:Button>
        </div>
    </div>
{% endblock %}
