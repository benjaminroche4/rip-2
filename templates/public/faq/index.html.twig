{% extends 'base.html.twig' %}

{% block title %}{{ 'meta.faq.title'|trans }}{% endblock %}
{% block description %}{{ 'meta.faq.description'|trans }}{% endblock %}
{% block url %}{{ path('app_faq') }}{% endblock %}

{% block schema_page %}
    ,{
        "@type": "FAQPage",
        "@id": "{{ site_url }}{{ path('app_faq') }}/#faqpage",
        "url": "{{ site_url }}{{ path('app_faq') }}",
        "name": "{{ 'meta.faq.title'|trans|striptags|e('js') }}",
        "description": "{{ 'meta.faq.description'|trans|striptags|e('js') }}",
        "inLanguage": "{{ app.request.locale == 'fr' ? 'fr-FR' : 'en-GB' }}",
        "isPartOf": { "@id": "{{ site_url }}/#website" },
        "about": { "@id": "{{ site_url }}/#organization" },
        "mainEntity": [
            {
                "@type": "Question",
                "name": "{{ 'faq.1.title'|trans|striptags|e('js') }}",
                "acceptedAnswer": { "@type": "Answer", "text": "{{ 'faq.1.text'|trans|striptags|e('js') }}" }
