{% block body %}
    <section class="max-w-7xl mx-auto lg:px-8 px-6 lg:pt-16 pt-12 lg:pb-10 pb-6">
        <div class="max-w-2xl mx-auto flex flex-col justify-center text-center space-y-4">
            <p class="text-center font-semibold text-primary font-secondary">{{ 'faq.title'|trans|raw }}</p>
            <h1 class="text-4xl lg:text-5xl/16 font-medium text-balance">{{ 'faq.subTitle'|trans|raw }}</h1>
        </div>
    </section>
    <section class="max-w-7xl mx-auto lg:px-8 px-6 lg:pb-16 pb-12 mt-8">
        <div class="max-w-3xl mx-auto">
            <twig:Section:FaqAccordion keyPrefix="faq" :keys="1..14" />
        </div>
    </section>
    <twig:Section:ctaFooter />
