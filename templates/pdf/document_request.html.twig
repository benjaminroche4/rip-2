{# Bilingual PDF for a DocumentRequest. Rendered through DocRaptor
   (Chrome headless), so modern CSS is allowed. The visual language
   follows the transactional emails (templates/emails/contact_*):
   nested gray→white cards, muted #525252 labels, green accent for
   the call-to-action. #}
{% set fr = locale == 'fr' %}
{% set t = {
    title: fr ? 'Demande de pièces' : 'Document request',
    intro: fr
        ? 'Bonjour, afin de finaliser votre dossier locatif, merci de nous transmettre les pièces listées ci-dessous via le lien sécurisé indiqué en bas de ce document.'
        : 'Hello, to finalise your rental file please upload the documents listed below using the secure link at the bottom of this page.',
    noticeLabel: fr ? 'Format requis' : 'Required format',
    noticeBody: fr
        ? 'Tous les documents doivent être transmis au format PDF. Les photos (JPG, PNG, HEIC) et captures d\'écran ne peuvent pas être acceptées par les bailleurs.'
        : 'All documents must be submitted in PDF format. Photos (JPG, PNG, HEIC) and screenshots cannot be accepted by landlords.',
    summary: fr ? 'Récapitulatif de la demande' : 'Request summary',
    typologyLabel: fr ? 'Composition du foyer' : 'Household composition',
    issuedOn: fr ? 'Émis le' : 'Issued on',
    noteLabel: fr ? 'Mot de l\'agence' : 'A note from us',
    persons: fr ? 'Personnes concernées' : 'People involved',
    docsForPerson: fr ? 'Pièces à transmettre' : 'Documents to provide',
    drive: fr ? 'Votre lien de dépôt sécurisé' : 'Your secure upload link',
    driveHelp: fr
        ? 'Cliquez sur le bouton ci-dessous pour accéder à votre espace de dépôt.'
        : 'Click the button below to open your secure upload space.',
    typology: {
        two_tenants_two_guarantors: fr ? '2 locataires + 2 garants' : '2 tenants + 2 guarantors',
        two_tenants_one_guarantor: fr ? '2 locataires + 1 garant' : '2 tenants + 1 guarantor',
        one_tenant_two_guarantors: fr ? '1 locataire + 2 garants' : '1 tenant + 2 guarantors',
        one_tenant_one_guarantor: fr ? '1 locataire + 1 garant' : '1 tenant + 1 guarantor',
        two_tenants: fr ? '2 locataires' : '2 tenants',
        one_tenant: fr ? '1 locataire' : '1 tenant',
    },
    role: {
        tenant: fr ? 'Locataire' : 'Tenant',
        guarantor: fr ? 'Garant' : 'Guarantor',
    },
    category: {
        identity: fr ? 'Identité' : 'Identity',
        work: fr ? 'Travail' : 'Work',
        housing: fr ? 'Logement' : 'Housing',
        financial: fr ? 'Finance' : 'Finance',
        education: fr ? 'Études' : 'Education',
        guarantee: fr ? 'Garantie' : 'Guarantee',
        other: fr ? 'Autres' : 'Other',
    },
    footerTag: fr ? 'Agence de Relocation pour Particuliers et Professionnels' : 'Relocation Agency for Individuals and Businesses',
    footerAddress: '155 Rue du Faubourg Saint-Denis, 75010 Paris — France',
} %}
<!doctype html>
<html lang="{{ locale }}">
<head>
    <meta charset="UTF-8">
    <title>{{ t.title }}</title>
    <style>
        @page { margin: 18mm 16mm 22mm 16mm; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Inter', 'Roboto', sans-serif;
            color: #1f2937;
            font-size: 10.5pt;
            line-height: 1.55;
            margin: 0;
            padding: 0;
        }
        a { color: #71172e; }
        h1, h2, h3 { font-weight: 600; color: #111827; }
        .muted { color: #525252; }
        .narrow { max-width: 480pt; margin: 0 auto; }
        .row-2col { display: table; width: 100%; }
        .row-2col > .col { display: table-cell; vertical-align: top; }
        .row-2col > .col-right { text-align: right; }

        /* Shared card chrome (gray rail → white inner), matches emails. */
        .gray-card {
            background-color: #F7F7F7;
            border: 1px solid #E5E5E5;
            border-radius: 12pt;
            padding: 10pt;
            margin-bottom: 14pt;
        }
        .white-inner {
            background-color: #ffffff;
            border-radius: 8pt;
            padding: 14pt 18pt;
        }
        .notice-card {
            background-color: #fef3f5;
            border: 1px solid #f3d4dc;
            border-radius: 12pt;
            padding: 14pt 18pt;
            margin-bottom: 16pt;
        }
        .drive-card {
            background-color: #EFFDF4;
            border: 1px solid #BBF7D0;
            border-radius: 12pt;
            padding: 18pt 22pt;
            margin-top: 8pt;
            page-break-inside: avoid;
            text-align: center;
        }
        .drive-label {
            margin: 0 0 4pt;
            font-size: 8pt;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1.2pt;
            color: #15803d;
        }
        .drive-help { margin: 0 0 12pt; font-size: 10pt; color: #166534; }
        .cta-link {
            display: inline-block;
            background-color: #71172e;
            color: #ffffff !important;
            text-decoration: none;
            font-weight: 600;
            font-size: 10.5pt;
            padding: 9pt 18pt;
            border-radius: 8pt;
            word-break: break-all;
        }
        .role-tenant, .role-guarantor {
            display: inline-block;
            padding: 2pt 10pt;
            border-radius: 999pt;
            font-weight: 600;
            font-size: 9pt;
            border: 1px solid;
        }
        .role-tenant { background-color: #EFFDF4; border-color: #BBF7D0; color: #15803d; }
        .role-guarantor { background-color: #EFF6FF; border-color: #BFDBFE; color: #1d4ed8; }
        hr.sep { width: 100%; border: none; border-top: 2px solid #eaeaea; margin: 10pt 0; }
        .section-label { margin: 0 0 8pt; font-size: 11pt; color: #111827; }
        .doc-name { color: #111827; font-weight: 600; }
        .doc-desc { color: #525252; font-size: 9pt; line-height: 1.5; }
        .doc-category {
            margin: 10pt 0 2pt;
            padding: 0;
            font-size: 8pt;
            font-weight: 700;
            letter-spacing: 1.4pt;
            text-transform: uppercase;
            color: #6b7280;
        }
        .doc-category:first-of-type { margin-top: 0; }
        .doc-list {
            list-style: disc outside;
            margin: 2pt 0 0;
            padding: 0 0 0 16pt;
        }
        .doc-list li {
            margin: 0;
            padding: 4pt 0;
            font-size: 10pt;
            color: #111827;
        }
        .doc-list li::marker {
            color: #111827;
            font-size: 11pt;
        }
        .footer-brand { margin: 14pt 0 0; font-size: 9pt; text-align: center; color: #525252; }
        .footer-address { margin: 4pt 0 0; font-size: 9pt; text-align: center; color: #9ca3af; }
        .page-footer {
            position: fixed;
            bottom: -14mm;
            left: 0; right: 0;
            text-align: center;
            color: #9ca3af;
            font-size: 7.5pt;
            line-height: 1.5;
        }
        .page-footer .brand { color: #71172e; font-weight: 600; }
    </style>
</head>
<body>
    <div class="narrow">
        {# ---- Centered logo (mirrors email header) ---- #}
        <div style="text-align:center">
            {% if logoDataUri %}
                <img src="{{ logoDataUri }}" alt="Relocation in Paris" width="166" height="38" style="display:block;border:none;outline:none;text-decoration:none;height:38px;width:166px;margin:0 auto">
            {% else %}
                <span style="font-size:15pt;font-weight:700;color:#71172e;letter-spacing:0.6pt">Relocation in Paris</span>
            {% endif %}
        </div>

        <h1 style="font-size:22pt;line-height:1.3;text-align:center;margin:14pt 0 0">{{ t.title }}</h1>
        <p style="margin:8pt 0 0;font-size:9pt;text-align:center;color:#9ca3af">
            {{ t.issuedOn }} {{ request.createdAt|format_date(pattern='dd MMMM yyyy', locale=locale) }}
        </p>

        <p style="margin:18pt 0 16pt;padding:0 16pt;font-size:10.5pt;line-height:1.6;color:#374151;text-align:center">
            {{ t.intro }}
        </p>

        {# ---- Format notice (rose accent box) ---- #}
        <div class="notice-card">
            <p style="margin:0 0 4pt;font-size:8pt;font-weight:700;text-transform:uppercase;letter-spacing:1.2pt;color:#71172e;text-align:center">{{ t.noticeLabel }}</p>
            <p style="margin:0;font-size:10pt;line-height:1.55;color:#4b1320;text-align:center">{{ t.noticeBody }}</p>
        </div>

        {# ---- Summary card (gray outer → white inner, mirrors emails contact info) ---- #}
        <div class="gray-card">
            <p class="section-label"><strong>{{ t.summary }}</strong></p>
            <div class="white-inner">
                <p style="margin:0;padding:4pt 0;font-size:10pt"><span class="muted">{{ t.typologyLabel }} :</span> <strong>{{ t.typology[request.typology.value] }}</strong></p>
                <p style="margin:0;padding:4pt 0;font-size:10pt"><span class="muted">{{ t.persons }} :</span> <strong>{{ request.persons|length }}</strong></p>
            </div>
        </div>

        {# ---- Persons section — one gray→white card per person ---- #}
        <p class="section-label" style="margin-top:6pt"><strong>{{ t.persons }}</strong></p>
        {% for person in request.persons %}
            <div class="gray-card" style="page-break-inside:avoid">
                <div class="white-inner">
                    <div class="row-2col">
                        <div class="col" style="font-size:11pt;color:#111827">
                            <span class="muted" style="font-size:9pt">#{{ '%02d'|format(loop.index) }}</span>
                            &nbsp;<strong>{{ person.firstName }} {{ person.lastName }}</strong>
                        </div>
                        <div class="col col-right" style="font-size:9pt">
                            <span class="{{ person.role.value == 'tenant' ? 'role-tenant' : 'role-guarantor' }}">{{ t.role[person.role.value] }}</span>
                        </div>
                    </div>
                    <hr class="sep">
                    <p class="muted" style="margin:0;padding:0 0 6pt;font-size:9pt">{{ t.docsForPerson }} :</p>
                    {# Group the M2M docs by category (the collection order is
                       insertion-based and doesn't match the form's category
                       grouping). Iterate the categories in enum order so the
                       PDF matches the form: Identity → Work → Housing → … #}
                    {% set docsByCategory = {} %}
                    {% for doc in person.documents %}
                        {% set cat = doc.category ? doc.category.value : 'other' %}
                        {% set bucket = docsByCategory[cat]|default([]) %}
                        {% set bucket = bucket|merge([doc]) %}
                        {% set docsByCategory = docsByCategory|merge({(cat): bucket}) %}
                    {% endfor %}

                    {% for category in ['identity', 'work', 'housing', 'financial', 'education', 'guarantee', 'other'] %}
                        {% if docsByCategory[category]|default([]) is not empty %}
                            <p class="doc-category">{{ t.category[category] }}</p>
                            {# Pinned first, then alphabetical on the localised name. #}
                            {% set sortedDocs = docsByCategory[category]|sort((a, b) => (b.pinned ? 1 : 0) <=> (a.pinned ? 1 : 0) ?: a.getName(locale) <=> b.getName(locale)) %}
                            <ul class="doc-list">
                                {% for doc in sortedDocs %}
                                    <li>
                                        <span class="doc-name">{{ doc.getName(locale) }}</span>
                                        {% set desc = doc.getDescription(locale) %}
                                        {% if desc %}<br><span class="doc-desc">{{ desc }}</span>{% endif %}
                                    </li>
                                {% endfor %}
                            </ul>
                        {% endif %}
                    {% endfor %}
                </div>
            </div>
        {% endfor %}

        {# ---- Personalised note (only when the advisor wrote one).
               Sits right above the drive CTA so the message is the last
               thing the recipient reads before clicking the upload link. #}
        {% if request.note|default('')|trim is not empty %}
            <div class="gray-card">
                <p class="section-label"><strong>{{ t.noteLabel }}</strong></p>
                <div class="white-inner">
                    <p style="margin:0;padding:2pt 0;font-size:10pt;line-height:1.65;color:#374151;white-space:pre-line">{{ request.note|trim }}</p>
                </div>
            </div>
        {% endif %}

        {# ---- Drive link — green highlight box (mirrors email's 30-min CTA) ---- #}
        <div class="drive-card">
            <p class="drive-label">{{ t.drive }}</p>
            <p class="drive-help">{{ t.driveHelp }}</p>
            <a class="cta-link" href="{{ request.driveLink }}">{{ request.driveLink }}</a>
        </div>

        {# ---- Bottom signature, centered like email footer ---- #}
        <hr class="sep" style="margin-top:20pt">
        <p class="footer-brand">
            <strong style="color:#71172e">Relocation in Paris</strong> &middot; {{ t.footerTag }}
        </p>
        <p class="footer-address">{{ t.footerAddress }}</p>
    </div>

    <div class="page-footer">
        <span class="brand">Relocation in Paris</span> &middot; {{ t.title }}
    </div>
</body>
</html>
