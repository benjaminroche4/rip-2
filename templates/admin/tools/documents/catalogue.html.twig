{% extends 'admin/base.html.twig' %}

{% block title %}{{ 'admin.tools.documents.catalogue.title'|trans }}{% endblock %}
{% block page_title %}{{ 'admin.tools.documents.catalogue.title'|trans }}{% endblock %}
{% block page_subtitle %}{{ 'admin.tools.documents.catalogue.subtitle'|trans }}{% endblock %}
{% block page_actions %}
    <a
        href="{{ path('admin_tools_documents', {adminPrefix: adminPrefix}) }}"
        class="inline-flex shrink-0 items-center gap-1.5 text-sm text-gray-500 transition-colors hover:text-gray-900"
    >
        {{ ux_icon('lucide:arrow-left', {class: 'size-4'}) }}
        {{ 'admin.tools.documents.catalogue.backToDocuments'|trans }}
    </a>
{% endblock %}

{% block body %}
    <div class="space-y-8" data-testid="tools-documents-catalogue-page">
        <twig:Admin:DocumentList :adminPrefix="adminPrefix" />
    </div>
{% endblock %}
