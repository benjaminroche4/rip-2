{% extends 'admin/base.html.twig' %}

{% block title %}{{ 'admin.tools.title'|trans }}{% endblock %}
{% block page_title %}{{ 'admin.tools.title'|trans }}{% endblock %}

{% block body %}
    <div class="space-y-8" data-testid="tools-page">
        <header>
            <p class="text-xs font-medium tracking-wide text-gray-500 uppercase">
                {{ 'admin.tools.section.overview'|trans }}
            </p>
            <h2 class="mt-2 max-w-[40ch] text-2xl font-semibold tracking-tight text-balance text-gray-900">
                {{ 'admin.tools.welcome'|trans }}
            </h2>
            <p class="mt-2 max-w-[60ch] text-sm text-pretty text-gray-500">
                {{ 'admin.tools.subtitle'|trans }}
            </p>
        </header>

        <section class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3" data-testid="tools-grid">
            <article class="rounded-2xl border border-gray-950/5 bg-white p-2" data-testid="tool-documents-card">
                <div class="flex h-full flex-col items-center gap-4 rounded-xl bg-linear-to-b from-neutral-100/50 to-neutral-100/0 p-6 text-center">
                    <div class="flex size-12 shrink-0 items-center justify-center rounded-full bg-primary/10 text-primary">
                        {{ ux_icon('lucide:file-text', {class: 'size-6'}) }}
                    </div>
                    <div class="space-y-1.5">
                        <h3 class="text-base font-semibold tracking-tight text-gray-900">
                            {{ 'admin.tools.documents.title'|trans }}
                        </h3>
                        <p class="text-sm text-pretty text-gray-500">
                            {{ 'admin.tools.documents.description'|trans }}
                        </p>
                    </div>
                    <twig:Button variant="outline" class="mt-auto w-full">
                        {{ 'admin.tools.documents.cta'|trans }}
                    </twig:Button>
                </div>
            </article>

            {# Placeholder slots — same outer shape so the grid feels balanced. #}
            {% for i in 1..2 %}
                <article class="rounded-2xl border border-dashed border-gray-950/10 bg-white/50 p-2" data-testid="tool-coming-soon">
                    <div class="flex h-full flex-col items-center justify-center gap-3 rounded-xl px-4 py-8 text-center">
                        <div class="flex size-10 shrink-0 items-center justify-center rounded-full bg-gray-100 text-gray-400">
                            {{ ux_icon('lucide:sparkles', {class: 'size-5'}) }}
                        </div>
                        <div class="space-y-1">
                            <h3 class="text-sm font-medium text-gray-700">
                                {{ 'admin.tools.comingSoon.title'|trans }}
                            </h3>
                            <p class="max-w-[24ch] text-xs text-pretty text-gray-400">
                                {{ 'admin.tools.comingSoon.description'|trans }}
                            </p>
                        </div>
                    </div>
                </article>
            {% endfor %}
        </section>
    </div>
{% endblock %}
