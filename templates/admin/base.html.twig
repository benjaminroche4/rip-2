<!DOCTYPE html>
<html lang="{{ app.request.locale }}" class="h-full">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <meta name="theme-color" content="#FFFFFF">
        {# noindex/nofollow servi via X-Robots-Tag par AdminNoIndexListener — couvre HTML + futurs exports JSON/CSV/PDF #}

        <title>{% block title %}Admin{% endblock %} — Relocation In Paris</title>

        {% block stylesheets %}
            {{ importmap('app') }}
        {% endblock %}
    </head>
    <body class="min-h-dvh bg-neutral-50 text-gray-900 antialiased">
        <div class="isolate flex min-h-dvh">
            <aside class="flex w-64 shrink-0 flex-col border-r border-gray-950/5 bg-white">
                <div class="px-5 py-6">
                    <a href="{{ path('admin_dashboard', {adminPrefix: adminPrefix}) }}" class="flex items-center gap-2.5">
                        <span class="size-2.5 rounded-full bg-primary"></span>
                        <span class="text-sm font-semibold tracking-tight text-gray-900">RIP Admin</span>
                    </a>
                </div>

                <nav class="flex flex-1 flex-col gap-0.5 px-3">
                    {% set currentRoute = app.request.attributes.get('_route') %}
                    <a
                        href="{{ path('admin_dashboard', {adminPrefix: adminPrefix}) }}"
                        class="rounded-lg px-3 py-2 text-sm transition-colors {% if currentRoute == 'admin_dashboard' %}bg-primary/5 font-medium text-primary{% else %}font-normal text-gray-600 hover:bg-gray-50 hover:text-gray-900{% endif %}"
                    >
                        {{ 'admin.nav.dashboard'|trans }}
                    </a>
                </nav>

                <div class="border-t border-gray-950/5 p-4">
                    <div class="flex items-center gap-3">
                        {% if app.user.avatarFilename %}
                            <img
                                src="{{ path('app_avatar', {filename: app.user.avatarFilename}) }}"
                                alt=""
                                width="36"
                                height="36"
                                class="size-9 shrink-0 rounded-full object-cover"
                            >
                        {% else %}
                            <div class="flex size-9 shrink-0 items-center justify-center rounded-full bg-primary/10 text-xs font-semibold text-primary">
                                {{ app.user.firstName|default(app.user.email)|first|upper }}
                            </div>
                        {% endif %}
                        <div class="min-w-0 flex-1">
                            <p class="truncate text-sm font-medium text-gray-900">{{ app.user.firstName|default(app.user.email) }}</p>
                            <p class="truncate text-xs text-gray-500">{{ app.user.email }}</p>
                        </div>
                    </div>
                    <a
                        href="{{ path('app_logout') }}"
                        class="mt-3 flex items-center justify-center rounded-lg border border-gray-950/10 px-3 py-1.5 text-xs font-medium text-gray-700 transition-colors hover:bg-gray-50"
                    >
                        {{ 'admin.nav.logout'|trans }}
                    </a>
                </div>
            </aside>

            <div class="flex flex-1 flex-col">
                <header class="flex items-center justify-between border-b border-gray-950/5 bg-white px-8 py-5">
                    <div>
                        <p class="text-xs font-medium tracking-wide text-gray-500 uppercase">{% block breadcrumb %}{{ 'admin.nav.dashboard'|trans }}{% endblock %}</p>
                        <h1 class="text-xl font-semibold tracking-tight text-balance text-gray-900">{% block page_title %}{% endblock %}</h1>
                    </div>
                    <div class="flex items-center gap-2">
                        {% block header_actions %}{% endblock %}
                    </div>
                </header>

                <main class="flex-1 px-8 py-8">
                    {% block body %}{% endblock %}
                </main>
            </div>
        </div>
    </body>
</html>
