<!DOCTYPE html>
<html lang="{{ app.request.locale }}" class="h-full">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <meta name="theme-color" content="#FFFFFF">

        {# Admin pages are noindex via X-Robots-Tag (AdminNoIndexListener) — covers HTML and any future JSON/CSV/PDF exports. #}
        <title>{% block title %}Admin{% endblock %}</title>

        <link rel="icon" type="image/x-icon" href="{{ asset('medias/favicon/favicon.ico') }}" sizes="32x32">
        <link rel="apple-touch-icon" sizes="180x180" href="{{ asset('medias/favicon/apple-touch-icon.png') }}">

        {% block stylesheets %}
            {{ importmap('app') }}
        {% endblock %}
    </head>
    <body class="min-h-dvh bg-neutral-50 text-gray-900 antialiased">
        <div class="isolate flex min-h-dvh">
            <aside class="sticky top-0 flex h-dvh w-64 shrink-0 flex-col border-r border-gray-950/5 bg-white">
                <div class="flex shrink-0 items-center justify-between border-b border-gray-950/5 px-5 py-5">
                    <a href="{{ path('admin_dashboard', {adminPrefix: adminPrefix}) }}" aria-label="Relocation In Paris — Admin">
                        <img
                            src="{{ asset('medias/logos/logo_red.svg') }}"
                            alt="Relocation In Paris"
                            width="140"
                            height="28"
                            class="h-7 w-auto"
                        >
                    </a>
                    <twig:Badge variant="secondary" class="rounded-full">Admin</twig:Badge>
                </div>

                {% set currentRoute = app.request.attributes.get('_route') %}
                <nav class="flex-1 space-y-6 overflow-y-auto px-3 py-5">
                    <div>
                        <p class="mb-1.5 px-3 text-xs font-semibold tracking-wide text-gray-400 uppercase">
                            {{ 'admin.sidebar.section.piloting'|trans }}
                        </p>
                        <ul class="space-y-0.5" role="list">
                            <li>
                                <a
                                    href="{{ path('admin_dashboard', {adminPrefix: adminPrefix}) }}"
                                    class="flex items-center gap-2 rounded-lg px-3 py-2 text-sm transition-colors {% if currentRoute == 'admin_dashboard' %}bg-neutral-100 font-medium text-primary{% else %}font-normal text-gray-600 hover:bg-gray-50 hover:text-gray-900{% endif %}"
                                >
                                    {{ ux_icon('lucide:home', {class: 'size-4 shrink-0'}) }}
                                    {{ 'admin.nav.dashboard'|trans }}
                                </a>
                            </li>
                            <li>
                                <a
                                    href="{{ path('admin_users', {adminPrefix: adminPrefix}) }}"
                                    class="flex items-center gap-2 rounded-lg px-3 py-2 text-sm transition-colors {% if currentRoute == 'admin_users' %}bg-neutral-100 font-medium text-primary{% else %}font-normal text-gray-600 hover:bg-gray-50 hover:text-gray-900{% endif %}"
                                >
                                    {{ ux_icon('lucide:users', {class: 'size-4 shrink-0'}) }}
                                    {{ 'admin.nav.users'|trans }}
                                </a>
                            </li>
                        </ul>
                    </div>

                    <div>
                        <p class="mb-1.5 px-3 text-xs font-semibold tracking-wide text-gray-400 uppercase">
                            {{ 'admin.sidebar.section.site'|trans }}
                        </p>
                        <ul class="space-y-0.5" role="list">
                            <li>
                                <a
                                    href="{{ path('app_home') }}"
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="flex items-center gap-2 rounded-lg px-3 py-2 text-sm font-normal text-gray-600 transition-colors hover:bg-gray-50 hover:text-gray-900"
                                >
                                    {{ ux_icon('lucide:external-link', {class: 'size-4 shrink-0'}) }}
                                    {{ 'admin.sidebar.nav.viewSite'|trans }}
                                </a>
                            </li>
                        </ul>
                    </div>
                </nav>

                {% set fullName = ((app.user.firstName ?: '') ~ ' ' ~ (app.user.lastName ?: ''))|trim %}
                <div class="shrink-0 border-t border-gray-950/5 p-4">
                    <div class="flex items-center gap-3">
                        {% if app.user.avatarFilename %}
                            <img
                                src="{{ path('app_avatar', {filename: app.user.avatarFilename}) }}"
                                alt=""
                                width="36"
                                height="36"
                                class="size-9 shrink-0 rounded-full object-cover"
                            >
                        {% else %}
                            <div class="flex size-9 shrink-0 items-center justify-center rounded-full bg-primary/10 text-xs font-semibold text-primary">
                                {{ (fullName ?: app.user.email)|first|upper }}
                            </div>
                        {% endif %}
                        <div class="min-w-0 flex-1">
                            <p class="truncate text-sm font-medium text-gray-900">{{ fullName ?: app.user.email }}</p>
                            <p class="truncate text-xs text-gray-500">{{ app.user.email }}</p>
                        </div>
                    </div>
                    <twig:Button as="a" variant="ghost" size="sm" href="{{ path('app_logout') }}" class="mt-3 w-full border border-gray-950/10 text-xs text-gray-700 hover:bg-gray-50 hover:text-gray-700">
                        {{ ux_icon('lucide:log-out', {class: 'size-3.5'}) }}
                        {{ 'admin.nav.logout'|trans }}
                    </twig:Button>
                </div>
            </aside>

            <div class="flex flex-1 flex-col">
                <header class="border-b border-gray-950/5 bg-white px-8 py-6">
                    <h1 class="text-3xl font-semibold tracking-tight text-balance text-gray-900">{% block page_title %}{% endblock %}</h1>
                </header>

                <main class="flex-1 px-8 py-6">
                    {% block body %}{% endblock %}
                </main>
            </div>
        </div>
    </body>
</html>
