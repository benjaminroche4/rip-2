{% extends 'admin/base.html.twig' %}

{% block title %}{{ 'admin.dashboard.title'|trans }}{% endblock %}
{% block page_title %}{{ 'admin.dashboard.title'|trans }}{% endblock %}

{% block body %}
    <div class="grid gap-6 lg:grid-cols-3">
        <div class="rounded-xl border border-neutral-200 bg-white p-6">
            <div class="text-xs font-medium uppercase tracking-wide text-gray-500">{{ 'admin.dashboard.welcome'|trans }}</div>
            <div class="mt-2 text-2xl font-semibold text-gray-900">{{ app.user.firstName|default(app.user.email) }}</div>
        </div>
    </div>

    <section class="mt-8 rounded-xl border border-neutral-200 bg-white p-6">
        <header class="mb-4">
            <h2 class="text-base font-semibold text-gray-900">{{ 'admin.dashboard.contactsMonthly.title'|trans }}</h2>
            <p class="text-sm text-gray-500">{{ 'admin.dashboard.contactsMonthly.subtitle'|trans }}</p>
        </header>
        <div class="h-72">
            <canvas
                data-controller="chart"
                data-chart-type-value="bar"
                data-chart-labels-value="{{ contactsChartLabels|json_encode }}"
                data-chart-data-value="{{ contactsChartData|json_encode }}"
                data-chart-label-value="{{ contactsChartLabel }}"
                data-testid="contacts-chart"
            ></canvas>
        </div>
    </section>
{% endblock %}
