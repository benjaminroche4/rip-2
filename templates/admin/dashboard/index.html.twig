{% extends 'admin/base.html.twig' %}

{% block title %}{{ 'admin.dashboard.title'|trans }}{% endblock %}
{% block page_title %}{{ 'admin.dashboard.title'|trans }}{% endblock %}

{% block body %}
    <div class="space-y-8">
        <header class="flex items-baseline justify-between gap-6">
            <div>
                <p class="text-xs font-medium tracking-wide text-gray-500 uppercase">
                    {{ 'admin.dashboard.section.overview'|trans }}
                </p>
                <h2 class="mt-2 max-w-[40ch] text-2xl font-semibold tracking-tight text-balance text-gray-900">
                    {{ 'admin.dashboard.welcome'|trans }} {{ app.user.firstName|default(app.user.email) }}
                </h2>
                <p class="mt-2 max-w-[60ch] text-sm text-pretty text-gray-500">
                    {{ 'admin.dashboard.subtitle'|trans }}
                </p>
            </div>
            <p class="shrink-0 text-sm tabular-nums text-gray-500">{{ todayLabel }}</p>
        </header>

        <section class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4" data-testid="kpi-grid">
            {% for kpi in kpis %}
                {% if kpi.previous is not null %}
                    <twig:Admin:KpiComparisonCard :kpi="kpi" />
                {% else %}
                    {# leadsLast12Months card — two stats with divider (12 months total + year-to-date) #}
                    <article class="rounded-2xl border border-gray-950/5 bg-white p-2">
                        <div class="rounded-xl bg-linear-to-b from-neutral-100/50 to-neutral-100/0 p-4">
                            <div>
                                <h3 class="text-xl font-semibold tracking-tight text-gray-900">{{ kpi.title }}</h3>
                                <p class="mt-0.5 text-sm text-pretty text-gray-500">{{ kpi.period }}</p>
                            </div>
                            <div class="mt-6 divide-y divide-gray-950/5">
                                <div class="flex items-baseline justify-between gap-3 pb-3">
                                    <p class="text-xs font-medium tracking-wide text-gray-500 uppercase">{{ 'admin.dashboard.kpi.period.last12m'|trans }}</p>
                                    <p class="text-2xl font-medium tabular-nums text-gray-900">{{ kpi.value|number_format(0, ',', ' ') }}</p>
                                </div>
                                <div class="flex items-baseline justify-between gap-3 pt-3">
                                    <p class="text-xs font-medium tracking-wide text-gray-500 uppercase">{{ 'admin.dashboard.kpi.thisYear'|trans({'%year%': thisYearLabel}) }}</p>
                                    <p class="text-2xl font-medium tabular-nums text-gray-900">{{ thisYearLeads|number_format(0, ',', ' ') }}</p>
                                </div>
                            </div>
                        </div>
                    </article>
                {% endif %}
            {% endfor %}
        </section>

        <section class="rounded-2xl border border-gray-950/5 bg-white p-2">
            <div class="rounded-xl bg-linear-to-b from-neutral-100/50 to-neutral-100/0">
                <div class="px-3 pt-3 pb-5">
                    <h3 class="text-xl font-semibold tracking-tight text-gray-900">
                        {{ 'admin.dashboard.activity.title'|trans }}
                    </h3>
                    <p class="mt-0.5 text-sm text-pretty text-gray-500">
                        {{ 'admin.dashboard.activity.subtitle'|trans }}
                    </p>
                </div>
                <div class="h-80 px-3 pt-5 pb-3">
                    <canvas
                        data-controller="chart"
                        data-chart-labels-value="{{ chartLabels|json_encode }}"
                        data-chart-series-value="{{ chartSeries|json_encode }}"
                        data-testid="activity-chart"
                    ></canvas>
                </div>
            </div>
        </section>

        <section class="rounded-2xl border border-gray-950/5 bg-white p-2">
            <div class="rounded-xl bg-linear-to-b from-neutral-100/50 to-neutral-100/0">
                <div class="px-3 pt-3 pb-5">
                    <h3 class="text-xl font-semibold tracking-tight text-gray-900">
                        {{ 'admin.dashboard.weekVsWeek.title'|trans }}
                    </h3>
                    <p class="mt-0.5 text-sm text-pretty text-gray-500">
                        {{ 'admin.dashboard.weekVsWeek.subtitle'|trans }}
                    </p>
                </div>
                <div class="h-80 px-3 pt-5 pb-3">
                    <canvas
                        data-controller="chart-bars"
                        data-chart-bars-labels-value="{{ weekChartLabels|json_encode }}"
                        data-chart-bars-series-value="{{ weekChartSeries|json_encode }}"
                        data-testid="week-vs-week-chart"
                    ></canvas>
                </div>
            </div>
        </section>

        {% if allTimeChartSeries|length > 0 %}
            <section class="rounded-2xl border border-gray-950/5 bg-white p-2">
                <div class="rounded-xl bg-linear-to-b from-neutral-100/50 to-neutral-100/0">
                    <div class="px-3 pt-3 pb-5">
                        <h3 class="text-xl font-semibold tracking-tight text-gray-900">
                            {{ 'admin.dashboard.contactsAllTime.title'|trans }}
                        </h3>
                        <p class="mt-0.5 text-sm text-pretty text-gray-500">
                            {{ 'admin.dashboard.contactsAllTime.subtitle'|trans }}
                        </p>
                    </div>
                    <div class="h-80 px-3 pt-5 pb-3">
                        <canvas
                            data-controller="chart"
                            data-chart-labels-value="{{ allTimeChartLabels|json_encode }}"
                            data-chart-series-value="{{ allTimeChartSeries|json_encode }}"
                            data-testid="contacts-all-time-chart"
                        ></canvas>
                    </div>
                </div>
            </section>
        {% endif %}

        {% if weekdayChartSeries|length > 0 %}
            <section class="rounded-2xl border border-gray-950/5 bg-white p-2">
                <div class="rounded-xl bg-linear-to-b from-neutral-100/50 to-neutral-100/0">
                    <div class="px-3 pt-3 pb-5">
                        <h3 class="text-xl font-semibold tracking-tight text-gray-900">
                            {{ 'admin.dashboard.contactsWeekdays.title'|trans }}
                        </h3>
                        <p class="mt-0.5 text-sm text-pretty text-gray-500">
                            {{ 'admin.dashboard.contactsWeekdays.subtitle'|trans }}
                        </p>
                    </div>
                    <div class="h-80 px-3 pt-5 pb-3">
                        <canvas
                            data-controller="chart-bars"
                            data-chart-bars-labels-value="{{ weekdayChartLabels|json_encode }}"
                            data-chart-bars-series-value="{{ weekdayChartSeries|json_encode }}"
                            data-testid="contacts-weekday-chart"
                        ></canvas>
                    </div>
                </div>
            </section>
        {% endif %}

    </div>
{% endblock %}
