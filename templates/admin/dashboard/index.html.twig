{% extends 'admin/base.html.twig' %}

{% block title %}{{ 'admin.dashboard.title'|trans }}{% endblock %}
{% block page_title %}{{ 'admin.dashboard.title'|trans }}{% endblock %}

{% block header_actions %}
    <twig:Badge variant="success">
        <span class="size-1.5 rounded-full bg-green-500"></span>
        {{ 'admin.dashboard.live'|trans }}
    </twig:Badge>
{% endblock %}

{% block body %}
    {% set contactsTotal = contactsChartData|reduce((acc, v) => acc + v, 0) %}
    {% set contactsThisMonth = contactsChartData|last %}
    {% set contactsAvg = (contactsTotal / 12)|number_format(1, '.', ' ') %}

    <div class="mx-auto max-w-6xl space-y-8">
        <section>
            <h2 class="text-2xl font-semibold tracking-tight text-balance text-gray-900">
                {{ 'admin.dashboard.welcome'|trans }} {{ app.user.firstName|default(app.user.email) }}
            </h2>
            <p class="mt-1 text-sm text-pretty text-gray-500">
                {{ 'admin.dashboard.subtitle'|trans }}
            </p>
        </section>

        {# Stats — surface unique avec dividers verticaux, pas de cards individuelles #}
        <div class="grid grid-cols-3 divide-x divide-gray-950/5 rounded-xl border border-gray-950/5 bg-white">
            <div class="px-6 py-5">
                <p class="truncate text-xs font-medium tracking-wide text-gray-500 uppercase">
                    {{ 'admin.dashboard.stats.thisMonth'|trans }}
                </p>
                <p class="mt-2 text-3xl font-semibold tabular-nums tracking-tight text-gray-900">
                    {{ contactsThisMonth }}
                </p>
            </div>
            <div class="px-6 py-5">
                <p class="truncate text-xs font-medium tracking-wide text-gray-500 uppercase">
                    {{ 'admin.dashboard.stats.total12m'|trans }}
                </p>
                <p class="mt-2 text-3xl font-semibold tabular-nums tracking-tight text-gray-900">
                    {{ contactsTotal }}
                </p>
            </div>
            <div class="px-6 py-5">
                <p class="truncate text-xs font-medium tracking-wide text-gray-500 uppercase">
                    {{ 'admin.dashboard.stats.monthlyAvg'|trans }}
                </p>
                <p class="mt-2 text-3xl font-semibold tabular-nums tracking-tight text-gray-900">
                    {{ contactsAvg }}
                </p>
            </div>
        </div>

        {# Chart card #}
        <section class="rounded-xl border border-gray-950/5 bg-white">
            <header class="flex items-center justify-between border-b border-gray-950/5 px-6 py-5">
                <div>
                    <h3 class="text-base font-semibold tracking-tight text-gray-900">
                        {{ 'admin.dashboard.contactsMonthly.title'|trans }}
                    </h3>
                    <p class="mt-0.5 text-sm text-gray-500">
                        {{ 'admin.dashboard.contactsMonthly.subtitle'|trans }}
                    </p>
                </div>
                <twig:Badge variant="secondary">12M</twig:Badge>
            </header>
            <div class="h-80 px-6 py-6">
                <canvas
                    data-controller="chart"
                    data-chart-type-value="bar"
                    data-chart-labels-value="{{ contactsChartLabels|json_encode }}"
                    data-chart-data-value="{{ contactsChartData|json_encode }}"
                    data-chart-label-value="{{ contactsChartLabel }}"
                    data-testid="contacts-chart"
                ></canvas>
            </div>
        </section>
    </div>
{% endblock %}
