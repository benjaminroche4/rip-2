{% extends 'admin/base.html.twig' %}

{% set displayName = profile.fullName ?: profile.email %}
{% set isAdmin = profile.primaryRole == 'admin' %}

{% block title %}{{ displayName }}{% endblock %}
{% block page_title %}{{ displayName }}{% endblock %}

{% block body %}
    <div class="space-y-8" data-testid="user-profile">
        <header class="flex items-baseline justify-between gap-6">
            <div>
                <p class="text-xs font-medium tracking-wide text-gray-500 uppercase">
                    {{ 'admin.users.section'|trans }}
                </p>
                <h2 class="mt-2 max-w-[40ch] text-2xl font-semibold tracking-tight text-balance text-gray-900">
                    {{ 'admin.users.profile.title'|trans }}
                </h2>
            </div>
            <a
                href="{{ path('admin_users', {adminPrefix: adminPrefix}) }}"
                class="inline-flex shrink-0 items-center gap-1.5 text-sm text-gray-500 transition-colors hover:text-gray-900"
            >
                {{ ux_icon('lucide:arrow-left', {class: 'size-4'}) }}
                {{ 'admin.users.profile.backToList'|trans }}
            </a>
        </header>

        <section class="rounded-2xl border border-gray-950/5 bg-white p-2">
            <div class="rounded-xl bg-linear-to-b from-neutral-100/50 to-neutral-100/0 p-6">
                <div class="flex items-start gap-5">
                    {% if profile.avatarFilename %}
                        <img
                            src="{{ path('app_avatar', {filename: profile.avatarFilename}) }}"
                            alt=""
                            width="64"
                            height="64"
                            class="size-16 shrink-0 rounded-full object-cover"
                        >
                    {% else %}
                        <div class="flex size-16 shrink-0 items-center justify-center rounded-full bg-primary/10 text-xl font-semibold text-primary">
                            {{ displayName|first|upper }}
                        </div>
                    {% endif %}
                    <div class="min-w-0 flex-1">
                        <h3 class="text-xl font-semibold tracking-tight text-gray-900">
                            {{ displayName }}
                        </h3>
                        <p class="mt-1 text-sm text-gray-500">{{ profile.email }}</p>
                        <div class="mt-3 flex flex-wrap gap-2">
                            <twig:Badge variant="{{ isAdmin ? 'primary' : 'secondary' }}" class="rounded-full">
                                {{ ('admin.users.role.' ~ profile.primaryRole)|trans }}
                            </twig:Badge>
                            {% if profile.language %}
                                <twig:Badge variant="secondary" class="rounded-full">
                                    {{ profile.language.value|upper }}
                                </twig:Badge>
                            {% endif %}
                            {% if profile.isProfileComplete %}
                                <twig:Badge variant="secondary" class="rounded-full">
                                    {{ 'admin.users.profile.profileComplete.yes'|trans }}
                                </twig:Badge>
                            {% else %}
                                <twig:Badge variant="secondary" class="rounded-full">
                                    {{ 'admin.users.profile.profileComplete.no'|trans }}
                                </twig:Badge>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section class="grid grid-cols-1 gap-6 sm:grid-cols-2">
            {% set authMethodKey = profile.hasGoogleAuth ? 'google' : 'password' %}
            {% set lastLoginValue = profile.lastLoginAt
                ? profile.lastLoginAt|format_datetime('medium', 'short', locale=app.request.locale)
                : 'admin.users.lastLoginNever'|trans %}

            {% set facts = [
                {
                    label: 'admin.users.profile.field.createdAt'|trans,
                    value: profile.createdAt|format_date('long', locale=app.request.locale),
                },
                {
                    label: 'admin.users.profile.field.lastLogin'|trans,
                    value: lastLoginValue,
                },
                {
                    label: 'admin.users.profile.field.authMethod'|trans,
                    value: ('admin.users.profile.authMethod.' ~ authMethodKey)|trans,
                },
                {
                    label: 'admin.users.profile.field.uniqueId'|trans,
                    value: profile.uniqueId,
                },
            ] %}

            {% for fact in facts %}
                <article class="rounded-2xl border border-gray-950/5 bg-white p-2">
                    <div class="rounded-xl bg-linear-to-b from-neutral-100/50 to-neutral-100/0 p-4">
                        <p class="text-xs font-medium tracking-wide text-gray-500 uppercase">{{ fact.label }}</p>
                        <p class="mt-2 truncate font-medium text-gray-900">{{ fact.value }}</p>
                    </div>
                </article>
            {% endfor %}
        </section>
    </div>
{% endblock %}
