{% extends 'admin/base.html.twig' %}

{% block title %}{{ 'admin.users.title'|trans }}{% endblock %}
{% block page_title %}{{ 'admin.users.title'|trans }}{% endblock %}

{% block body %}
    <div class="space-y-8" data-testid="users-page">
        <header>
            <p class="text-xs font-medium tracking-wide text-gray-500 uppercase">
                {{ 'admin.users.section'|trans }}
            </p>
            <h2 class="mt-2 max-w-[40ch] text-2xl font-semibold tracking-tight text-balance text-gray-900">
                {{ 'admin.users.subtitle'|trans }}
            </h2>
        </header>

        <twig:Admin:UserList adminPrefix="{{ adminPrefix }}" />
    </div>
{% endblock %}
