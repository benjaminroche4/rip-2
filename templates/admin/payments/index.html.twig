{% extends 'admin/base.html.twig' %}

{% block title %}{{ 'admin.payments.title'|trans }}{% endblock %}

{% block page_header %}
    <twig:Admin:PageHeader
        title="{{ 'admin.payments.title'|trans }}"
        subtitle="{{ 'admin.payments.subtitle'|trans }}"
    />
{% endblock %}

{% block body %}
    {# Lazy turbo-frame: header renders immediately, the data fragment
       is fetched in a second request. The default child below is shown
       until the frame's `src` resolves, giving the admin a visible
       loading state instead of an empty screen during the ~1-2s Stripe
       roundtrip. #}
    <turbo-frame
        id="payments-body"
        src="{{ path('admin_payments_data', {adminPrefix: adminPrefix}) }}"
        loading="lazy"
        data-testid="payments-body"
    >
        <div class="flex flex-col items-center justify-center gap-3 py-20 text-gray-400" data-testid="payments-loading">
            <twig:Spinner class="size-8" />
            <p class="text-sm">{{ 'admin.payments.loading'|trans }}</p>
        </div>
    </turbo-frame>
{% endblock %}
