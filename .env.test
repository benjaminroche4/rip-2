# define your env variables for the test env here
KERNEL_CLASS='App\Kernel'
APP_SECRET='$ecretf0rt3st'

# Admin URL secret for test runs only — not a real secret, just satisfies the
# 16-64 chars regex on the {adminPrefix} route requirement so AdminAccessTest
# can hit /fr/<prefix>/admin. Production uses ADMIN_PATH_PREFIX from .env.local.
ADMIN_PATH_PREFIX=test_admin_prefix_1234567890abcdef
